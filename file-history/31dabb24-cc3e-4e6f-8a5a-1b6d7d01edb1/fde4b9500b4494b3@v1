"use client"

import { useState, useRef } from "react"
import { Download, Loader2, FileText, CheckCircle, Check, Link2 } from "lucide-react"
import { toast } from "sonner"
import Link from "next/link"
import { Button } from "@/components/ui/button"
import { Badge } from "@/components/ui/badge"
import {
  AlertDialog,
  AlertDialogAction,
  AlertDialogCancel,
  AlertDialogContent,
  AlertDialogDescription,
  AlertDialogFooter,
  AlertDialogHeader,
  AlertDialogTitle,
} from "@/components/ui/alert-dialog"
import { cn } from "@/lib/utils"
import { MarkdownRenderer } from "@/components/markdown-renderer"
import type { ProposalSection, ProposalStatus, ProposalInteresse, ProposalModelo } from "@/lib/proposal-types"
import { formatDateShort } from "@/lib/proposal-types"

interface ProposalDocumentProps {
  empresa: string
  para?: string
  projeto?: string
  proposalNumber: string
  dataCriacao: number
  sections: ProposalSection[]
  highlightedSections: Set<string>
  status: ProposalStatus
  interesse?: ProposalInteresse
  modeloTrabalho?: ProposalModelo
  projetoGeradoId?: string
  projetoGeradoNome?: string
  onMarkConcluida?: () => void
  onAprovar?: () => void
}

export function ProposalDocument({
  empresa,
  para,
  projeto,
  proposalNumber,
  dataCriacao,
  sections,
  highlightedSections,
  status,
  interesse,
  modeloTrabalho,
  projetoGeradoId,
  projetoGeradoNome,
  onMarkConcluida,
  onAprovar,
}: ProposalDocumentProps) {
  const [downloading, setDownloading] = useState(false)
  const [approveOpen, setApproveOpen] = useState(false)
  const documentRef = useRef<HTMLDivElement>(null)

  async function handleDownloadPDF() {
    if (sections.length === 0) return
    setDownloading(true)
    try {
      const { jsPDF } = await import("jspdf")

      // Load letterhead images
      const toB64 = async (url: string): Promise<string> => {
        const res = await fetch(url)
        const blob = await res.blob()
        return new Promise((resolve) => {
          const reader = new FileReader()
          reader.onload = () => resolve(reader.result as string)
          reader.readAsDataURL(blob)
        })
      }
      const logoB64 = await toB64("/wa-logo-footer.png")

      const doc = new jsPDF({ orientation: "portrait", unit: "mm", format: "a4" })

      const PW = doc.internal.pageSize.getWidth()   // 210
      const PH = doc.internal.pageSize.getHeight()  // 297
      const ML = 20
      const MR = 20
      const MT = 24
      const CW = PW - ML - MR
      const FY = PH - 27  // footer line y (~270mm)

      let pageNum = 1

      const drawPageBase = () => {
        // Footer line (#efefef, 0.5pt)
        doc.setDrawColor(239, 239, 239)
        doc.setLineWidth(0.5)
        doc.line(ML, FY, PW - MR, FY)

        // WaProject logo: 26.76mm × 9.23mm (from DOCX EMU dimensions)
        doc.addImage(logoB64, "PNG", ML, FY + 4, 26.76, 9.23)

        // Page number: right-aligned, bold, #0047ba
        doc.setFont("helvetica", "bold")
        doc.setFontSize(9)
        doc.setTextColor(0, 71, 186)
        doc.text(String(pageNum), PW - MR, FY + 10, { align: "right" })
      }

      drawPageBase()
      let y = MT

      const checkY = (needed: number) => {
        if (y + needed > FY - 8) {
          doc.addPage()
          pageNum++
          drawPageBase()
          y = MT
        }
      }

      const clean = (t: string) => t.replace(/\*\*/g, "").replace(/\*/g, "")

      // Header title
      doc.setFontSize(13)
      doc.setFont("helvetica", "bold")
      doc.setTextColor(0, 59, 113)
      doc.text("PROPOSTA COMERCIAL — PROJETO SOB MEDIDA", ML, y)
      y += 7

      if (modeloTrabalho && modeloTrabalho !== "Vazio") {
        doc.setFontSize(8)
        doc.setFont("helvetica", "bold")
        doc.setTextColor(0, 86, 163)
        doc.text(`MODELO DE CONTRATAÇÃO: ${modeloTrabalho.toUpperCase()}`, ML, y)
        y += 5
      }


      // Meta grid (2 columns)
      y += 3
      const metas: [string, string][] = [
        ["PARA", para || "—"],
        ["EMPRESA", empresa || "—"],
        ["VALIDADE", "30 dias"],
        ["PROPOSTA Nº", `WA-${proposalNumber}`],
      ]
      const col2X = ML + CW / 2 + 5
      for (let i = 0; i < metas.length; i += 2) {
        checkY(5.5)
        const [l1, v1] = metas[i]
        doc.setFontSize(8.5); doc.setFont("helvetica", "bold"); doc.setTextColor(0, 59, 113)
        doc.text(`${l1}:`, ML, y)
        doc.setFont("helvetica", "normal"); doc.setTextColor(51, 65, 85)
        doc.text(v1, ML + 23, y)
        if (metas[i + 1]) {
          const [l2, v2] = metas[i + 1]
          doc.setFont("helvetica", "bold"); doc.setTextColor(0, 59, 113)
          doc.text(`${l2}:`, col2X, y)
          doc.setFont("helvetica", "normal"); doc.setTextColor(51, 65, 85)
          doc.text(v2, col2X + 27, y)
        }
        y += 5
      }

      // Separator
      y += 4
      doc.setDrawColor(210, 210, 210); doc.setLineWidth(0.25)
      doc.line(ML, y, PW - MR, y)
      y += 8

      // Sections
      for (const section of sections) {
        checkY(18)

        // Section title — 12pt bold primary blue + underline
        doc.setFontSize(12); doc.setFont("helvetica", "bold"); doc.setTextColor(0, 59, 113)
        const titleLines = doc.splitTextToSize(section.title, CW) as string[]
        for (const tl of titleLines) { doc.text(tl, ML, y); y += 6.5 }
        doc.setDrawColor(0, 59, 113); doc.setLineWidth(0.4)
        doc.line(ML, y, ML + 40, y)
        y += 6

        // Content lines
        let numCounter = 0
        for (const line of section.content.split("\n")) {
          const t = line.trim()
          if (!t) { numCounter = 0; y += 2; continue }
          if (/^-{1,3}$/.test(t)) continue
          if (/^[-*•✅❌]?\s*(PARA|EMPRESA|DATA|VALIDADE|TIPO|MODELO|PROPOSTA\s*N[ºo°]?):/i.test(t)) continue

          const h1m = t.match(/^#\s+(.+)$/)
          const h2m = t.match(/^##\s+(.+)$/)
          const h3m = t.match(/^###\s+(.+)$/)
          const lim = t.match(/^[-*•✅❌✓✗]\s+(.+)$/)
          const numm = t.match(/^(\d+)\.\s+(.+)$/)

          if (h1m || h2m || h3m) {
            numCounter = 0
            const txt = clean((h3m || h2m || h1m)![1])
            // h2 → 10.5pt primary blue; h3 → 9.5pt dark gray; h1 → 11pt primary blue
            const fs = h1m ? 11 : h2m ? 10.5 : 9.5
            const color: [number, number, number] = (h1m || h2m) ? [0, 59, 113] : [55, 65, 81]
            checkY(10); y += 3
            doc.setFontSize(fs); doc.setFont("helvetica", "bold"); doc.setTextColor(...color)
            const ls = doc.splitTextToSize(txt, CW) as string[]
            for (const l of ls) { checkY(6); doc.text(l, ML, y); y += fs * 0.52 }
            y += 1
          } else if (lim) {
            numCounter = 0
            const txt = clean(lim[1])
            const textX = ML + 7; const textW = CW - 7
            checkY(5)
            doc.setFillColor(0, 59, 113)
            doc.circle(ML + 2.5, y - 1.3, 0.8, "F")
            doc.setFontSize(9); doc.setFont("helvetica", "normal"); doc.setTextColor(55, 65, 81)
            const ls = doc.splitTextToSize(txt, textW) as string[]
            for (let i = 0; i < ls.length; i++) {
              if (i > 0) checkY(4.5)
              doc.text(ls[i], textX, y); y += 4.5
            }
          } else if (numm) {
            // Numbered list — show actual number
            const num = numm[1]
            const txt = clean(numm[2])
            const textX = ML + 7; const textW = CW - 7
            checkY(5)
            doc.setFontSize(9); doc.setFont("helvetica", "bold"); doc.setTextColor(0, 59, 113)
            doc.text(`${num}.`, ML, y)
            doc.setFont("helvetica", "normal"); doc.setTextColor(55, 65, 81)
            const ls = doc.splitTextToSize(txt, textW) as string[]
            for (let i = 0; i < ls.length; i++) {
              if (i > 0) checkY(4.5)
              doc.text(ls[i], textX, y); y += 4.5
            }
          } else {
            numCounter = 0
            const txt = clean(t)
            checkY(5)
            const isBold = /^\*\*/.test(t)
            doc.setFontSize(9); doc.setFont("helvetica", isBold ? "bold" : "normal")
            doc.setTextColor(isBold ? 30 : 75, isBold ? 41 : 85, isBold ? 59 : 99)
            const ls = doc.splitTextToSize(txt, CW) as string[]
            for (const l of ls) { checkY(4.5); doc.text(l, ML, y); y += 4.5 }
          }
        }
        y += 10
      }

      const sanitizedName = (empresa || "SemEmpresa").replace(/\s+/g, "_")
      const dateStr = formatDateShort(dataCriacao).replace(/\//g, "-")
      doc.save(`Proposta_${sanitizedName}_${dateStr}.pdf`)
      toast.success("PDF gerado com sucesso!")
    } catch (err) {
      console.error("[ProposalDocument] PDF error:", err)
      toast.error("Erro ao gerar o PDF.")
    } finally {
      setDownloading(false)
    }
  }

  function getStatusBadge() {
    switch (status) {
      case "Aprovada":
        return <Badge className="bg-primary text-primary-foreground hover:bg-primary">Aprovada</Badge>
      case "Concluída":
        return <Badge className="bg-[#dcfce7] text-[#16a34a] hover:bg-[#dcfce7]">Concluída</Badge>
      case "Rascunho":
      default:
        return <Badge className="bg-[#fef3c7] text-[#a16207] hover:bg-[#fef3c7]">Rascunho</Badge>
    }
  }

  return (
    <div className="flex h-full flex-col rounded-lg border border-border bg-card shadow-sm">
      {/* Header */}
      <div className="flex flex-wrap items-center justify-between gap-2 border-b border-border px-4 py-3">
        <div className="flex items-center gap-2">
          <h2 className="text-sm font-semibold text-foreground">Proposta Comercial</h2>
          {sections.length > 0 && getStatusBadge()}
        </div>
        <div className="flex flex-wrap items-center gap-2">
          <Button
            variant="outline"
            size="sm"
            onClick={handleDownloadPDF}
            disabled={downloading || sections.length === 0}
            className="text-primary border-primary/30 hover:bg-secondary"
          >
            {downloading ? (
              <Loader2 className="mr-1.5 h-3.5 w-3.5 animate-spin" />
            ) : (
              <Download className="mr-1.5 h-3.5 w-3.5" />
            )}
            Baixar PDF
          </Button>
          {/* Mark as Concluida - visible when Rascunho and has content */}
          {status === "Rascunho" && sections.length > 0 && onMarkConcluida && (
            <Button
              variant="outline"
              size="sm"
              onClick={onMarkConcluida}
              className="border-[#16a34a]/30 text-[#16a34a] hover:bg-[#dcfce7]"
            >
              <CheckCircle className="mr-1.5 h-3.5 w-3.5" />
              Marcar como Concluída
            </Button>
          )}
          {/* Aprovar Proposta - visible when Concluída */}
          {status === "Concluída" && onAprovar && (
            <Button
              size="sm"
              onClick={() => setApproveOpen(true)}
              className="bg-[#16a34a] text-primary-foreground hover:bg-[#15803d]"
            >
              <CheckCircle className="mr-1.5 h-3.5 w-3.5" />
              Aprovar Proposta
            </Button>
          )}
        </div>
      </div>

      {/* Approved info banner */}
      {status === "Aprovada" && projetoGeradoId && (
        <div className="flex items-center gap-3 border-b border-border bg-secondary px-4 py-3">
          <Link2 className="h-4 w-4 shrink-0 text-primary" />
          <p className="text-sm text-primary">
            {"Esta proposta foi aprovada e gerou o projeto "}
            <strong>{`"${projetoGeradoNome || ""}"`}</strong>.{" "}
            <Link href={`/dashboard/projetos/${projetoGeradoId}`} className="font-medium underline underline-offset-2 hover:text-primary/90">
              Ver Projeto
            </Link>
          </p>
        </div>
      )}

      {/* Document content */}
      <div ref={documentRef} className="flex-1 overflow-y-auto p-4 lg:p-6">
        {sections.length === 0 ? (
          <div className="flex h-full flex-col items-center justify-center rounded-lg border-2 border-dashed border-border p-6 text-center">
            <FileText className="mb-3 h-12 w-12 text-muted-foreground/40" />
            <p className="text-sm font-medium text-muted-foreground">
              A proposta sera gerada aqui conforme voce fornecer informacoes ao assistente.
            </p>
            <p className="mt-1 text-xs text-muted-foreground">
              Comece a conversa ao lado!
            </p>
          </div>
        ) : (
          <div className="mx-auto max-w-[700px] rounded-lg border border-border bg-card p-4 shadow-md lg:p-8">
            {/* Document Header */}
            <div className="mb-6 border-b border-border pb-6">
              <div className="mb-4 text-center">
                <h1 className="text-base font-extrabold uppercase tracking-widest text-primary lg:text-lg">
                  PROPOSTA COMERCIAL — PROJETO SOB MEDIDA
                </h1>
                {modeloTrabalho && modeloTrabalho !== "Vazio" && (
                  <p className="mt-1.5 text-[11px] font-semibold uppercase tracking-widest text-primary/70">
                    MODELO DE CONTRATAÇÃO: {modeloTrabalho.toUpperCase()}
                  </p>
                )}
              </div>
              <div className="mx-auto mb-4 h-px w-16 bg-primary/30" />
              <div className="grid grid-cols-2 gap-x-6 gap-y-1.5">
                {[
                  ["PARA", para || "—"],
                  ["EMPRESA", empresa || "—"],
                  ["PROJETO", projeto || "—"],
                  ["DATA", formatDateShort(dataCriacao)],
                  ["VALIDADE", "30 dias"],
                  ["PROPOSTA Nº", `WA-${proposalNumber}`],
                ].map(([label, value]) => (
                  <div key={label} className="flex gap-1.5 text-xs lg:text-sm">
                    <span className="min-w-[90px] shrink-0 font-bold text-foreground">{label}:</span>
                    <span className="text-foreground/70">{value}</span>
                  </div>
                ))}
              </div>
            </div>

            {/* Sections */}
            <div className="flex flex-col gap-6">
              {sections.map((section) => (
                <div
                  key={section.key}
                  className={cn(
                    "rounded-md px-3 py-2 transition-colors",
                    highlightedSections.has(section.key) && "section-highlight"
                  )}
                >
                  <h2 className="mb-3 border-b border-border/60 pb-1.5 text-sm font-bold text-primary lg:text-base">
                    {section.title}
                  </h2>
                  <MarkdownRenderer
                    content={section.content
                      .split("\n")
                      .filter((l) => {
                        const t = l.trim()
                        if (/^-{1,3}$/.test(t)) return false
                        if (/^[-*•✅❌]?\s*(PARA|EMPRESA|DATA|VALIDADE|TIPO|MODELO|PROPOSTA\s*N[ºo°]?):/i.test(t)) return false
                        return true
                      })
                      .join("\n")}
                    className="prose-h3:text-primary prose-h3:font-semibold prose-h4:text-foreground/90"
                  />
                </div>
              ))}
            </div>
          </div>
        )}
      </div>

      {/* Approve confirmation dialog */}
      <AlertDialog open={approveOpen} onOpenChange={setApproveOpen}>
        <AlertDialogContent>
          <AlertDialogHeader>
            <div className="mb-2 flex justify-center">
              <div className="flex h-12 w-12 items-center justify-center rounded-full bg-[#dcfce7]">
                <CheckCircle className="h-6 w-6 text-[#16a34a]" />
              </div>
            </div>
            <AlertDialogTitle className="text-center">Aprovar Proposta</AlertDialogTitle>
            <AlertDialogDescription className="text-center">
              Ao aprovar esta proposta, as seguintes acoes serao realizadas automaticamente:
            </AlertDialogDescription>
          </AlertDialogHeader>
          <div className="flex flex-col gap-2 rounded-lg bg-secondary/50 p-4">
            <div className="flex items-start gap-2">
              <Check className="mt-0.5 h-4 w-4 shrink-0 text-[#16a34a]" />
              <span className="text-sm text-foreground">
                {`Um novo projeto sera criado com o nome "${empresa}"`}
              </span>
            </div>
            <div className="flex items-start gap-2">
              <Check className="mt-0.5 h-4 w-4 shrink-0 text-[#16a34a]" />
              <span className="text-sm text-foreground">
                A proposta comercial sera adicionada a base de conhecimento do novo projeto
              </span>
            </div>
            <div className="flex items-start gap-2">
              <Check className="mt-0.5 h-4 w-4 shrink-0 text-[#16a34a]" />
              <span className="text-sm text-foreground">
                {`O status da proposta sera alterado para "Aprovada"`}
              </span>
            </div>
          </div>
          <p className="text-center text-xs text-muted-foreground">Deseja prosseguir?</p>
          <AlertDialogFooter>
            <AlertDialogCancel>Cancelar</AlertDialogCancel>
            <AlertDialogAction
              onClick={() => {
                setApproveOpen(false)
                onAprovar?.()
              }}
              className="bg-[#16a34a] text-primary-foreground hover:bg-[#15803d]"
            >
              Aprovar
            </AlertDialogAction>
          </AlertDialogFooter>
        </AlertDialogContent>
      </AlertDialog>
    </div>
  )
}

