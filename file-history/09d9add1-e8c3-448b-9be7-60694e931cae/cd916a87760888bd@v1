interface AppointmentModalProps {
  isOpen: boolean;
  onClose: () => void;
  preSelectedDate?: Date;
  preSelectedTime?: string;
  preSelectedProfessionalId?: string;
  onSuccess?: () => void;
}

interface TimeSlot {
  time: string;
  available: boolean;
}

// Função de busca inteligente que ignora case, acentos e permite busca parcial
const normalizeString = (str: string): string => {
  return str
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "") // Remove acentos
    .replace(/[^a-z0-9\s]/g, ""); // Remove caracteres especiais
};

// Função de busca flexível que funciona com diferentes formatos de texto
const smartSearch = (searchTerm: string, target: string): boolean => {
  if (!searchTerm || !target) return true;

  const normalizedSearch = normalizeString(searchTerm);
  const normalizedTarget = normalizeString(target);

  // Busca exata
  if (normalizedTarget.includes(normalizedSearch)) {
    return true;
  }

  // Busca por palavras separadas (permite buscar "jo si" para encontrar "João Silva")
  const searchWords = normalizedSearch
    .split(/\s+/)
    .filter((word) => word.length > 0);
  return searchWords.every((word) => normalizedTarget.includes(word));
};

export function AppointmentModal({
  isOpen,
  onClose,
  preSelectedDate,
  preSelectedTime,
  preSelectedProfessionalId,
  onSuccess,
}: AppointmentModalProps) {
  const { selectedSalon } = useSelectedSalon();
  const { user } = useAuth();
  const [loading, setLoading] = useState(false);
  const [saving, setSaving] = useState(false);
  const [loadingSlots, setLoadingSlots] = useState(false);

  // Usar ref para controlar execução e evitar múltiplas chamadas
  const loadingSlotsRef = useRef(false);
  const lastLoadedKey = useRef<string>("");

  // Lists
  const [clients, setClients] = useState<Client[]>([]);
  const [services, setServices] = useState<Service[]>([]);
  const [professionals, setProfessionals] = useState<User[]>([]);
  const [timeSlots, setTimeSlots] = useState<TimeSlot[]>([]);

  // Form data - Step by step
  const [selectedClient, setSelectedClient] = useState<string>("");
  const [selectedService, setSelectedService] = useState<string>("");
  const [selectedProfessional, setSelectedProfessional] = useState<string>("");
  const [selectedDate, setSelectedDate] = useState<Date>(() => {
    // Garantir que sempre temos uma data válida
    if (
      preSelectedDate &&
      preSelectedDate instanceof Date &&
      !isNaN(preSelectedDate.getTime())
    ) {
      return preSelectedDate;
    }
    return new Date();
  });
  const [selectedTime, setSelectedTime] = useState<string>("");
  const [notes, setNotes] = useState<string>("");

  // UI State
  const [isDatePickerOpen, setIsDatePickerOpen] = useState(false);
  const [currentStep, setCurrentStep] = useState(1); // 1 = selection, 2 = scheduling

  // Search states for dropdowns
  const [clientSearchQuery, setClientSearchQuery] = useState<string>("");
  const [serviceSearchQuery, setServiceSearchQuery] = useState<string>("");
  const [professionalSearchQuery, setProfessionalSearchQuery] =
    useState<string>("");

  // Callbacks memoizados para evitar re-renderizações
  const handleClientSearchChange = useCallback((value: string) => {
    setClientSearchQuery(value);
  }, []);

  const handleServiceSearchChange = useCallback((value: string) => {
    setServiceSearchQuery(value);
  }, []);

  const handleProfessionalSearchChange = useCallback((value: string) => {
    setProfessionalSearchQuery(value);
  }, []);

  // Load initial data when modal opens
  useEffect(() => {
    if (isOpen && selectedSalon?.id) {
      loadInitialData();
      // Pre-select date if provided and valid
      if (
        preSelectedDate &&
        preSelectedDate instanceof Date &&
        !isNaN(preSelectedDate.getTime())
      ) {
        setSelectedDate(preSelectedDate);
      }
      // Pre-select professional if provided, or if user is a professional
      if (user?.role === "Profissional" && user?.id) {
        setSelectedProfessional(user.id);
      } else if (preSelectedProfessionalId) {
        setSelectedProfessional(preSelectedProfessionalId);
      }
      // Pre-select time if provided
      if (preSelectedTime) {
        setSelectedTime(preSelectedTime);
      }
    }
  }, [
    isOpen,
    selectedSalon?.id,
    preSelectedDate,
    preSelectedProfessionalId,
    preSelectedTime,
  ]);

  // Load clients and services on mount
  const loadInitialData = async () => {
    if (!selectedSalon?.id) {
      toast.error("Nenhum salão selecionado");
      return;
    }

    try {
      setLoading(true);

      // Load clients from the salon
      const clientsResponse = await clientService.getAll({
        salonId: selectedSalon.id,
        active: true,
      });
      setClients(clientsResponse || []);

      // Load only bookable services using the new dedicated endpoint
      // Pass salonId and tenantId to get salon-specific pricing
      const servicesResponse = await serviceService.getBookableServices(
        selectedSalon.id,
        selectedSalon.tenantId
      );

      // CRITICAL VALIDATION: Check if services have category
      const servicesWithoutCategory =
        servicesResponse?.filter((s) => !s.categoryId) || [];
      if (servicesWithoutCategory.length > 0) {
        toast.warning(
          `${servicesWithoutCategory.length} serviços sem categoria foram detectados. Entre em contato com o suporte.`
        );
      }

      // Filter only services with valid category
      const validServices = servicesResponse?.filter((s) => s.categoryId) || [];

      if (validServices.length === 0) {
        toast.error(
          "Nenhum serviço válido disponível. Verifique se os serviços têm categoria definida."
        );
      }

      setServices(validServices);
    } catch (error) {
      toast.error("Erro ao carregar dados. Por favor, tente novamente.");
    } finally {
      setLoading(false);
    }
  };

  // When service is selected, load professionals who offer this service
  useEffect(() => {
    if (selectedService) {
      loadProfessionalsForService();
    } else {
      setProfessionals([]);
      setSelectedProfessional("");
    }
  }, [selectedService]);

  // Helper function to check if professional has availability on the selected date
  const isProfessionalAvailableOnDate = async (
    professional: User,
    date: Date,
    salonId: string
  ): Promise<boolean> => {
    try {
      const dayOfWeek = date.getDay();
      const dayNames = [
        "sunday",
        "monday",
        "tuesday",
        "wednesday",
        "thursday",
        "friday",
        "saturday",
      ];
      const dayName = dayNames[dayOfWeek];

      // Get salon schedule for this day
      const salonSchedule = await salonService.getWorkingHours(salonId);
      const salonDaySchedule = salonSchedule.find(
        (sh) => Number(sh.dayOfWeek) === dayOfWeek
      );

      // If salon is closed on this day, professional can't work
      if (!salonDaySchedule || !salonDaySchedule.isOpen) {
        return false;
      }

      // Get salon end time for this day
      const salonEndTime = salonDaySchedule.close || "18:00";

      // Check professional's schedule for this day
      let professionalDaySchedule = null;
      if (professional.schedule) {
        // Try by day name first, then by day number
        professionalDaySchedule =
          professional.schedule[dayName] ||
          professional.schedule[dayOfWeek.toString()] ||
          professional.schedule[dayOfWeek];
      }

      // Determine the final end time for the professional
      let finalEndTime: string;

      if (professionalDaySchedule) {
        // Professional has schedule for this day
        // Check if has breaks, if yes, use the last break end time, otherwise use endTime
        const professionalEndTime =
          professionalDaySchedule.endTime || professionalDaySchedule.end || "";
        const breaks = professionalDaySchedule.breaks || [];

        if (breaks.length > 0) {
          // Find the last break end time
          const lastBreakEndTime = breaks.reduce(
            (latest: string, breakPeriod: any) => {
              const breakEnd = breakPeriod.end || breakPeriod.endTime || "";
              if (!latest) return breakEnd;
              return breakEnd > latest ? breakEnd : latest;
            },
            ""
          );

          // Use the greater between professional end time and last break end
          finalEndTime =
            lastBreakEndTime > professionalEndTime
              ? lastBreakEndTime
              : professionalEndTime;
        } else {
          finalEndTime = professionalEndTime;
        }

        // If professional has no valid end time, inherit from salon
        if (!finalEndTime || finalEndTime.trim() === "") {
          finalEndTime = salonEndTime;
        }
      } else {
        // Professional has no schedule for this day - inherit salon end time
        finalEndTime = salonEndTime;
      }

      // Now check if the final end time is >= current time (only if selected date is today)
      const isSelectedDateToday = isToday(date);

      if (isSelectedDateToday) {
        const now = new Date();
        const currentTimeInMinutes = now.getHours() * 60 + now.getMinutes();

        const [endHour, endMinute] = finalEndTime.split(":").map(Number);
        const finalEndTimeInMinutes = endHour * 60 + endMinute;

        if (finalEndTimeInMinutes <= currentTimeInMinutes) {
          return false;
        }
      }

      return true;
    } catch (error) {
      console.error(
        `Error checking availability for ${professional.name}:`,
        error
      );
      return false;
    }
  };

  const loadProfessionalsForService = async () => {
    if (!selectedSalon?.id) {
      return;
    }

    try {
      setLoading(true);

      // Get all professionals from the salon with their schedules
      const professionalsResponse = await userService.getAll({
        salonId: selectedSalon.id,
        role: "professional",
        active: true,
      });

      // For each professional, fetch their services
      const professionalsWithServices = await Promise.all(
        professionalsResponse.map(async (prof) => {
          try {
            const userServices = await userService.getUserServices(prof.id);
            return {
              ...prof,
              userServices: userServices || [],
            };
          } catch (error) {
            console.error(`❌ Error loading services for ${prof.name}:`, error);
            return {
              ...prof,
              userServices: [],
            };
          }
        })
      );

      // Filter professionals who:
      // 1. Offer the selected service
      // 2. Are available on the selected date
      const filteredProfessionalsPromises = professionalsWithServices.map(
        async (prof) => {
          // Check if professional has the selected service
          const hasService = prof.userServices.some((us) => {
            return (
              (us.serviceId === selectedService || us.id === selectedService) &&
              us.isActive !== false
            );
          });

          if (!hasService) {
            return null;
          }

          // Check if professional is available on the selected date
          const isAvailable = await isProfessionalAvailableOnDate(
            prof,
            selectedDate,
            selectedSalon.id
          );

          if (isAvailable) {
            return prof;
          } else {
            return null;
          }
        }
      );

      const filteredProfessionalsResults = await Promise.all(
        filteredProfessionalsPromises
      );
      const filteredProfessionals = filteredProfessionalsResults.filter(
        (p) => p !== null
      ) as User[];

      setProfessionals(filteredProfessionals);

      // If there's a pre-selected professional and they're available, keep them selected
      if (
        preSelectedProfessionalId &&
        filteredProfessionals.some((p) => p.id === preSelectedProfessionalId)
      ) {
        setSelectedProfessional(preSelectedProfessionalId);
      } else {
        setSelectedProfessional("");
      }
    } catch (error) {
      console.error("Error loading professionals:", error);
      toast.error("Erro ao carregar profissionais");
    } finally {
      setLoading(false);
    }
  };

  // When professional and date are selected, load available time slots
  useEffect(() => {
    // Criar um abort controller para cancelar requisições pendentes
    const abortController = new AbortController();
    let isMounted = true;

    const loadSlots = async () => {
      if (
        selectedProfessional &&
        selectedService &&
        selectedDate &&
        currentStep === 2
      ) {
        // Só executar se o componente ainda estiver montado
        if (isMounted) {
          await loadAvailableTimeSlots();
        }
      } else {
        if (isMounted) {
          setTimeSlots([]);
        }
      }
    };

    loadSlots();

    // Cleanup function
    return () => {
      isMounted = false;
      abortController.abort();
    };
  }, [selectedProfessional, selectedService, selectedDate, currentStep]);

  // Usar useCallback para evitar recreação da função
  const loadAvailableTimeSlots = useCallback(async () => {
    // Criar uma chave única para esta combinação
    const loadKey = `${selectedProfessional}-${selectedService}-${format(
      selectedDate,
      "yyyy-MM-dd"
    )}`;

    // Verificar se já está carregando ou se já foi carregado
    if (loadingSlotsRef.current) {
      return;
    }

    if (lastLoadedKey.current === loadKey) {
      return;
    }

    try {
      loadingSlotsRef.current = true;
      lastLoadedKey.current = loadKey;

      setLoadingSlots(true);
      setTimeSlots([]); // Clear previous slots

      // Status baseados no enum AppointmentStatus
      // Status que NÃO bloqueiam horários:
      // COMPLETED = agendamento já foi realizado
      // CANCELLED = agendamento foi cancelado
      // NO_SHOW = cliente não compareceu
      const NON_BLOCKING_STATUSES = [
        AppointmentStatus.COMPLETED,
        AppointmentStatus.CANCELLED,
        AppointmentStatus.NO_SHOW,
      ];

      // Status que BLOQUEIAM horários:
      // SCHEDULED = agendado mas não confirmado
      // CONFIRMED = confirmado
      // IN_PROGRESS = em andamento
      const BLOCKING_STATUSES = [
        AppointmentStatus.SCHEDULED,
        AppointmentStatus.CONFIRMED,
        AppointmentStatus.IN_PROGRESS,
      ];

      // REGRA 1: Buscar os horários do salão
      const dayOfWeek = selectedDate.getDay();
      const dayNames = [
        "sunday",
        "monday",
        "tuesday",
        "wednesday",
        "thursday",
        "friday",
        "saturday",
      ];
      const dayName = dayNames[dayOfWeek];

      const salonSchedule = await salonService.getWorkingHours(
        selectedSalon.id
      );

      const salonDaySchedule = salonSchedule.find((sh) => {
        // Garantir comparação numérica
        const scheduleDay = Number(sh.dayOfWeek);
        const targetDay = Number(dayOfWeek);
        return scheduleDay === targetDay;
      });

      // Se o salão está fechado neste dia, retornar vazio
      if (!salonDaySchedule || !salonDaySchedule.isOpen) {
        setTimeSlots([]);
        return;
      }

      // REGRA 2: Buscar os horários do profissional caso ele tenha
      let professional = professionals.find(
        (p) => p.id === selectedProfessional
      );

      // Se profissional não está no cache, buscar da API
      if (!professional) {
        try {
          professional = await userService.getById(selectedProfessional);
        } catch (error) {
          console.error("❌ Erro ao buscar profissional:", error);
          return;
        }
      }

      if (!professional) {
        console.error("❌ Profissional não encontrado");
        return;
      }

      // O schedule pode vir em diferentes formatos:
      // 1. Com chaves nomeadas: { monday: {...}, tuesday: {...} }
      // 2. Com chaves numéricas: { "0": {...}, "1": {...} }
      // 3. Pode usar start/end ou startTime/endTime
      let professionalDaySchedule = null;

      if (professional.schedule) {
        // Tentar buscar por nome do dia primeiro
        professionalDaySchedule = professional.schedule[dayName];

        // Se não encontrar, tentar por número
        if (!professionalDaySchedule) {
          professionalDaySchedule = professional.schedule[dayOfWeek.toString()];
        }

        // Se ainda não encontrar, tentar por número sem conversão
        if (!professionalDaySchedule) {
          professionalDaySchedule = professional.schedule[dayOfWeek];
        }
      }

      // Funções auxiliares para conversão de tempo
      function timeToMinutes(time: string): number {
        if (!time || time.trim() === "") return 0;
        const [hours, minutes] = time.split(":").map(Number);
        return hours * 60 + minutes;
      }

      function minutesToTime(minutes: number): string {
        const hours = Math.floor(minutes / 60);
        const mins = minutes % 60;
        return `${hours.toString().padStart(2, "0")}:${mins
          .toString()
          .padStart(2, "0")}`;
      }

      // Função para converter horário UTC para minutos locais
      function utcDateToLocalMinutes(utcDate: Date): number {
        const localDate = new Date(utcDate);
        return localDate.getHours() * 60 + localDate.getMinutes();
      }

      // SEMPRE usar os horários do salão como base
      const salonStartStr = salonDaySchedule.open || "09:00";
      const salonEndStr = salonDaySchedule.close || "18:00";
      const [salonStartHour, salonStartMinute] = salonStartStr
        .split(":")
        .map(Number);
      const [salonEndHour, salonEndMinute] = salonEndStr.split(":").map(Number);
      const salonStartMinutes = salonStartHour * 60 + salonStartMinute;
      const salonEndMinutes = salonEndHour * 60 + salonEndMinute;

      // Determinar horário efetivo do profissional
      let professionalStartMinutes: number | null = null;
      let professionalEndMinutes: number | null = null;
      let professionalBreaks: any[] = [];

      if (professionalDaySchedule && professionalDaySchedule.isWorking) {
        // Profissional tem horário definido e está trabalhando
        // O backend pode enviar start/end ou startTime/endTime
        let profStartStr =
          professionalDaySchedule.start ||
          professionalDaySchedule.startTime ||
          "";
        let profEndStr =
          professionalDaySchedule.end || professionalDaySchedule.endTime || "";

        // REGRA 4: Se profissional tem strings vazias, herdar do salão
        if (!profStartStr || profStartStr.trim() === "") {
          profStartStr = salonStartStr;
        }
        if (!profEndStr || profEndStr.trim() === "") {
          profEndStr = salonEndStr;
        }

        professionalStartMinutes = timeToMinutes(profStartStr);
        professionalEndMinutes = timeToMinutes(profEndStr);

        // REGRA 4: Garantir que o profissional não trabalhe fora do horário do salão
        if (professionalStartMinutes < salonStartMinutes) {
          professionalStartMinutes = salonStartMinutes;
        }
        if (professionalEndMinutes > salonEndMinutes) {
          professionalEndMinutes = salonEndMinutes;
        }

        professionalBreaks = professionalDaySchedule.breaks || [];
      } else if (
        professionalDaySchedule &&
        professionalDaySchedule.isWorking === false
      ) {
        // Profissional explicitamente marcado como não trabalhando

        professionalStartMinutes = null;
        professionalEndMinutes = null;
        professionalBreaks = [];
      } else {
        // Profissional sem schedule definido - herda do salão

        professionalStartMinutes = salonStartMinutes;
        professionalEndMinutes = salonEndMinutes;
        professionalBreaks = [];
      }

      // Obter duração do serviço
      const service = services.find((s) => s.id === selectedService);
      const serviceDuration = service?.duration || 30;

      // REGRA 5: Sempre gerar TODOS os slots baseados nos horários do SALÃO
      const slots: TimeSlot[] = [];
      const slotDuration = 15; // Intervalos de 15 minutos

      // REGRA 3: Verificar se a data selecionada é hoje e obter hora atual em minutos locais
      const isSelectedDateToday = isToday(selectedDate);
      const now = new Date();
      const currentTimeInMinutes = now.getHours() * 60 + now.getMinutes();

      // Começar do horário de abertura do SALÃO
      let currentMinutes = salonStartMinutes;
      let debugFirstSlot = true;
      let availableCount = 0;
      let blockedCount = 0;

      while (currentMinutes < salonEndMinutes) {
        const time = minutesToTime(currentMinutes);
        const slotStartMinutes = currentMinutes;
        const serviceEndMinutes = slotStartMinutes + serviceDuration;

        // Inicializar como disponível
        let available = true;
        let reason = "";

        // Debug do primeiro slot
        if (debugFirstSlot) {
          debugFirstSlot = false;
        }

        // REGRA 4: Verificar se é data/hora passada
        if (isSelectedDateToday && slotStartMinutes <= currentTimeInMinutes) {
          available = false;
          reason = "Horário já passou";
        }
        // Verificar se há tempo suficiente no salão
        else if (serviceEndMinutes > salonEndMinutes) {
          available = false;
          reason = "Sem tempo suficiente antes do fechamento";
        }
        // Verificar se está dentro do horário do profissional
        else if (
          professionalStartMinutes !== null &&
          professionalEndMinutes !== null
        ) {
          if (
            slotStartMinutes < professionalStartMinutes ||
            serviceEndMinutes > professionalEndMinutes
          ) {
            available = false;
            reason = `Fora do horário do profissional (${minutesToTime(
              professionalStartMinutes
            )}-${minutesToTime(professionalEndMinutes)})`;
          }
        }
        // Se profissional não trabalha neste dia
        else if (professionalStartMinutes === null) {
          available = false;
          reason = "Profissional não trabalha neste dia";
        }

        // Verificar se está no intervalo do profissional
        if (
          available &&
          professionalBreaks &&
          Array.isArray(professionalBreaks)
        ) {
          for (const breakPeriod of professionalBreaks) {
            const breakStartMinutes = timeToMinutes(breakPeriod.start);
            const breakEndMinutes = timeToMinutes(breakPeriod.end);

            // Verifica sobreposição com intervalo
            if (
              slotStartMinutes < breakEndMinutes &&
              serviceEndMinutes > breakStartMinutes
            ) {
              available = false;
              reason = "Durante intervalo do profissional";
              break;
            }
          }
        }

        slots.push({
          time,
          available,
        });

        if (available) {
          availableCount++;
        } else {
          blockedCount++;
        }

        // Incrementar por duração do slot
        currentMinutes += slotDuration;
      }

      const availableSlotsBeforeConflicts = slots.filter((s) => s.available);

      // REGRA 3: Buscar os agendamentos existentes do profissional nesta data
      try {
        const dateStr = format(selectedDate, "yyyy-MM-dd");

        const queryParams = {
          professionalId: selectedProfessional,
          startDate: dateStr,
          endDate: dateStr,
        };

        const appointments = await appointmentService.list(queryParams);

        // Logar detalhes de cada agendamento
        if (appointments.data.length > 0) {
          let blockingCount = 0;
          let nonBlockingCount = 0;

          appointments.data.forEach((apt, index) => {
            const aptStart = new Date(apt.startTime);
            const aptStartMinutes = utcDateToLocalMinutes(aptStart);

            let aptEndMinutes;
            if (apt.endTime) {
              const aptEnd = new Date(apt.endTime);
              aptEndMinutes = utcDateToLocalMinutes(aptEnd);
            } else {
              const duration = apt.service?.duration || apt.duration || 30;
              aptEndMinutes = aptStartMinutes + duration;
            }

            const isNonBlocking = NON_BLOCKING_STATUSES.includes(
              apt.status as AppointmentStatus
            );

            if (isNonBlocking) {
              nonBlockingCount++;
            } else {
              blockingCount++;
            }
          });
        }

        // REGRA 2: Marcar slots como indisponíveis se conflitam com agendamentos existentes
        const updatedSlots = slots.map((slot) => {
          // Se já está indisponível, manter assim
          if (!slot.available) {
            return slot;
          }

          const slotStartMinutes = timeToMinutes(slot.time);
          const slotEndMinutes = slotStartMinutes + serviceDuration;

          // Verificar conflito com cada agendamento
          const hasConflict = appointments.data.some((appointment) => {
            // Ignorar agendamentos que NÃO bloqueiam (cancelados, concluídos, no-show)
            if (
              NON_BLOCKING_STATUSES.includes(
                appointment.status as AppointmentStatus
              )
            ) {
              return false;
            }

            // Calcular início e fim do agendamento existente (converter UTC para local)
            const aptStart = new Date(appointment.startTime);
            const aptStartMinutes = utcDateToLocalMinutes(aptStart);

            let aptEndMinutes;
            if (appointment.endTime) {
              const aptEnd = new Date(appointment.endTime);
              aptEndMinutes = utcDateToLocalMinutes(aptEnd);
            } else {
              const duration =
                appointment.service?.duration || appointment.duration || 30;
              aptEndMinutes = aptStartMinutes + duration;
            }

            // Verificar sobreposição
            const overlaps =
              (slotStartMinutes >= aptStartMinutes &&
                slotStartMinutes < aptEndMinutes) ||
              (slotEndMinutes > aptStartMinutes &&
                slotEndMinutes <= aptEndMinutes) ||
              (slotStartMinutes <= aptStartMinutes &&
                slotEndMinutes >= aptEndMinutes) ||
              (aptStartMinutes <= slotStartMinutes &&
                aptEndMinutes >= slotEndMinutes);

            return overlaps;
          });

          return {
            ...slot,
            available: slot.available && !hasConflict,
          };
        });

