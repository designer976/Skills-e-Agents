                                : slot.available
                                  ? "bg-background border border-input hover:bg-accent hover:text-accent-foreground"
                                  : "bg-muted text-muted-foreground border border-muted-foreground/20 cursor-not-allowed opacity-60"
                            )}
                          >
                            {slot.time}
                          </button>
                        ))}
                      </div>
                      {timeSlots.every((slot) => !slot.available) && (
                        <p className="text-center text-sm text-muted-foreground mt-4">
                          Todos os horários estão indisponíveis neste dia
                        </p>
                      )}
                    </div>
                  )}
                </div>
              </div>

              {/* Notes */}
              <div className="space-y-2">
                <Label htmlFor="notes">Observações (opcional)</Label>
                <Textarea
                  id="notes"
                  value={notes}
                  onChange={(e) => setNotes(e.target.value.slice(0, 200))}
                  placeholder="Adicione observações sobre o agendamento..."
                  maxLength={200}
                  rows={3}
                />
              </div>
            </>
          )}
        </div>

        {/* Summary Card - Shows when all selections are made in Step 1 */}
        {currentStep === 1 &&
          selectedClient &&
          selectedService &&
          selectedProfessional && (
            <div className="mt-6 p-4 bg-muted/50 rounded-lg space-y-3">
              <h3 className="font-semibold text-base">Resumo do Agendamento</h3>
              <div className="space-y-2 text-sm">
                <div className="flex justify-between">
                  <span className="text-muted-foreground">Cliente:</span>
                  <span className="font-medium">
                    {clients.find((c) => c.id === selectedClient)?.name}
                  </span>
                </div>
                <div className="flex justify-between">
                  <span className="text-muted-foreground">Serviço:</span>
                  <span className="font-medium">
                    {services.find((s) => s.id === selectedService)?.name}
                  </span>
                </div>
                <div className="flex justify-between">
                  <span className="text-muted-foreground">Profissional:</span>
                  <span className="font-medium">
                    {
                      professionals.find((p) => p.id === selectedProfessional)
                        ?.name
                    }
                  </span>
                </div>
                <div className="border-t pt-2 mt-2">
                  <div className="flex justify-between">
                    <span className="text-muted-foreground">Duração:</span>
                    <span className="font-medium">
                      {serviceDetails?.duration}
                    </span>
                  </div>
                  {serviceDetails?.price !== "Consultar valor" && (
                    <div className="flex justify-between">
                      <span className="text-muted-foreground">Valor:</span>
                      <span className="font-medium text-base">
                        {serviceDetails?.price}
                      </span>
                    </div>
                  )}
                </div>
              </div>
            </div>
          )}
        </div>

        <div className="sticky bottom-0 z-10 bg-background px-4 pt-3 pb-4 border-t shrink-0 flex flex-col-reverse sm:flex-row sm:justify-end gap-2 sm:gap-3">
          {currentStep === 1 ? (
            <>
              <Button variant="outline" onClick={handleClose} className="w-full sm:w-auto min-h-[44px]">
                Cancelar
              </Button>
              <Button onClick={handleNextStep} disabled={!canProceedToStep2} className="w-full sm:w-auto min-h-[44px] salon-button-primary">
                Continuar
              </Button>
            </>
          ) : (
            <>
              <Button variant="outline" onClick={handleBackStep} className="w-full sm:w-auto min-h-[44px]">
                Voltar
              </Button>
              <Button onClick={handleSubmit} disabled={saving || !selectedTime} className="w-full sm:w-auto min-h-[44px] salon-button-primary">
                {saving ? (
                  <>
                    <Loader2 className="mr-2 h-4 w-4 animate-spin" />
                    Salvando...
                  </>
                ) : (
                  "Confirmar Agendamento"
                )}
              </Button>
            </>
          )}
        </div>
      </DialogContent>
    </Dialog>
  );
}
