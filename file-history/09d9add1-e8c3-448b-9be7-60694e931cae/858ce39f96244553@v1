import { UseFormReturn, useController } from "react-hook-form";
import { StepScheduleData } from "./schemas";
import { IconCheck as Check } from "@tabler/icons-react";

interface StepScheduleProps {
    form: UseFormReturn<StepScheduleData>;
}

const DAYS_OF_WEEK = [
    { value: 1, label: "Segunda-Feira" },
    { value: 2, label: "Terça-Feira" },
    { value: 3, label: "Quarta-Feira" },
    { value: 4, label: "Quinta-Feira" },
    { value: 5, label: "Sexta-Feira" },
    { value: 6, label: "Sábado" },
    { value: 0, label: "Domingo" },
];

export function StepSchedule({ form }: StepScheduleProps) {
    const { register, control, formState: { errors } } = form;

    return (
        <div className="space-y-6 animate-fade-in">
            <div className="text-center mb-8">
                <h1 className="font-semibold text-foreground mb-2 text-lg">
                    Quais os horários de funcionamento do salão?
                </h1>
                <p className="text-sm text-muted-foreground">
                    Defina o horário padrão do seu salão.
                </p>
            </div>

            <div className="space-y-6 max-w-lg mx-auto">
                {/* grid-cols-1 em telas pequenas (iPhone 13 = 390px) → sem colisão de inputs de hora;
                    grid-cols-2 a partir de sm (≥640px) para layout lado-a-lado em tablets/desktop */}
                <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div className="min-w-0">
                        <label className="block text-sm font-medium text-foreground mb-2">
                            Hora inicial
                        </label>
                        <input
                            className="w-full h-11 px-3 text-sm border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#dd4227]/20 focus:border-[#dd4227] appearance-none"
                            type="time"
                            {...register("startTime")}
                        />
                        {errors.startTime && (
                            <p className="text-red-500 text-xs mt-1">{errors.startTime.message}</p>
                        )}
                    </div>
                    <div className="min-w-0">
                        <label className="block text-sm font-medium text-foreground mb-2">
                            Hora final
                        </label>
                        <input
                            className="w-full h-11 px-3 text-sm border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#dd4227]/20 focus:border-[#dd4227] appearance-none"
                            type="time"
                            {...register("endTime")}
                        />
                        {errors.endTime && (
                            <p className="text-red-500 text-xs mt-1">{errors.endTime.message}</p>
                        )}
                    </div>
                </div>

                <div>
                    <label className="block text-sm font-medium text-foreground mb-3">
                        Dias de funcionamento
                    </label>
                    <div className="flex flex-wrap gap-2 justify-center">
                        <DaysSelector control={control} />
                    </div>
                    {errors.daysOpen && (
                        <p className="text-red-500 text-xs mt-1 text-center">{errors.daysOpen.message}</p>
                    )}
                </div>
            </div>

            <p className="text-xs text-muted-foreground text-center bg-muted/50 p-3 rounded-lg mt-6">
                Você pode configurar horários diferentes para cada dia posteriormente nas configurações do salão.
            </p>
        </div>
    );
}

function DaysSelector({ control }: { control: any }) {
    const { field } = useController({
        control,
        name: "daysOpen",
    });

    const selectedDays = field.value || [];

    const handleToggle = (dayValue: number) => {
        if (selectedDays.includes(dayValue)) {
            field.onChange(selectedDays.filter((d: number) => d !== dayValue));
        } else {
            field.onChange([...selectedDays, dayValue]);
        }
    };

    return (
        <>
            {DAYS_OF_WEEK.map((day) => {
                const isSelected = selectedDays.includes(day.value);
                return (
                    <button
                        key={day.value}
                        type="button"
                        onClick={() => handleToggle(day.value)}
                        className={`
                            px-4 py-2 rounded-lg text-sm font-medium transition-colors
                            ${isSelected
                                ? "bg-[#dd4227] text-white shadow-md"
                                : "bg-muted text-muted-foreground hover:bg-muted/80"
                            }
                        `}
                    >
                        {day.label}
                    </button>
                )
            })}
        </>
    )
}
