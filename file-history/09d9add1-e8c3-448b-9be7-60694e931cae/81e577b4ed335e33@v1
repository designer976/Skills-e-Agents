import { cn } from "@/lib/utils";
import { Button } from "@/components/ui/button";
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from "@/components/ui/select";
import { IconChevronLeft as ChevronLeft, IconChevronRight as ChevronRight } from "@tabler/icons-react";

interface ResponsivePaginationProps {
  currentPage: number;
  totalPages: number;
  totalItems: number;
  pageSize: number;
  onPageChange: (page: number) => void;
  onPageSizeChange: (size: number | string) => void;
  itemLabel?: string;
  pageSizeOptions?: number[];
  className?: string;
}

export function ResponsivePagination({
  currentPage,
  totalPages,
  totalItems,
  pageSize,
  onPageChange,
  onPageSizeChange,
  itemLabel = "registros",
  pageSizeOptions = [5, 10, 20, 50],
  className,
}: ResponsivePaginationProps) {
  const from = totalItems === 0 ? 0 : Math.min((currentPage - 1) * pageSize + 1, totalItems);
  const to = Math.min(currentPage * pageSize, totalItems);

  const pageNumbers = Array.from({ length: Math.min(5, totalPages) }, (_, i) => {
    if (totalPages <= 5) return i + 1;
    if (currentPage <= 3) return i + 1;
    if (currentPage >= totalPages - 2) return totalPages - 4 + i;
    return currentPage - 2 + i;
  });

  return (
    <div className={cn(
      "mt-8 flex flex-col items-center gap-4 md:flex-row md:justify-between pb-8 w-full",
      className
    )}>

      {/* Controle de Itens e Resumo */}
      <div className="flex flex-col items-center sm:flex-row gap-3 md:items-center">
        <div className="flex items-center gap-2">
          <span className="text-xs font-medium text-muted-foreground whitespace-nowrap">
            Itens por página:
          </span>
          <Select
            value={pageSize.toString()}
            onValueChange={(v) => onPageSizeChange(Number(v))}
          >
            <SelectTrigger className="w-[70px] h-8 text-xs bg-background">
              <SelectValue />
            </SelectTrigger>
            <SelectContent>
              {pageSizeOptions.map((size) => (
                <SelectItem key={size} value={size.toString()}>
                  {size}
                </SelectItem>
              ))}
            </SelectContent>
          </Select>
        </div>

        <span className="text-xs font-medium text-muted-foreground bg-muted/30 px-3 py-1 rounded-full border whitespace-nowrap">
          Mostrando {from}–{to} de {totalItems} {itemLabel}
        </span>
      </div>

      {/* Controles de Navegação */}
      <div className="flex items-center justify-center gap-2">

        {/* Botão Anterior Corrigido */}
        <Button
          variant="outline"
          onClick={() => onPageChange(currentPage - 1)}
          disabled={currentPage === 1}
          // w-8 h-8 p-0 força o botão a ser quadrado no mobile. 
          // md:w-auto md:px-3 devolve o formato retangular no desktop.
          className="flex items-center justify-center h-8 w-8 p-0 md:w-auto md:px-3 shrink-0 bg-background"
        >
          <ChevronLeft className="h-4 w-4 md:mr-1 shrink-0" />
          <span className="hidden md:inline">Anterior</span>
        </Button>

        {/* Números das Páginas — visíveis a partir de sm (tablets+) */}
        <div className="hidden sm:flex items-center gap-1">
          {pageNumbers.map((pageNum, i) => (
            <Button
              key={i}
              variant={pageNum === currentPage ? "default" : "outline"}
              onClick={() => onPageChange(pageNum)}
              className={cn(
                "w-8 h-8 p-0 text-xs",
                pageNum === currentPage ? "salon-button-primary" : "bg-background"
              )}
            >
              {pageNum}
            </Button>
          ))}
        </div>

        {/* Indicador de Página Compacto — visível SÓ no mobile */}
        <span className="sm:hidden text-sm font-medium text-muted-foreground px-2 shrink-0">
          Pág {currentPage} / {totalPages}
        </span>

        {/* Botão Próxima Corrigido */}
        <Button
          variant="outline"
          onClick={() => onPageChange(currentPage + 1)}
          disabled={currentPage === totalPages}
          className="flex items-center justify-center h-8 w-8 p-0 md:w-auto md:px-3 shrink-0 bg-background"
        >
          <span className="hidden md:inline">Próxima</span>
          <ChevronRight className="h-4 w-4 md:ml-1 shrink-0" />
        </Button>
      </div>
    </div>
  );
}