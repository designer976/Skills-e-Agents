import React from "react";
import {
  ColumnDef,
  Table as TanstackTable,
  flexRender,
  getCoreRowModel,
  getPaginationRowModel,
  useReactTable,
} from "@tanstack/react-table";
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/ui/table";
import {
  Pagination,
  PaginationContent,
  PaginationEllipsis,
  PaginationItem,
  PaginationLink,
  PaginationNext,
  PaginationPrevious,
} from "@/components/ui/pagination";
import { cn } from "@/lib/utils";

interface Column<T> {
  key: keyof T;
  header: React.ReactNode | string;
  render?: (value: any, row: T) => React.ReactNode;
  className?: string;
  width?: string;
}

interface MobileCardConfig<T> {
  title: keyof T | ((row: T) => React.ReactNode);
  subtitle?: keyof T | ((row: T) => React.ReactNode);
  badge?: keyof T | ((row: T) => React.ReactNode);
  excludeFromGrid?: (keyof T)[];
}

interface DataTableProps<T> {
  data: T[];
  columns: Column<T>[];
  onRowClick?: (row: T) => void;
  className?: string;
  mobileView?: "cards";
  mobileCardConfig?: MobileCardConfig<T>;
  pageSize?: number;
}

export function DataTable<T extends object>({
  data,
  columns,
  onRowClick,
  className,
  mobileView,
  mobileCardConfig,
  pageSize,
}: DataTableProps<T>) {
  const safeData = data || [];

  const tanstackColumns: ColumnDef<T>[] = columns.map((col) => ({
    id: String(col.key),
    accessorKey: col.key as string,
    header: () => col.header,
    cell: ({ getValue, row }) =>
      col.render
        ? col.render(getValue(), row.original)
        : String(getValue() ?? "-"),
  }));

  const table = useReactTable({
    data: safeData,
    columns: tanstackColumns,
    getCoreRowModel: getCoreRowModel(),
    ...(pageSize && {
      getPaginationRowModel: getPaginationRowModel(),
      initialState: { pagination: { pageSize } },
    }),
  });

  const getMobileValue = (
    row: T,
    field: keyof T | ((row: T) => React.ReactNode) | undefined
  ) => {
    if (!field) return null;
    if (typeof field === "function") return field(row);
    return String(row[field] || "-");
  };

  return (
    <div className={cn("w-full", className)}>
      {/* Card View para Mobile */}
      {mobileView === "cards" && (
        <div className="grid grid-cols-1 gap-4 md:hidden mb-6">
          {safeData.map((row, index) => (
            <div
              key={index}
              onClick={() => onRowClick?.(row)}
              className={cn(
                "salon-card p-4 space-y-3",
                onRowClick && "cursor-pointer active:bg-muted/50"
              )}
            >
              <div className="flex justify-between items-start">
                <div>
                  <h4 className="font-medium text-primary text-[15px] leading-tight">
                    {mobileCardConfig?.title
                      ? getMobileValue(row, mobileCardConfig.title)
                      : "Registro"}
                  </h4>
                  {mobileCardConfig?.subtitle && (
                    <p className="text-[13px] text-muted-foreground mt-0.5">
                      {getMobileValue(row, mobileCardConfig.subtitle)}
                    </p>
                  )}
                </div>
                {mobileCardConfig?.badge && (
                  <span className="bg-secondary text-primary text-[10px] font-bold uppercase px-2 py-0.5 rounded-full">
                    {getMobileValue(row, mobileCardConfig.badge)}
                  </span>
                )}
              </div>

              <div className="grid grid-cols-2 gap-3 pt-3 border-t-[0.5px] border-border/50">
                {columns
                  .filter(
                    (col) =>
                      typeof col.header === "string" &&
                      col.header !== "Ações" &&
                      col.header !== "Status" &&
                      col.key !== mobileCardConfig?.title &&
                      col.key !== mobileCardConfig?.subtitle &&
                      col.key !== mobileCardConfig?.badge &&
                      !mobileCardConfig?.excludeFromGrid?.includes(col.key)
                  )
                  .slice(0, 6)
                  .map((col) => (
                    <div key={String(col.key)}>
                      <p className="text-[10px] text-muted-foreground uppercase font-medium tracking-[0.06em]">
                        {typeof col.header === "string" ? col.header : ""}
                      </p>
                      <p className="text-[13px] text-foreground font-normal truncate mt-0.5">
                        {col.render
                          ? col.render(row[col.key], row)
                          : String(row[col.key] || "-")}
                      </p>
                    </div>
                  ))}
              </div>

              {columns.some(
                (col) =>
                  typeof col.header === "string" && col.header === "Ações"
              ) && (
                <div className="pt-2 flex justify-end">
                  {columns
                    .find(
                      (col) =>
                        typeof col.header === "string" &&
                        col.header === "Ações"
                    )
                    ?.render?.(null, row)}
                </div>
              )}
            </div>
          ))}
          {safeData.length === 0 && (
            <div className="salon-card p-8 text-center text-muted-foreground">
              Nenhum registro encontrado
            </div>
          )}
        </div>
      )}

      {/* Tabela Desktop */}
      <div
        className={cn(
          "salon-card overflow-x-auto w-full rounded-2xl",
          mobileView === "cards" && "hidden md:block"
        )}
      >
        <Table className="min-w-[600px]">
          <TableHeader>
            <TableRow className="salon-table-header hover:bg-tertiary">
              {table.getFlatHeaders().map((header) => {
                const col = columns.find((c) => String(c.key) === header.id);
                return (
                  <TableHead
                    key={header.id}
                    className={cn(
                      "button-text text-foreground whitespace-nowrap",
                      col?.className
                    )}
                    style={{ width: col?.width }}
                  >
                    {flexRender(
                      header.column.columnDef.header,
                      header.getContext()
                    )}
                  </TableHead>
                );
              })}
            </TableRow>
          </TableHeader>
          <TableBody>
            {table.getRowModel().rows.length === 0 ? (
              <TableRow>
                <TableCell
                  colSpan={columns.length}
                  className="text-center text-muted-foreground py-8"
                >
                  Nenhum registro encontrado
                </TableCell>
              </TableRow>
            ) : (
              table.getRowModel().rows.map((row) => (
                <TableRow
                  key={row.id}
                  onClick={() => onRowClick?.(row.original)}
                  className={cn(
                    "border-border h-16 transition-colors",
                    onRowClick && "cursor-pointer hover:bg-muted/30"
                  )}
                >
                  {row.getVisibleCells().map((cell) => {
                    const col = columns.find(
                      (c) => String(c.key) === cell.column.id
                    );
                    return (
                      <TableCell
                        key={cell.id}
                        className={cn(
                          "body-text align-middle py-4 px-4 whitespace-nowrap",
                          col?.header === "Ações" && "min-w-[120px]",
                          col?.className
                        )}
                        style={{ width: col?.width }}
                      >
                        {flexRender(
                          cell.column.columnDef.cell,
                          cell.getContext()
                        )}
                      </TableCell>
                    );
                  })}
                </TableRow>
              ))
            )}
          </TableBody>
        </Table>
      </div>

      {/* Paginação */}
      {pageSize && table.getPageCount() > 1 && (
        <DataTablePagination table={table} />
      )}
    </div>
  );
}

interface DataTablePaginationProps<T> {
  table: TanstackTable<T>;
}

function DataTablePagination<T>({ table }: DataTablePaginationProps<T>) {
  const pageIndex = table.getState().pagination.pageIndex;
  const pageCount = table.getPageCount();

  const pages = buildPageRange(pageIndex, pageCount);

  return (
    <Pagination className="mt-4">
      <PaginationContent>
        <PaginationItem>
          <PaginationPrevious
            onClick={() => table.previousPage()}
            aria-disabled={!table.getCanPreviousPage()}
            className={cn(!table.getCanPreviousPage() && "pointer-events-none opacity-50")}
          />
        </PaginationItem>

        {pages.map((page, i) =>
          page === "ellipsis" ? (
            <PaginationItem key={`ellipsis-${i}`}>
              <PaginationEllipsis />
            </PaginationItem>
          ) : (
            <PaginationItem key={page}>
              <PaginationLink
                isActive={page === pageIndex}
                onClick={() => table.setPageIndex(page)}
              >
                {page + 1}
              </PaginationLink>
            </PaginationItem>
          )
        )}

        <PaginationItem>
          <PaginationNext
            onClick={() => table.nextPage()}
            aria-disabled={!table.getCanNextPage()}
            className={cn(!table.getCanNextPage() && "pointer-events-none opacity-50")}
          />
        </PaginationItem>
      </PaginationContent>
    </Pagination>
  );
}

type PageItem = number | "ellipsis";

function buildPageRange(current: number, total: number): PageItem[] {
  if (total <= 7) return Array.from({ length: total }, (_, i) => i);

  if (current < 4) {
    return [0, 1, 2, 3, 4, "ellipsis", total - 1];
  }

  if (current > total - 5) {
    return [0, "ellipsis", total - 5, total - 4, total - 3, total - 2, total - 1];
  }

  return [0, "ellipsis", current - 1, current, current + 1, "ellipsis", total - 1];
}
