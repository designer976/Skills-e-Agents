import { IconLoader2 as Loader2 } from "@tabler/icons-react";
import { cn } from "@/lib/utils";

interface LoadingSpinnerProps extends React.ComponentProps<'div'> {
  size?: "sm" | "md" | "lg";
  text?: string;
}

const SIZE_CLASSES: Record<NonNullable<LoadingSpinnerProps["size"]>, string> = {
  sm: "size-4",
  md: "size-8",
  lg: "size-12",
};

function LoadingSpinner({
  size = "md",
  text,
  className,
  ...props
}: LoadingSpinnerProps) {
  return (
    <div
      data-slot="loading-spinner"
      className={cn("flex flex-col items-center justify-center gap-3", className)}
      {...props}
    >
      <Loader2
        role="status"
        aria-label={text ? `Loading: ${text}` : "Loading"}
        className={cn(SIZE_CLASSES[size], "animate-spin text-primary")}
      />
      {text && <p className="text-sm text-muted-foreground">{text}</p>}
    </div>
  );
}

// Simpler spinner for inline use (like the prototype)
function Spinner({ className, ...props }: React.ComponentProps<'svg'>) {
  return (
    <Loader2
      role="status"
      aria-label="Loading"
      data-slot="spinner"
      className={cn('size-4 animate-spin', className)}
      {...props}
    />
  )
}

export { LoadingSpinner, Spinner }
