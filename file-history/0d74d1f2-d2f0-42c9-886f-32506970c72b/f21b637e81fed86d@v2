// ─── Tipos ────────────────────────────────────────────────────────────────────

export type FaseVistoria =
  | "Agendada"
  | "Vistoriador atribuído"
  | "A caminho"
  | "Chegou no local"
  | "Em execução"
  | "Finalizada"
  | "Enviada para Qualidade"

export const FASES_ORDERED: FaseVistoria[] = [
  "Agendada",
  "Vistoriador atribuído",
  "A caminho",
  "Chegou no local",
  "Em execução",
  "Finalizada",
  "Enviada para Qualidade",
]

export interface EventoTimeline {
  id: number
  dataHora: string
  fase: FaseVistoria
  descricao: string
  origem: "Sistema" | "App" | "Backoffice"
}

export interface Anotacao {
  id: number
  autor: string
  dataHora: string
  texto: string
  tag: "Ocorrência" | "Cliente" | "Acesso" | "Financeiro" | "Geral"
}

export interface VistoriaAndamento {
  id: string
  // Agendamento
  dataAgendada: string
  horaAgendada: string
  // Cliente
  clienteNome: string
  clienteTipo: "PF" | "PJ"
  // Imóvel
  endereco: string
  cidade: string
  uf: string
  complemento?: string
  bairro: string
  cep: string
  tipoImovel: string
  areaUtil: number
  mobilia: string
  statusImovel: string
  referenciaAcesso?: string
  // Vistoria
  tipo: string
  valor: string
  // Vistoriador
  vistoriadorNome: string
  vistoriadorNivel: "Júnior" | "Pleno" | "Sênior"
  // Fase
  faseAtual: FaseVistoria
  ultimaAtualizacaoDataHora: string
  semUpdateHaMins: number
  temAlerta: boolean
  // Timeline
  eventos: EventoTimeline[]
  // Anotações internas (só backoffice)
  anotacoes: Anotacao[]
}

