"use client"

import { use } from "react"
import { useRouter } from "next/navigation"
import { AdminDashboardLayout } from "@/components/admin/admin-dashboard-layout"
import { AdminButton } from "@/components/admin/admin-button"
import { getVistoriaById, ETAPAS } from "@/lib/mock-vistorias"
import {
  MapPin, Tag, CalendarClock, User,
  MessageSquare, Download, Check,
} from "lucide-react"

export default function VistoriaDetalhePage({ params }: { params: Promise<{ id: string }> }) {
  const { id } = use(params)
  const router = useRouter()
  const vistoria = getVistoriaById(id)

  if (!vistoria) {
    return (
      <AdminDashboardLayout profile="cliente" title="Vistoria não encontrada">
        <div className="flex flex-col items-center justify-center py-20">
          <p className="text-gray-500 mb-4">Vistoria não encontrada.</p>
          <AdminButton variant="outline" onClick={() => router.back()}>Voltar</AdminButton>
        </div>
      </AdminDashboardLayout>
    )
  }

  return (
    <AdminDashboardLayout
      profile="cliente"
      title={vistoria.id}
      breadcrumbs={[
        { label: "Vistorias", href: "/admin/cliente/vistorias/andamento" },
        {
          label: vistoria.status === "Pedido"
            ? "Vistorias Solicitadas"
            : vistoria.status === "Em andamento"
              ? "Vistorias em Andamento"
              : "Vistorias Concluídas",
          href:
            vistoria.status === "Pedido"
              ? "/admin/cliente/vistorias/pedidos"
              : vistoria.status === "Em andamento"
                ? "/admin/cliente/vistorias/andamento"
                : "/admin/cliente/vistorias/concluidas",
        },
      ]}
    >

      <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {/* Coluna principal */}
        <div className="lg:col-span-2 space-y-6">
          {/* Dados principais */}
          <div className="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <div className="flex items-center gap-3 mb-5">
              <h2 className="text-base font-bold text-gray-900">Informações da Vistoria</h2>
              <span className={`px-2 py-0.5 rounded-full text-xs font-semibold ${vistoria.statusColor}`}>
                {vistoria.status}
              </span>
            </div>
            <div className="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <InfoRow icon={<MapPin size={16} className="text-[#0B7A8F]" />} label="Endereço" value={vistoria.endereco} />
              <InfoRow icon={<Tag size={16} className="text-[#0B7A8F]" />} label="Tipo de vistoria" value={vistoria.tipo} />
              <InfoRow icon={<CalendarClock size={16} className="text-[#0B7A8F]" />} label="Data / hora agendada" value={vistoria.dataHora} />
              <InfoRow icon={<User size={16} className="text-[#0B7A8F]" />} label="Responsável" value={vistoria.responsavel} />
            </div>
          </div>

          {/* Linha do tempo horizontal */}
          <div className="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <h2 className="text-base font-bold text-gray-900 mb-5">Etapas da Vistoria</h2>
            <div className="flex items-start gap-0">
              {ETAPAS.map((etapa, idx) => {
                const concluida = idx < vistoria.etapa
                const atual = idx === vistoria.etapa
                return (
                  <div key={idx} className="flex-1 flex flex-col items-center gap-1 min-w-0">
                    <div className="flex items-center w-full">
                      <div className={`h-0.5 flex-1 ${idx === 0 ? "invisible" : concluida || atual ? "bg-[#0B7A8F]" : "bg-gray-200"}`} />
                      <div className={`flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center border-2 transition-all ${
                        concluida ? "bg-[#0B7A8F] border-[#0B7A8F]" : atual ? "bg-white border-[#0B7A8F]" : "bg-white border-gray-300"
                      }`}>
                        {concluida ? <Check size={14} className="text-white" /> : atual ? <div className="w-2.5 h-2.5 rounded-full bg-[#0B7A8F]" /> : null}
                      </div>
                      <div className={`h-0.5 flex-1 ${idx === ETAPAS.length - 1 ? "invisible" : concluida ? "bg-[#0B7A8F]" : "bg-gray-200"}`} />
                    </div>
                    <p className={`text-center text-xs leading-tight px-1 mt-2 ${
                      concluida ? "text-[#0B7A8F] font-medium" : atual ? "text-[#002533] font-bold" : "text-gray-400"
                    }`}>{etapa}</p>
                  </div>
                )
              })}
            </div>
          </div>

          {/* Histórico */}
          <div className="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <h2 className="text-base font-bold text-gray-900 mb-5 flex items-center gap-2">
              <MessageSquare size={16} className="text-[#0B7A8F]" /> Histórico
            </h2>
            <div className="space-y-4">
              {vistoria.historico.map((item, idx) => (
                <div key={idx} className="flex gap-4">
                  <div className="w-1 rounded-full bg-[#0B7A8F]/20 flex-shrink-0" />
                  <div>
                    <p className="text-xs text-gray-400 font-mono mb-1">{item.data}</p>
                    <p className="text-sm text-gray-700 leading-relaxed">{item.texto}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        {/* Coluna lateral */}
        <div className="space-y-6">
          <div className="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <h2 className="text-base font-bold text-gray-900 mb-4">Ações</h2>
            <div className="space-y-3">
              {vistoria.temRelatorio && (
                <AdminButton variant="primary" size="md" icon={<Download size={16} />} onClick={() => {}} className="w-full justify-center">
                  Baixar Relatório
                </AdminButton>
              )}
              <AdminButton variant="outline" size="md" onClick={() => {}} className="w-full justify-center">
                Solicitar Alteração
              </AdminButton>
            </div>
          </div>

          <div className="bg-gray-50 rounded-2xl border border-gray-100 p-6">
            <h2 className="text-sm font-bold text-gray-700 mb-4">Resumo</h2>
            <div className="space-y-3 text-sm">
              <div className="flex justify-between">
                <span className="text-gray-500">Código</span>
                <span className="font-mono text-gray-900">{vistoria.id}</span>
              </div>
              <div className="flex justify-between">
                <span className="text-gray-500">Tipo</span>
                <span className="text-gray-900">{vistoria.tipo}</span>
              </div>
              <div className="flex justify-between">
                <span className="text-gray-500">Data</span>
                <span className="text-gray-900">{vistoria.data}</span>
              </div>
              <div className="flex justify-between">
                <span className="text-gray-500">Relatório</span>
                <span className={vistoria.temRelatorio ? "text-green-600 font-medium" : "text-gray-400"}>
                  {vistoria.temRelatorio ? "Disponível" : "Pendente"}
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </AdminDashboardLayout>
  )
}

function InfoRow({ icon, label, value }: { icon: React.ReactNode; label: string; value: string }) {
  return (
    <div className="flex items-start gap-3">
      <div className="mt-0.5 flex-shrink-0">{icon}</div>
      <div>
        <p className="text-xs text-gray-400 font-medium uppercase tracking-wide">{label}</p>
        <p className="text-sm text-gray-800 font-medium mt-0.5">{value}</p>
      </div>
    </div>
  )
}
