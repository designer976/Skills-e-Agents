"use client"

import { use } from "react"
import { useRouter } from "next/navigation"
import { AdminDashboardLayout } from "@/components/admin/admin-dashboard-layout"
import { AdminButton } from "@/components/admin/admin-button"
import { getVistoriaById, ETAPAS, type Vistoria } from "@/lib/mock-vistorias"
import {
  MapPin,
  Tag,
  CalendarClock,
  User,
  Check,
  MessageSquare,
  Download,
  FileText,
  DollarSign,
  Zap,
  Clock,
} from "lucide-react"
import { cn } from "@/lib/utils"

// ─── Helpers ─────────────────────────────────────────────────────────────────

function InfoRow({ icon, label, value }: { icon: React.ReactNode; label: string; value: string }) {
  return (
    <div className="flex items-start gap-3">
      <div className="mt-0.5 shrink-0">{icon}</div>
      <div>
        <p className="text-xs text-gray-400 font-medium uppercase tracking-wide">{label}</p>
        <p className="text-sm text-gray-800 font-medium mt-0.5">{value}</p>
      </div>
    </div>
  )
}

// ─── Stepper de etapas ────────────────────────────────────────────────────────

function StepperEtapas({ etapaAtual }: { etapaAtual: number }) {
  return (
    <div className="flex items-start gap-0">
      {ETAPAS.map((etapa, idx) => {
        const concluida = idx < etapaAtual
        const atual = idx === etapaAtual
        return (
          <div key={idx} className="flex-1 flex flex-col items-center gap-1 min-w-0">
            <div className="flex items-center w-full">
              <div className={cn(
                "h-0.5 flex-1",
                idx === 0 ? "invisible" : concluida || atual ? "bg-[#0B7A8F]" : "bg-gray-200"
              )} />
              <div className={cn(
                "shrink-0 w-7 h-7 rounded-full flex items-center justify-center border-2 transition-colors",
                concluida ? "bg-[#0B7A8F] border-[#0B7A8F]"
                  : atual ? "bg-white border-[#0B7A8F]"
                    : "bg-white border-gray-200"
              )}>
                {concluida
                  ? <Check size={12} className="text-white" />
                  : atual
                    ? <div className="w-2 h-2 rounded-full bg-[#0B7A8F]" />
                    : null}
              </div>
              <div className={cn(
                "h-0.5 flex-1",
                idx === ETAPAS.length - 1 ? "invisible" : concluida ? "bg-[#0B7A8F]" : "bg-gray-200"
              )} />
            </div>
            <p className={cn(
              "text-center text-[10px] leading-tight px-0.5 mt-1",
              concluida ? "text-[#0B7A8F] font-medium"
                : atual ? "text-[#002533] font-bold"
                  : "text-gray-400"
            )}>{etapa}</p>
          </div>
        )
      })}
    </div>
  )
}

// ─── Bloco A — Etapas (coluna direita) ───────────────────────────────────────

function BlocoEtapas({ vistoria }: { vistoria: Vistoria }) {
  const etapaLabel = ETAPAS[vistoria.etapa] ?? "Concluído"
  const ultimoEvento = vistoria.historico[vistoria.historico.length - 1]

  return (
    <div className="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 space-y-4">
      <h2 className="text-base font-bold text-gray-900">Status da vistoria</h2>

      {/* Etapa atual — destaque */}
      <div className="flex items-center gap-3 p-4 bg-[#0B7A8F]/5 border border-[#0B7A8F]/10 rounded-lg">
        <div className="h-10 w-10 rounded-full bg-[#0B7A8F]/10 flex items-center justify-center shrink-0">
          <Zap size={18} className="text-[#0B7A8F]" aria-hidden="true" />
        </div>
        <div className="flex-1 min-w-0">
          <p className="text-xs text-gray-400 mb-1">Etapa atual</p>
          <span className={cn(
            "inline-flex items-center text-xs font-semibold px-2.5 py-1 rounded-full",
            vistoria.statusColor
          )}>
            {etapaLabel}
          </span>
        </div>
      </div>

      {/* Última atualização */}
      {ultimoEvento && (
        <div className="flex items-center justify-between text-sm">
          <span className="text-gray-500 flex items-center gap-1.5">
            <Clock size={13} className="text-gray-400" aria-hidden="true" />
            Última atualização
          </span>
          <span className="font-medium text-gray-800">{ultimoEvento.data}</span>
        </div>
      )}

      {/* Stepper */}
      <StepperEtapas etapaAtual={vistoria.etapa} />
    </div>
  )
}

// ─── Bloco B — Resumo (coluna direita) ───────────────────────────────────────

function BlocoResumo({ vistoria }: { vistoria: Vistoria }) {
  return (
    <div className="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 space-y-4">
      <h2 className="text-base font-bold text-gray-900">Resumo</h2>

      <div className="space-y-3 text-sm">
        <div className="flex items-center justify-between">
          <span className="flex items-center gap-1.5 text-gray-500">
            <FileText size={13} className="text-gray-400" />
            Código
          </span>
          <span className="font-mono font-medium text-gray-800">{vistoria.id}</span>
        </div>
        <div className="flex items-center justify-between">
          <span className="flex items-center gap-1.5 text-gray-500">
            <Tag size={13} className="text-gray-400" />
            Tipo
          </span>
          <span className="font-medium text-gray-800">{vistoria.tipo}</span>
        </div>
        <div className="flex items-center justify-between">
          <span className="flex items-center gap-1.5 text-gray-500">
            <CalendarClock size={13} className="text-gray-400" />
            Data
          </span>
          <span className="font-medium text-gray-800">{vistoria.data}</span>
        </div>
        <div className="flex items-center justify-between">
          <span className="flex items-center gap-1.5 text-gray-500">
            <DollarSign size={13} className="text-gray-400" />
            Valor
          </span>
          <span className="font-medium text-gray-800">{vistoria.valor}</span>
        </div>
        <div className="flex items-center justify-between">
          <span className="flex items-center gap-1.5 text-gray-500">
            <FileText size={13} className="text-gray-400" />
            Relatório
          </span>
          <span className={cn("font-medium", vistoria.temRelatorio ? "text-green-600" : "text-gray-400")}>
            {vistoria.temRelatorio ? "Disponível" : "Pendente"}
          </span>
        </div>
      </div>
    </div>
  )
}

// ─── Bloco C — Ações (coluna direita) ────────────────────────────────────────

function BlocoAcoes({ vistoria }: { vistoria: Vistoria }) {
  return (
    <div className="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 space-y-3">
      <h2 className="text-base font-bold text-gray-900">Ações</h2>
      {vistoria.temRelatorio && (
        <AdminButton
          variant="primary"
          size="md"
          icon={<Download size={15} />}
          onClick={() => {}}
          className="w-full justify-center"
        >
          Baixar Relatório
        </AdminButton>
      )}
      <AdminButton
        variant="outline"
        size="md"
        onClick={() => {}}
        className="w-full justify-center"
      >
        Solicitar Alteração
      </AdminButton>
    </div>
  )
}

// ─── Page ─────────────────────────────────────────────────────────────────────

export default function VistoriaDetalhePage({ params }: { params: Promise<{ id: string }> }) {
  const { id } = use(params)
  const router = useRouter()
  const vistoria = getVistoriaById(id)

  if (!vistoria) {
    return (
      <AdminDashboardLayout profile="cliente" title="Vistoria não encontrada">
        <div className="flex flex-col items-center justify-center py-20 gap-4">
          <p className="text-gray-500">Vistoria não encontrada.</p>
          <AdminButton variant="outline" onClick={() => router.back()}>Voltar</AdminButton>
        </div>
      </AdminDashboardLayout>
    )
  }

  const breadcrumbLabel =
    vistoria.status === "Pedido"
      ? "Vistorias Solicitadas"
      : vistoria.status === "Em andamento"
        ? "Vistorias em Andamento"
        : "Vistorias Concluídas"

  const breadcrumbHref =
    vistoria.status === "Pedido"
      ? "/admin/cliente/vistorias/pedidos"
      : vistoria.status === "Em andamento"
        ? "/admin/cliente/vistorias/andamento"
        : "/admin/cliente/vistorias/concluidas"

  return (
    <AdminDashboardLayout
      profile="cliente"
      title={vistoria.id}
      breadcrumbs={[
        { label: "Vistorias", href: "/admin/cliente/vistorias/andamento" },
        { label: breadcrumbLabel, href: breadcrumbHref },
      ]}
    >
      <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">

        {/* ── Coluna esquerda (2/3) ──────────────────────────────────────── */}
        <div className="lg:col-span-2 space-y-6">

          {/* Informações da Vistoria */}
          <div className="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <div className="flex items-center gap-3 mb-5">
              <h2 className="text-base font-bold text-gray-900">Informações da Vistoria</h2>
              <span className={cn("text-xs font-semibold px-2.5 py-1 rounded-full", vistoria.statusColor)}>
                {vistoria.status}
              </span>
            </div>
            <div className="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <InfoRow
                icon={<MapPin size={16} className="text-[#0B7A8F]" />}
                label="Endereço"
                value={vistoria.endereco}
              />
              <InfoRow
                icon={<Tag size={16} className="text-[#0B7A8F]" />}
                label="Tipo de vistoria"
                value={vistoria.tipo}
              />
              <InfoRow
                icon={<CalendarClock size={16} className="text-[#0B7A8F]" />}
                label="Data / hora agendada"
                value={vistoria.dataHora}
              />
              <InfoRow
                icon={<User size={16} className="text-[#0B7A8F]" />}
                label="Responsável"
                value={vistoria.responsavel}
              />
            </div>

            {/* Detalhes secundários */}
            <div className="mt-5 pt-5 border-t border-gray-100 grid grid-cols-2 sm:grid-cols-3 gap-4">
              {[
                { label: "Valor",     value: vistoria.valor },
                { label: "Data",      value: vistoria.data  },
                { label: "Relatório", value: vistoria.temRelatorio ? "Disponível" : "Pendente" },
              ].map(({ label, value }) => (
                <div key={label}>
                  <p className="text-xs text-gray-400 uppercase tracking-wide">{label}</p>
                  <p className={cn(
                    "text-sm font-medium mt-0.5",
                    label === "Relatório"
                      ? vistoria.temRelatorio ? "text-green-600" : "text-gray-400"
                      : "text-gray-700"
                  )}>{value}</p>
                </div>
              ))}
            </div>
          </div>

          {/* Histórico */}
          <div className="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
            <h2 className="text-base font-bold text-gray-900 mb-5 flex items-center gap-2">
              <MessageSquare size={16} className="text-[#0B7A8F]" aria-hidden="true" />
              Histórico
            </h2>
            <div className="space-y-4">
              {vistoria.historico.map((item, idx) => (
                <div key={idx} className="flex gap-4">
                  <div className="w-1 rounded-full bg-[#0B7A8F]/20 shrink-0" />
                  <div>
                    <p className="text-xs text-gray-400 font-mono mb-0.5">{item.data}</p>
                    <p className="text-sm text-gray-700 leading-relaxed">{item.texto}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        {/* ── Coluna direita (1/3) ───────────────────────────────────────── */}
        <div className="space-y-6">
          <BlocoEtapas vistoria={vistoria} />
          <BlocoResumo vistoria={vistoria} />
          <BlocoAcoes vistoria={vistoria} />
        </div>
      </div>
    </AdminDashboardLayout>
  )
}
