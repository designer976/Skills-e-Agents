@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  * {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background-color: #1C1411;
    color: #F0ECE4;
    font-family: Inter, system-ui, sans-serif;
  }

  ::selection {
    background: rgba(196, 75, 58, 0.3);
    color: #F0ECE4;
  }
}

@layer components {
  /* Buttons */
  .btn-primary {
    @apply inline-flex items-center gap-2 font-semibold px-6 py-3 rounded-full
           transition-[background-color,box-shadow] duration-200 hover:brightness-110 active:scale-95;
    background-color: #C44B3A;
    color: #F0ECE4;
    box-shadow: 0 0 20px rgba(196, 75, 58, 0.3);
  }

  .btn-ghost {
    @apply inline-flex items-center gap-2 font-semibold px-6 py-3 rounded-full
           transition-[background-color,border-color] duration-200;
    color: #F0ECE4;
    border: 1px solid rgba(212, 184, 150, 0.2);
  }

  .btn-ghost:hover {
    border-color: rgba(212, 184, 150, 0.4);
    background-color: #2F2119;
  }

  .btn-outline-primary {
    @apply inline-flex items-center gap-2 font-semibold px-6 py-3 rounded-full
           transition-[background-color,border-color] duration-200;
    color: #C44B3A;
    border: 1px solid rgba(196, 75, 58, 0.4);
  }

  .btn-outline-primary:hover {
    border-color: #C44B3A;
    background-color: rgba(196, 75, 58, 0.1);
  }

  /* Labels */
  .section-label {
    @apply text-xs font-semibold tracking-[0.2em] uppercase;
    color: #A67C52;
  }

  /* Typography */
  .display-title {
    @apply font-display font-bold leading-tight tracking-tight;
  }

  /* Glass card */
  .glass-card {
    @apply backdrop-blur-sm rounded-2xl transition-[border-color,box-shadow] duration-300;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.04) 0%, rgba(255, 255, 255, 0.01) 100%);
    border: 1px solid rgba(212, 184, 150, 0.1);
  }

  .glass-card:hover {
    border-color: rgba(212, 184, 150, 0.25);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(212, 184, 150, 0.1);
  }

  /* Gradient text */
  .gradient-text {
    @apply bg-clip-text text-transparent;
    background-image: linear-gradient(135deg, #F0ECE4 0%, #D4B896 50%, #C44B3A 100%);
  }

  .gradient-text-red {
    @apply bg-clip-text text-transparent;
    background-image: linear-gradient(135deg, #C44B3A 0%, #6B2016 100%);
  }

  /* Divider */
  .divider {
    border-top: 1px solid rgba(212, 184, 150, 0.1);
  }

  /* Pill badge */
  .pill {
    @apply inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-xs font-medium;
    border: 1px solid rgba(212, 184, 150, 0.2);
    background-color: #2F2119;
    color: #9E8B7A;
  }
}

@layer utilities {
  .text-balance {
    text-wrap: balance;
  }

  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  .glow-primary {
    box-shadow: 0 0 40px rgba(196, 75, 58, 0.2);
  }

  .glow-primary-sm {
    box-shadow: 0 0 16px rgba(196, 75, 58, 0.15);
  }

  .text-glow {
    text-shadow: 0 0 30px rgba(196, 75, 58, 0.4);
  }
}
