@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  * {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background-color: #F8F4EE;
    color: #1A1209;
    font-family: Inter, system-ui, sans-serif;
  }

  ::selection {
    background: rgba(196, 75, 58, 0.15);
    color: #1A1209;
  }
}

@layer components {
  /* Buttons */
  .btn-primary {
    @apply inline-flex items-center gap-2 font-semibold px-6 py-3 rounded-full
           transition-[background-color,box-shadow] duration-200 hover:brightness-110 active:scale-95;
    background-color: #C44B3A;
    color: #FFFFFF;
    box-shadow: 0 0 20px rgba(196, 75, 58, 0.25);
  }

  .btn-ghost {
    @apply inline-flex items-center gap-2 font-semibold px-6 py-3 rounded-full
           transition-[background-color,border-color] duration-200;
    color: #1A1209;
    border: 1px solid rgba(26, 18, 9, 0.15);
  }

  .btn-ghost:hover {
    border-color: rgba(26, 18, 9, 0.3);
    background-color: #F0EAE0;
  }

  .btn-outline-primary {
    @apply inline-flex items-center gap-2 font-semibold px-6 py-3 rounded-full
           transition-[background-color,border-color] duration-200;
    color: #C44B3A;
    border: 1px solid rgba(196, 75, 58, 0.4);
  }

  .btn-outline-primary:hover {
    border-color: #C44B3A;
    background-color: rgba(196, 75, 58, 0.06);
  }

  /* Labels */
  .section-label {
    @apply text-xs font-semibold tracking-[0.2em] uppercase;
    color: #A67C52;
  }

  /* Typography */
  .display-title {
    @apply font-display font-bold leading-tight tracking-tight;
  }

  /* Card — white with soft shadow (light theme) */
  .glass-card {
    @apply rounded-2xl transition-[border-color,box-shadow] duration-300;
    background: #FFFFFF;
    border: 1px solid rgba(26, 18, 9, 0.07);
    box-shadow: 0 2px 16px rgba(26, 18, 9, 0.06);
  }

  .glass-card:hover {
    border-color: rgba(196, 75, 58, 0.2);
    box-shadow: 0 8px 32px rgba(26, 18, 9, 0.1);
  }

  /* Gradient text */
  .gradient-text {
    @apply bg-clip-text text-transparent;
    background-image: linear-gradient(135deg, #1A1209 0%, #7A6856 50%, #C44B3A 100%);
  }

  .gradient-text-red {
    @apply bg-clip-text text-transparent;
    background-image: linear-gradient(135deg, #C44B3A 0%, #8B2E20 100%);
  }

  /* Divider */
  .divider {
    border-top: 1px solid rgba(26, 18, 9, 0.08);
  }

  /* Pill badge */
  .pill {
    @apply inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-xs font-medium;
    border: 1px solid rgba(26, 18, 9, 0.1);
    background-color: #EAE0D2;
    color: #7A6856;
  }
}

@layer utilities {
  .text-balance {
    text-wrap: balance;
  }

  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  .glow-primary {
    box-shadow: 0 0 40px rgba(196, 75, 58, 0.15);
  }

  .glow-primary-sm {
    box-shadow: 0 0 16px rgba(196, 75, 58, 0.1);
  }

  .text-glow {
    text-shadow: 0 0 30px rgba(196, 75, 58, 0.3);
  }
}
