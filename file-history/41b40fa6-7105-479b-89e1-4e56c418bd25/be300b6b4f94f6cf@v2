interface BorderBeamProps {
  size?: number
  duration?: number
  colorFrom?: string
  colorTo?: string
  className?: string
}

export default function BorderBeam({
  size = 120,
  duration = 3,
  colorFrom = '#C44B3A',
  colorTo = '#D4B896',
  className = '',
}: BorderBeamProps) {
  return (
    <div
      className={`pointer-events-none absolute inset-0 rounded-2xl overflow-hidden ${className}`}
      style={{ zIndex: 1 }}
    >
      <style>{`
        @property --border-angle {
          syntax: '<angle>';
          initial-value: 0deg;
          inherits: false;
        }
        @keyframes borderBeamSpin {
          from { --border-angle: 0deg; }
          to { --border-angle: 360deg; }
        }
        @keyframes borderBeamMove {
          0%   { top: -${size / 2}px; left: 50%; transform: translateX(-50%); }
          25%  { top: 50%; left: calc(100% - ${size / 2}px); transform: translateY(-50%); }
          50%  { top: calc(100% - ${size / 2}px); left: 50%; transform: translateX(-50%); }
          75%  { top: 50%; left: -${size / 2}px; transform: translateY(-50%); }
          100% { top: -${size / 2}px; left: 50%; transform: translateX(-50%); }
        }
      `}</style>

      {/* Rotating conic gradient border */}
      <div
        style={{
          position: 'absolute',
          inset: -1,
          borderRadius: 'inherit',
          background: `conic-gradient(from var(--border-angle, 0deg), transparent 0deg, ${colorFrom} 60deg, ${colorTo} 120deg, transparent 180deg)`,
          animation: `borderBeamSpin ${duration}s linear infinite`,
          maskImage: 'linear-gradient(#000, #000)',
          WebkitMaskImage: '-webkit-linear-gradient(#000, #000)',
        }}
      />

      {/* Inner fill to show only the border ring */}
      <div
        className="absolute bg-surface"
        style={{
          inset: 1,
          borderRadius: 'inherit',
          zIndex: 2,
        }}
      />

      {/* Travelling glow */}
      <div
        className="absolute"
        style={{
          width: size,
          height: size,
          borderRadius: '50%',
          background: `radial-gradient(circle, ${colorFrom}40, transparent 70%)`,
          animation: `borderBeamMove ${duration}s linear infinite`,
          zIndex: 3,
        }}
      />
    </div>
  )
}
