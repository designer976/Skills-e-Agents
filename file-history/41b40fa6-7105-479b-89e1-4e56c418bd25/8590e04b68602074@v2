import { useState, useEffect } from 'react'
import { Menu, X, ChevronDown } from 'lucide-react'

const solutions = [
  { label: 'Para Salão de Beleza', href: '#' },
  { label: 'Para Barbearia', href: '#' },
  { label: 'Para Estúdio de Beleza', href: '#' },
]

export default function Navbar() {
  const [scrolled, setScrolled] = useState(false)
  const [menuOpen, setMenuOpen] = useState(false)
  const [solutionsOpen, setSolutionsOpen] = useState(false)

  useEffect(() => {
    const onScroll = () => setScrolled(window.scrollY > 20)
    window.addEventListener('scroll', onScroll)
    return () => window.removeEventListener('scroll', onScroll)
  }, [])

  return (
    <header
      className={`fixed top-0 left-0 right-0 z-50 transition-all duration-300 ${
        scrolled ? 'bg-white/90 backdrop-blur-md shadow-sm' : 'bg-transparent'
      }`}
    >
      <div className="max-w-7xl mx-auto px-6 lg:px-8">
        <div className="flex items-center justify-between h-18 py-4">
          {/* Logo */}
          <a href="/" className="flex items-center gap-2 group">
            <span className="font-display font-bold text-xl tracking-tight text-[#1A1A1A]">
              EASY{' '}
              <span className="text-primary">✦</span>{' '}
              SALON
            </span>
          </a>

          {/* Desktop Nav */}
          <nav className="hidden md:flex items-center gap-8">
            {/* Soluções dropdown */}
            <div className="relative">
              <button
                className="flex items-center gap-1 text-sm font-medium text-[#1A1A1A]/70 hover:text-[#1A1A1A] transition-colors"
                onMouseEnter={() => setSolutionsOpen(true)}
                onMouseLeave={() => setSolutionsOpen(false)}
              >
                Soluções <ChevronDown size={14} className={`transition-transform ${solutionsOpen ? 'rotate-180' : ''}`} />
              </button>
              {solutionsOpen && (
                <div
                  className="absolute top-full left-0 mt-2 w-52 bg-white rounded-2xl shadow-lg border border-accent py-2"
                  onMouseEnter={() => setSolutionsOpen(true)}
                  onMouseLeave={() => setSolutionsOpen(false)}
                >
                  {solutions.map((s) => (
                    <a
                      key={s.label}
                      href={s.href}
                      className="block px-4 py-2.5 text-sm text-[#1A1A1A]/70 hover:text-[#1A1A1A] hover:bg-cream transition-colors"
                    >
                      {s.label}
                    </a>
                  ))}
                </div>
              )}
            </div>
            <a href="#planos" className="text-sm font-medium text-[#1A1A1A]/70 hover:text-[#1A1A1A] transition-colors">
              Planos
            </a>
            <a href="#sobre" className="text-sm font-medium text-[#1A1A1A]/70 hover:text-[#1A1A1A] transition-colors">
              Quem somos
            </a>
          </nav>

          {/* Desktop CTAs */}
          <div className="hidden md:flex items-center gap-3">
            <a href="#" className="text-sm font-semibold text-[#1A1A1A]/70 hover:text-[#1A1A1A] transition-colors px-4 py-2">
              Login
            </a>
            <a href="#" className="btn-primary text-sm py-2.5 px-5">
              Crie sua conta
            </a>
          </div>

          {/* Mobile menu button */}
          <button
            className="md:hidden p-2 rounded-lg hover:bg-accent/50 transition-colors"
            onClick={() => setMenuOpen(!menuOpen)}
          >
            {menuOpen ? <X size={20} /> : <Menu size={20} />}
          </button>
        </div>
      </div>

      {/* Mobile Menu */}
      {menuOpen && (
        <div className="md:hidden bg-white border-t border-accent">
          <div className="px-6 py-4 space-y-4">
            <div>
              <p className="text-xs font-semibold uppercase tracking-wider text-muted mb-2">Soluções</p>
              {solutions.map((s) => (
                <a
                  key={s.label}
                  href={s.href}
                  className="block py-2 text-sm text-[#1A1A1A]/70 hover:text-[#1A1A1A]"
                >
                  {s.label}
                </a>
              ))}
            </div>
            <a href="#planos" className="block py-2 text-sm font-medium text-[#1A1A1A]/70">Planos</a>
            <a href="#sobre" className="block py-2 text-sm font-medium text-[#1A1A1A]/70">Quem somos</a>
            <div className="flex flex-col gap-2 pt-2 border-t border-accent">
              <a href="#" className="btn-ghost text-sm justify-center">Login</a>
              <a href="#" className="btn-primary text-sm justify-center">Crie sua conta</a>
            </div>
          </div>
        </div>
      )}
    </header>
  )
}
