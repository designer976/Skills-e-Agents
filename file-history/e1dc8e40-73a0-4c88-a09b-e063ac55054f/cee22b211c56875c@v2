export type NivelVistoriador = "Júnior" | "Pleno" | "Sênior"

export type PendenciaGravidade = "ok" | "leve" | "grave"

export interface PendenciaItem {
  descricao: string
  gravidade: PendenciaGravidade
}

export interface VistoriaQualidade {
  id: string
  imobiliaria: string
  endereco: string
  tipo: "Entrada" | "Saída"
  dataHora: string
  vistoriadorNome: string
  vistoriadorNivel: NivelVistoriador
  prioridade: Prioridade
  selo: QualidadeSelo
  // Diagnóstico
  pendencias: PendenciaItem[]
  // Dados extras para o modal
  cidade: string
  uf: string
  complemento?: string
  anotacoesInternas?: string
}

