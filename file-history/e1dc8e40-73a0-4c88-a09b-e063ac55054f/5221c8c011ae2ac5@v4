"use client"

import { useMemo, useState } from "react"
import { useRouter } from "next/navigation"
import { AdminDashboardLayout } from "@/components/admin/admin-dashboard-layout"
import { AdminTable, AdminTableSortHeader } from "@/components/admin/admin-table"
import { AdminInput } from "@/components/admin/admin-input"
import {
  VISTORIAS_ANDAMENTO,
  FASE_CONFIG,
  FASES_ORDERED,
  type VistoriaAndamento,
  type FaseVistoria,
} from "@/lib/mock-andamento"
import { type ColumnDef } from "@tanstack/react-table"
import {
  Search,
  AlertTriangle,
  Clock,
  User,
  Eye,
} from "lucide-react"
import { AdminSelect, AdminSelectContent, AdminSelectItem } from "@/components/admin/admin-select"
import { AdminButton } from "@/components/admin/admin-button"
import { cn } from "@/lib/utils"

// ─── Badge Fase ───────────────────────────────────────────────────────────────
function BadgeFase({ fase }: { fase: FaseVistoria }) {
  const cfg = FASE_CONFIG[fase]
  return (
    <span className={cn("inline-flex items-center text-xs font-semibold px-2.5 py-1 rounded-full", cfg.bg, cfg.color)}>
      {cfg.label}
    </span>
  )
}

// ─── Badge Alerta ─────────────────────────────────────────────────────────────
function BadgeAlerta({ mins }: { mins: number }) {
  if (mins < 30) return null
  return (
    <span className="inline-flex items-center gap-1 text-xs font-semibold px-2 py-0.5 rounded-full bg-orange-50 text-orange-600">
      <AlertTriangle size={11} />
      Sem update há {mins} min
    </span>
  )
}

// ─── Tempo relativo ───────────────────────────────────────────────────────────
function TempoRelativo({ mins }: { mins: number }) {
  if (mins === 0) return <span className="text-xs text-gray-400">Agora mesmo</span>
  if (mins < 60) return <span className="text-xs text-gray-400">há {mins} min</span>
  const h = Math.floor(mins / 60)
  return <span className="text-xs text-gray-400">há {h}h{mins % 60 > 0 ? ` ${mins % 60}min` : ""}</span>
}

// ─── Colunas ──────────────────────────────────────────────────────────────────
function buildColumns(onVer: (v: VistoriaAndamento) => void): ColumnDef<VistoriaAndamento>[] {
  return [
    {
      accessorKey: "dataAgendada",
      meta: { className: "w-[100px]" },
      header: ({ column }) => <AdminTableSortHeader column={column} label="Data / Hora" />,
      cell: ({ row }) => (
        <div className="min-w-0">
          <p className="text-sm font-medium text-gray-800 truncate">{row.original.dataAgendada}</p>
          <p className="text-xs text-gray-400 truncate">{row.original.horaAgendada}</p>
        </div>
      ),
    },
    {
      accessorKey: "clienteNome",
      meta: { className: "w-[150px]" },
      header: ({ column }) => <AdminTableSortHeader column={column} label="Cliente" />,
      cell: ({ row }) => (
        <div className="min-w-0">
          <p className="text-sm font-medium text-gray-800 truncate">{row.original.clienteNome}</p>
          <span className="text-xs text-gray-400 truncate block">{row.original.clienteTipo}</span>
        </div>
      ),
    },
    {
      accessorKey: "endereco",
      meta: { className: "hidden lg:table-cell w-[180px]" },
      header: "Endereço",
      cell: ({ row }) => (
        <div className="min-w-0">
          <p className="text-sm text-gray-700 truncate">{row.original.endereco}{row.original.complemento ? `, ${row.original.complemento}` : ""}</p>
          <p className="text-xs text-gray-400 truncate">{row.original.cidade}/{row.original.uf}</p>
        </div>
      ),
    },
    {
      accessorKey: "tipo",
      meta: { className: "hidden xl:table-cell w-[110px]" },
      header: "Tipo",
      cell: ({ row }) => <span className="text-sm text-gray-500 truncate block">{row.original.tipo}</span>,
    },
    {
      accessorKey: "vistoriadorNome",
      meta: { className: "w-[160px]" },
      header: "Vistoriador",
      cell: ({ row }) => (
        <div className="flex items-center gap-2 min-w-0">
          <div className="h-7 w-7 rounded-full bg-[#0B7A8F]/10 flex items-center justify-center shrink-0">
            <User size={13} className="text-[#0B7A8F]" />
          </div>
          <div className="min-w-0">
            <p className="text-sm font-medium text-gray-800 truncate">{row.original.vistoriadorNome}</p>
            <p className="text-xs text-gray-400 truncate">{row.original.vistoriadorNivel}</p>
          </div>
        </div>
      ),
    },
    {
      accessorKey: "faseAtual",
      meta: { className: "w-[120px]" },
      header: "Fase",
      cell: ({ row }) => <BadgeFase fase={row.original.faseAtual} />,
    },
    {
      accessorKey: "semUpdateHaMins",
      meta: { className: "hidden lg:table-cell w-[150px]" },
      header: ({ column }) => <AdminTableSortHeader column={column} label="Última atualização" />,
      cell: ({ row }) => (
        <div className="space-y-1">
          <div className="flex items-center gap-1 text-xs text-gray-400">
            <Clock size={11} />
            <TempoRelativo mins={row.original.semUpdateHaMins} />
          </div>
          <BadgeAlerta mins={row.original.semUpdateHaMins} />
        </div>
      ),
    },
    {
      id: "acoes",
      meta: { className: "w-[52px] min-w-[52px]" },
      header: "",
      cell: ({ row }) => (
        <div className="flex justify-end">
          <AdminButton
            variant="ghost"
            size="sm"
            icon={<Eye size={14} />}
            className="h-8 w-8 p-0"
            title="Ver detalhes"
            onClick={() => onVer(row.original)}
          />
        </div>
      ),
    },
  ]
}

// ─── Page ─────────────────────────────────────────────────────────────────────
export default function VistoriasAndamentoPage() {
  const router = useRouter()
  const [busca, setBusca] = useState("")
  const [filtroFase, setFiltroFase] = useState("all")
  const [filtroVistoriador, setFiltroVistoriador] = useState("all")
  const [filtroSomenteAlerta, setFiltroSomenteAlerta] = useState(false)

  const vistoriadores = useMemo(
    () => Array.from(new Set(VISTORIAS_ANDAMENTO.map((v) => v.vistoriadorNome))).sort(),
    []
  )

  const dados = useMemo(() => {
    const termo = busca.toLowerCase()
    return VISTORIAS_ANDAMENTO.filter((v) => {
      const matchBusca =
        !termo ||
        [v.id, v.endereco, v.clienteNome, v.vistoriadorNome, v.cidade].some((s) =>
          s.toLowerCase().includes(termo)
        )
      const matchFase = filtroFase === "all" || v.faseAtual === filtroFase
      const matchVistoriador = filtroVistoriador === "all" || v.vistoriadorNome === filtroVistoriador
      const matchAlerta = !filtroSomenteAlerta || v.temAlerta
      return matchBusca && matchFase && matchVistoriador && matchAlerta
    })
  }, [busca, filtroFase, filtroVistoriador, filtroSomenteAlerta])

  const totalAlertas = useMemo(() => VISTORIAS_ANDAMENTO.filter((v) => v.temAlerta).length, [])

  const columns = useMemo(
    () => buildColumns((v) => router.push(`/admin/cliente/vistorias/andamento/${v.id}`)),
    [router]
  )

  return (
    <AdminDashboardLayout
      profile="cliente"
      title="Vistorias em Andamento"
      breadcrumbs={[{ label: "Vistorias", href: "/admin/cliente/vistorias/andamento" }]}
    >
      <div className="space-y-4">
        {/* Alerta geral */}
        {totalAlertas > 0 && (
          <div className="flex items-center gap-3 px-4 py-3 bg-orange-50 border border-orange-100 rounded-lg">
            <AlertTriangle size={16} className="text-orange-500 shrink-0" />
            <p className="text-sm text-orange-700">
              <span className="font-semibold">{totalAlertas} vistoria{totalAlertas > 1 ? "s" : ""}</span>{" "}
              sem atualização há mais de 30 minutos.
            </p>
            <button
              onClick={() => setFiltroSomenteAlerta(true)}
              className="ml-auto text-xs font-semibold text-orange-600 hover:underline"
            >
              Ver somente alertas
            </button>
          </div>
        )}

        {/* Filtros — linha única */}
        <div className="flex flex-wrap items-end gap-3">
          <div className="flex-1 min-w-[200px]">
            <AdminInput
              variant="form"
              placeholder="Buscar por endereço, cliente ou código..."
              value={busca}
              onChange={(e) => setBusca(e.target.value)}
              icon={<Search size={15} aria-hidden="true" />}
            />
          </div>

          <AdminSelect
            placeholder="Todas as fases"
            value={filtroFase}
            onValueChange={setFiltroFase}
            triggerClassName="w-48"
          >
            <AdminSelectContent>
              <AdminSelectItem value="all">Todas as fases</AdminSelectItem>
              {FASES_ORDERED.map((f) => (
                <AdminSelectItem key={f} value={f}>{f}</AdminSelectItem>
              ))}
            </AdminSelectContent>
          </AdminSelect>

          <AdminSelect
            placeholder="Todos os vistoriadores"
            value={filtroVistoriador}
            onValueChange={setFiltroVistoriador}
            triggerClassName="w-48"
          >
            <AdminSelectContent>
              <AdminSelectItem value="all">Todos os vistoriadores</AdminSelectItem>
              {vistoriadores.map((v) => (
                <AdminSelectItem key={v} value={v}>{v}</AdminSelectItem>
              ))}
            </AdminSelectContent>
          </AdminSelect>

          <AdminButton
            variant={filtroSomenteAlerta ? "outline" : "outline"}
            onClick={() => setFiltroSomenteAlerta((v) => !v)}
            icon={<AlertTriangle size={14} aria-hidden="true" />}
            className={cn(
              filtroSomenteAlerta
                ? "bg-orange-50 border-orange-200 text-orange-700 hover:bg-orange-100"
                : ""
            )}
          >
            Somente alertas
          </AdminButton>
        </div>

        {/* Contador — abaixo dos filtros, acima da tabela */}
        <p className="text-sm text-muted-foreground">
          <span className="font-semibold text-foreground">{dados.length}</span>{" "}
          vistoria{dados.length !== 1 ? "s" : ""} encontrada{dados.length !== 1 ? "s" : ""}
        </p>

        {/* Tabela */}
        <AdminTable
          data={dados}
          columns={columns}
          filterValue={busca}
          showSearch={false}
          emptyMessage="Nenhuma vistoria em andamento encontrada."
          emptyIcon={<Clock size={32} className="opacity-30" />}
        />
      </div>
    </AdminDashboardLayout>
  )
}
