              <p className="text-sm text-gray-700">Conteúdo do card com padding padrão <code className="font-mono text-xs">p-6</code>.</p>
            </AdminCard>
          </Showcase>

          <Showcase label="<AdminCard padding='sm | md | lg | none'>">
            <div className="flex flex-col gap-3 max-w-sm">
              <AdminCard padding="sm"><p className="text-xs text-gray-500">padding sm — p-4</p></AdminCard>
              <AdminCard padding="md"><p className="text-xs text-gray-500">padding md — p-6 (padrão)</p></AdminCard>
              <AdminCard padding="lg"><p className="text-xs text-gray-500">padding lg — p-8</p></AdminCard>
            </div>
          </Showcase>

          <Showcase label="<AdminCard title='...' description='...' action={...}>">
            <AdminCard
              title="Título do Card"
              description="Descrição opcional do bloco"
              action={<AdminButton size="sm" variant="outline">Ação</AdminButton>}
              className="max-w-md"
            >
              <p className="text-sm text-gray-600">Conteúdo interno do card.</p>
            </AdminCard>
          </Showcase>

          <Showcase label="<AdminCard flat> — sem sombra">
            <AdminCard flat className="max-w-sm">
              <p className="text-sm text-gray-700">Card sem sombra, apenas borda.</p>
            </AdminCard>
          </Showcase>

          <Showcase label="<AdminCard overflow='hidden'> — para tabelas e listas">
            <AdminCard overflow="hidden" padding="none" className="max-w-sm">
              <div className="px-4 py-3 bg-gray-50 border-b border-gray-100 text-xs font-medium text-gray-500">Cabeçalho interno</div>
              <div className="p-4 text-sm text-gray-700">Conteúdo sem padding no card, controlado internamente.</div>
            </AdminCard>
          </Showcase>
        </Section>

        {/* ════════════════════════════════════════════════════════════════════
            ADMIN MODAL
        ════════════════════════════════════════════════════════════════════ */}
        <Section title="AdminModal" description="Modal padrão do painel com header fixo, body com scroll e footer fixo.">
          <Showcase label="<AdminModal> + <AdminModalHeader> + <AdminModalBody> + <AdminModalFooter>">
            <div className="flex flex-col gap-3">
              <AdminButton variant="primary" onClick={() => setShowModal(true)}>
                Abrir Modal Demo
              </AdminButton>
              <div className="text-xs text-gray-500 space-y-1">
                <p><code className="font-mono">size=&quot;sm&quot;</code> → max-w-md</p>
                <p><code className="font-mono">size=&quot;md&quot;</code> → max-w-2xl (padrão)</p>
                <p><code className="font-mono">size=&quot;lg&quot;</code> → max-w-3xl</p>
                <p><code className="font-mono">size=&quot;xl&quot;</code> → max-w-5xl</p>
              </div>
            </div>
          </Showcase>
          {showModal && (
            <AdminModal onClose={() => setShowModal(false)} size="md">
              <AdminModalHeader
                title="Título do Modal"
                subtitle="Subtítulo ou identificador contextual"
                onClose={() => setShowModal(false)}
              />
              <AdminModalBody>
                <p className="text-sm text-gray-700">Conteúdo do modal. O body tem <code className="font-mono text-xs">p-6 space-y-6</code> por padrão e scroll aparece ao passar o mouse.</p>
                <AdminCard flat title="Card dentro do modal">
                  <p className="text-sm text-gray-500">Cards e outros componentes funcionam normalmente dentro do modal.</p>
                </AdminCard>
              </AdminModalBody>
              <AdminModalFooter>
                <AdminButton variant="outline" onClick={() => setShowModal(false)}>Cancelar</AdminButton>
                <AdminButton variant="primary" onClick={() => setShowModal(false)}>Confirmar</AdminButton>
              </AdminModalFooter>
            </AdminModal>
          )}
        </Section>

        {/* ════════════════════════════════════════════════════════════════════
            ADMIN TOOLTIP
        ════════════════════════════════════════════════════════════════════ */}
        <Section title="DashboardFilters" description="Filtros de estado e período para dashboards.">
          <Showcase label="<DashboardFilters estado={...} periodo={...} />">
            <DashboardFilters
              estado={estado}
              onEstadoChange={setEstado}
              periodo={periodo}
              onPeriodoChange={setPeriodo}
            />
            <p className="text-xs text-gray-500 mt-4">
              Estado: <code className="font-mono">{estado}</code> | Período: <code className="font-mono">{periodo}</code>
            </p>
          </Showcase>
        </Section>

        {/* ════════════════════════════════════════════════════════════════════
            BADGES
        ════════════════════════════════════════════════════════════════════ */}
        <Section title="Badge" description="Badges para status e categorias.">
          <Showcase label="<Badge variant='...'>">
            <div className="flex flex-wrap items-center gap-3">
              <Badge>Default</Badge>
              <Badge variant="secondary">Secondary</Badge>
              <Badge variant="outline">Outline</Badge>
              <Badge variant="destructive">Destructive</Badge>
              <span className="px-2 py-1 rounded-full text-xs font-semibold text-green-700 bg-green-50">Concluída</span>
              <span className="px-2 py-1 rounded-full text-xs font-semibold text-blue-600 bg-blue-50">Em andamento</span>
              <span className="px-2 py-1 rounded-full text-xs font-semibold text-yellow-700 bg-yellow-50">Aguardando</span>
              <span className="px-2 py-1 rounded-full text-xs font-semibold text-red-600 bg-red-50">Divergência</span>
            </div>
          </Showcase>
        </Section>

        {/* ════════════════════════════════════════════════════════════════════
            SELECT (shadcn)
        ════════════════════════════════════════════════════════════════════ */}
        <Section title="Select" description="Select dropdown do shadcn/ui. Sempre use position=&quot;popper&quot; side=&quot;bottom&quot; sideOffset={4} no SelectContent para abrir abaixo do trigger com largura igual ao campo.">
          <Showcase label='<Select> + <SelectTrigger> + <SelectContent position="popper" side="bottom" sideOffset={4}>'>
            <div className="max-w-xs">
              <Select defaultValue="sp">
                <SelectTrigger>
                  <SelectValue placeholder="Selecione um estado" />
                </SelectTrigger>
                <SelectContent position="popper" side="bottom" sideOffset={4}>
                  <SelectItem value="sp">São Paulo</SelectItem>
                  <SelectItem value="rj">Rio de Janeiro</SelectItem>
                  <SelectItem value="mg">Minas Gerais</SelectItem>
                </SelectContent>
              </Select>
            </div>
          </Showcase>
        </Section>

        {/* ════════════════════════════════════════════════════════════════════
            TABLE (AdminTable + TanStack)
        ════════════════════════════════════════════════════════════════════ */}
        <Section title="Table" description="Tabela do sistema usando AdminTable + @tanstack/react-table.">
          <Showcase label="<AdminTable data={...} columns={...} />">
            <AdminTableDemo />
          </Showcase>
          <div className="mt-4 p-4 bg-blue-50 rounded-xl border border-blue-100">
            <p className="text-sm text-blue-800 font-medium mb-2">Paginação integrada</p>
            <p className="text-xs text-blue-600">
              O <code className="font-mono bg-blue-100 px-1 rounded">AdminTable</code> inclui paginação automática com:
            </p>
            <ul className="text-xs text-blue-600 mt-2 space-y-1 ml-4 list-disc">
              <li><strong>Itens por página:</strong> Select para escolher 5, 10, 20 ou 50 registros</li>
              <li><strong>Navegação:</strong> Botões para primeira, anterior, próxima e última página</li>
              <li><strong>Contador:</strong> Exibe "Página X de Y — N registro(s)"</li>
            </ul>
          </div>
        </Section>

        {/* ════════════════════════════════════════════════════════════════════
            BREADCRUMB
        ════════════════════════════════════════════════════════════════════ */}
        <Section title="Breadcrumb" description="Navegação hierárquica usando o componente shadcn/ui Breadcrumb.">
          <Showcase label="<Breadcrumb> + <BreadcrumbList> + <BreadcrumbItem>">
            <Breadcrumb>
              <BreadcrumbList>
                <BreadcrumbItem>
                  <BreadcrumbLink asChild><a href="#">Dashboard</a></BreadcrumbLink>
                </BreadcrumbItem>
                <BreadcrumbSeparator />
                <BreadcrumbItem>
                  <BreadcrumbLink asChild><a href="#">Vistorias</a></BreadcrumbLink>
                </BreadcrumbItem>
                <BreadcrumbSeparator />
                <BreadcrumbItem>
                  <BreadcrumbPage>V-2024-1021</BreadcrumbPage>
                </BreadcrumbItem>
              </BreadcrumbList>
            </Breadcrumb>
          </Showcase>
        </Section>

        {/* ════════════════════════════════════════════════════════════════════
            TABS (shadcn)
        ════════════════════════════════════════════════════════════════════ */}
        <Section title="Tabs" description="Navegação em abas do shadcn/ui.">
          <Showcase label="<Tabs> + <TabsList> + <TabsTrigger> + <TabsContent>">
            <Tabs defaultValue="clientes" className="w-full">
              <TabsList>
                <TabsTrigger value="clientes">Clientes</TabsTrigger>
                <TabsTrigger value="condicoes">Condições</TabsTrigger>
              </TabsList>
              <TabsContent value="clientes" className="mt-4">
                <p className="text-sm text-gray-600">Conteúdo da aba Clientes.</p>
              </TabsContent>
              <TabsContent value="condicoes" className="mt-4">
                <p className="text-sm text-gray-600">Conte��do da aba Condições.</p>
              </TabsContent>
            </Tabs>
          </Showcase>
        </Section>

        {/* ════════════════════════════════════════════════════════════════════
            SKELETON
        ════════════════════════════════════════════════════════════════════ */}
        <Section title="Skeleton" description="Placeholder de carregamento.">
          <Showcase label="<Skeleton className='h-4 w-[250px]' />">
            <div className="space-y-3">
              <Skeleton className="h-4 w-[250px]" />
              <Skeleton className="h-4 w-[200px]" />
              <Skeleton className="h-10 w-full max-w-sm" />
              <div className="flex items-center gap-3">
                <Skeleton className="h-12 w-12 rounded-full" />
                <div className="space-y-2">
                  <Skeleton className="h-4 w-[150px]" />
                  <Skeleton className="h-3 w-[100px]" />
                </div>
              </div>
            </div>
          </Showcase>
        </Section>

        {/* Footer */}
        </>)}
        <footer className="mt-16 pt-8 border-t border-gray-200 text-center">
          <p className="text-xs text-gray-400">
            Design System — Rios Vistorias © {new Date().getFullYear()}
          </p>
        </footer>

      </main>
    </div>
  )
}
