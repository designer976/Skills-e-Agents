"use client"

import { useMemo } from "react"
import Link from "next/link"
import { AdminDashboardLayout } from "@/components/admin/admin-dashboard-layout"
import { AdminButton } from "@/components/admin/admin-button"
import { AdminTable } from "@/components/admin/admin-table"
import { vistorias, type Vistoria } from "@/lib/mock-vistorias"
import { type ColumnDef } from "@tanstack/react-table"
import { Eye, Download } from "lucide-react"

const columns: ColumnDef<Vistoria, unknown>[] = [
  {
    accessorKey: "id",
    header: "Código",
    cell: ({ row }) => (
      <span className="font-mono text-xs text-gray-500">{row.original.id}</span>
    ),
  },
  {
    accessorKey: "endereco",
    header: "Endereço",
    cell: ({ row }) => (
      <span className="text-sm text-gray-700">{row.original.endereco}</span>
    ),
  },
  {
    accessorKey: "tipo",
    header: "Tipo",
    cell: ({ row }) => (
      <span className="text-sm text-gray-500">{row.original.tipo}</span>
    ),
  },
  {
    accessorKey: "data",
    header: "Data",
    cell: ({ row }) => (
      <span className="text-sm text-gray-500">{row.original.data}</span>
    ),
  },
  {
    id: "status",
    header: "Status",
    cell: () => (
      <span className="px-2.5 py-1 rounded-full text-xs font-semibold text-green-700 bg-green-50">
        Concluída
      </span>
    ),
  },
  {
    id: "acoes",
    header: "",
    cell: ({ row }) => (
      <div className="flex items-center gap-1 justify-end">
        <Link href={`/admin/cliente/vistorias/${row.original.id}`}>
          <AdminButton variant="ghost" size="sm" icon={<Eye size={14} />} className="h-8 w-8 p-0" title="Ver" />
        </Link>
        {row.original.temRelatorio && (
          <AdminButton variant="ghost" size="sm" icon={<Download size={14} />} className="h-8 w-8 p-0 text-[#0B7A8F]" title="Baixar relatório" />
        )}
      </div>
    ),
  },
]

export default function VistoriasConcluidasPage() {
  const data = useMemo(() => vistorias.filter((v) => v.status === "Concluído"), [])

  return (
    <AdminDashboardLayout
      profile="cliente"
      title="Vistorias Concluídas"
      breadcrumbs={[
        { label: "Vistorias", href: "/admin/cliente/vistorias/concluidas" },
      ]}
    >
      <AdminTable
        data={data}
        columns={columns}
        searchPlaceholder="Buscar por código ou endereço..."
        emptyMessage="Nenhuma vistoria concluída encontrada."
      />
    </AdminDashboardLayout>
  )
}
