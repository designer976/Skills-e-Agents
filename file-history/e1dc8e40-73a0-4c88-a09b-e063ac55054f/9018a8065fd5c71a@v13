  prazo: number
  vigenciaInicio: string
  vigenciaFim: string
  status: "ativo" | "expirado"
}

interface FaixaPreco {
  de: string
  ate: string
  preco: string
}

interface PrecosImovel {
  semMobilia: string
  semiMobiliado: string
  mobiliado: string
}

