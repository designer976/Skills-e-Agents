import {
  getVistoriaAndamentoById,
  FASES_ORDERED,
  FASE_CONFIG,
  TAG_CONFIG,
  faseIndex,
  type VistoriaAndamento,
  type FaseVistoria,
  type Anotacao,
} from "@/lib/mock-andamento"
import {
  MapPin,
  Tag,
  CalendarClock,
  User,
  Check,
  Lock,
  Clock,
  Zap,
  MessageSquare,
  Plus,
  AlertTriangle,
  ChevronRight,
