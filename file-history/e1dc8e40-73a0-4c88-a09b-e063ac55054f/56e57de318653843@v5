"use client"

import { useState, useMemo } from "react"
import { AdminDashboardLayout } from "@/components/admin/admin-dashboard-layout"
import { AdminButton } from "@/components/admin/admin-button"
import { AdminInput } from "@/components/admin/admin-input"
import { AdminTabs } from "@/components/admin/admin-tabs"
import { AdminSelect, AdminSelectContent, AdminSelectItem } from "@/components/admin/admin-select"
import {
  AdminModal,
  AdminModalHeader,
  AdminModalBody,
} from "@/components/admin/admin-modal"
import {
  VISTORIAS_QUALIDADE,
  SELO_CONFIG,
  PRIORIDADE_ABAS,
  type VistoriaQualidade,
  type Prioridade,
  type QualidadeSelo,
  type PendenciaGravidade,
} from "@/lib/mock-qualidade"
import {
  Search,
  CheckCircle2,
  AlertTriangle,
  XCircle,
  User,
  MapPin,
  Calendar,
  ClipboardList,
  MessageSquare,
  ChevronRight,
} from "lucide-react"
import { cn } from "@/lib/utils"

// ─── Selo de Qualidade ────────────────────────────────────────────────────────

function SeloQualidade({ selo }: { selo: QualidadeSelo }) {
  const cfg = SELO_CONFIG[selo]
  const Icon = selo === "green" ? CheckCircle2 : selo === "yellow" ? AlertTriangle : XCircle

  return (
    <div className={cn("flex items-center gap-3 px-4 py-3 rounded-lg border", cfg.bg, cfg.border)}>
      <div className={cn("h-9 w-9 rounded-full flex items-center justify-center shrink-0", cfg.iconBg)}>
        <Icon size={18} className={cfg.text} aria-hidden="true" />
      </div>
      <div className="min-w-0">
        <p className={cn("text-sm font-bold tracking-wide", cfg.text)}>{cfg.label}</p>
        <p className={cn("text-xs mt-0.5", cfg.text, "opacity-80")}>{cfg.subLabel}</p>
      </div>
    </div>
  )
}

// ─── Badge Pendência ──────────────────────────────────────────────────────────

const PENDENCIA_STYLE: Record<PendenciaGravidade, string> = {
  ok:    "bg-green-50 text-green-700 border-green-100",
  leve:  "bg-amber-50 text-amber-700 border-amber-100",
  grave: "bg-red-50 text-red-700 border-red-100",
}

const PENDENCIA_ICON: Record<PendenciaGravidade, React.ElementType> = {
  ok:    CheckCircle2,
  leve:  AlertTriangle,
  grave: XCircle,
}

function BadgePendencia({ gravidade, descricao }: { gravidade: PendenciaGravidade; descricao: string }) {
  const Icon = PENDENCIA_ICON[gravidade]
  return (
    <div className={cn("flex items-center gap-2 px-3 py-2 rounded-lg border text-xs", PENDENCIA_STYLE[gravidade])}>
      <Icon size={13} aria-hidden="true" className="shrink-0" />
      <span>{descricao}</span>
    </div>
  )
}

// ─── Card de Vistoria ─────────────────────────────────────────────────────────

function CardVistoria({
  vistoria,
  onClick,
}: {
  vistoria: VistoriaQualidade
  onClick: () => void
}) {
  return (
    <button
      type="button"
      onClick={onClick}
      className="w-full text-left flex flex-col sm:flex-row items-start sm:items-center gap-4 p-4 bg-card border border-border rounded-lg hover:bg-secondary transition-colors group"
    >
      {/* Bloco identidade */}
      <div className="flex-1 min-w-0 space-y-1">
        <p className="text-sm font-semibold text-foreground truncate">{vistoria.imobiliaria}</p>
        <p className="text-xs text-muted-foreground truncate">
          {vistoria.endereco}{vistoria.complemento ? `, ${vistoria.complemento}` : ""} — {vistoria.cidade}/{vistoria.uf}
        </p>
        <div className="flex flex-wrap items-center gap-3 pt-1">
          <span className="inline-flex items-center gap-1 text-xs text-muted-foreground">
            <Calendar size={11} aria-hidden="true" />
            {vistoria.dataHora}
          </span>
          <span className="inline-flex items-center gap-1 text-xs text-muted-foreground">
            <User size={11} aria-hidden="true" />
            {vistoria.vistoriadorNome}
            <span className="text-[10px] opacity-60">({vistoria.vistoriadorNivel})</span>
          </span>
          <span className="px-2 py-0.5 rounded-full text-xs font-medium bg-muted text-muted-foreground">
            {vistoria.tipo}
          </span>
        </div>
      </div>

      {/* Bloco selo */}
      <div className="shrink-0 w-full sm:w-56">
        <SeloQualidade selo={vistoria.selo} />
      </div>

      {/* Seta */}
      <ChevronRight
        size={16}
        className="shrink-0 text-muted-foreground opacity-0 group-hover:opacity-100 transition-opacity hidden sm:block"
        aria-hidden="true"
      />
    </button>
  )
}

// ─── Modal de Detalhe ─────────────────────────────────────────────────────────

type DetalheAba = "dados" | "avaliacao" | "anotacoes"

const DETALHE_ABAS = [
  { id: "dados",     label: "Dados",             icon: ClipboardList },
  { id: "avaliacao", label: "Avaliação",          icon: CheckCircle2  },
  { id: "anotacoes", label: "Anotações internas", icon: MessageSquare },
] as const

function ModalDetalhe({
  vistoria,
  onClose,
}: {
  vistoria: VistoriaQualidade
  onClose: () => void
}) {
  const [aba, setAba] = useState<DetalheAba>("dados")

  const itensPendencias = useMemo(() => ({
    ok:    vistoria.pendencias.filter((p) => p.gravidade === "ok"),
    leve:  vistoria.pendencias.filter((p) => p.gravidade === "leve"),
    grave: vistoria.pendencias.filter((p) => p.gravidade === "grave"),
  }), [vistoria.pendencias])

  return (
    <AdminModal onClose={onClose} size="lg">
      <AdminModalHeader
        title={vistoria.id}
        subtitle={`${vistoria.imobiliaria} — ${vistoria.endereco}`}
        onClose={onClose}
      />

      {/* Sub-abas */}
      <div className="px-6 pt-4">
        <AdminTabs
          value={aba}
          onChange={(v) => setAba(v as DetalheAba)}
          tabs={DETALHE_ABAS.map((a) => ({ id: a.id, label: a.label, icon: a.icon }))}
        />
      </div>

      <AdminModalBody className="pt-4">
        {/* ── Aba Dados ─────────────────────────────────────────────────────── */}
        {aba === "dados" && (
          <div className="space-y-4">
            {/* Selo */}
            <SeloQualidade selo={vistoria.selo} />

            {/* Informações */}
            <div className="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <InfoRow icon={MapPin} label="Endereço" value={`${vistoria.endereco}${vistoria.complemento ? `, ${vistoria.complemento}` : ""}`} />
              <InfoRow icon={MapPin} label="Cidade / UF" value={`${vistoria.cidade}/${vistoria.uf}`} />
              <InfoRow icon={ClipboardList} label="Tipo" value={vistoria.tipo} />
              <InfoRow icon={Calendar} label="Data / Hora" value={vistoria.dataHora} />
              <InfoRow icon={User} label="Vistoriador" value={`${vistoria.vistoriadorNome} (${vistoria.vistoriadorNivel})`} />
              <InfoRow icon={ClipboardList} label="Prioridade" value={vistoria.prioridade.toUpperCase()} />
            </div>
          </div>
        )}

        {/* ── Aba Avaliação ─────────────────────────────────────────────────── */}
        {aba === "avaliacao" && (
          <div className="space-y-5">
            <p className="text-sm text-muted-foreground">Diagnóstico automático com base nos dados da vistoria.</p>

            {/* Itens OK */}
            {itensPendencias.ok.length > 0 && (
              <div className="space-y-2">
                <p className="text-xs font-semibold text-foreground uppercase tracking-wide flex items-center gap-1.5">
                  <CheckCircle2 size={13} className="text-green-600" aria-hidden="true" />
                  Itens OK
                </p>
                <div className="space-y-1.5">
                  {itensPendencias.ok.map((p, i) => (
                    <BadgePendencia key={i} gravidade="ok" descricao={p.descricao} />
                  ))}
                </div>
              </div>
            )}

            {/* Pendências leves */}
            {itensPendencias.leve.length > 0 && (
              <div className="space-y-2">
                <p className="text-xs font-semibold text-foreground uppercase tracking-wide flex items-center gap-1.5">
                  <AlertTriangle size={13} className="text-amber-600" aria-hidden="true" />
                  Pendências leves
                </p>
                <div className="space-y-1.5">
                  {itensPendencias.leve.map((p, i) => (
                    <BadgePendencia key={i} gravidade="leve" descricao={p.descricao} />
                  ))}
                </div>
              </div>
            )}

            {/* Pendências graves */}
            {itensPendencias.grave.length > 0 && (
              <div className="space-y-2">
                <p className="text-xs font-semibold text-foreground uppercase tracking-wide flex items-center gap-1.5">
                  <XCircle size={13} className="text-red-600" aria-hidden="true" />
                  Pendências graves
                </p>
                <div className="space-y-1.5">
                  {itensPendencias.grave.map((p, i) => (
                    <BadgePendencia key={i} gravidade="grave" descricao={p.descricao} />
                  ))}
                </div>
              </div>
            )}
          </div>
        )}

        {/* ── Aba Anotações ─────────────────────────────────────────────────── */}
        {aba === "anotacoes" && (
          <div className="space-y-3">
            {vistoria.anotacoesInternas ? (
              <div className="p-4 bg-muted rounded-lg border border-border">
                <p className="text-sm text-foreground">{vistoria.anotacoesInternas}</p>
              </div>
            ) : (
              <div className="flex flex-col items-center justify-center py-10 gap-2">
                <MessageSquare size={32} className="text-muted-foreground opacity-30" aria-hidden="true" />
                <p className="text-sm text-muted-foreground">Nenhuma anotação interna registrada.</p>
              </div>
            )}
          </div>
        )}
      </AdminModalBody>

      <div className="px-6 pb-4 flex justify-end">
        <AdminButton variant="outline" onClick={onClose}>Fechar</AdminButton>
      </div>
    </AdminModal>
  )
}

// ─── InfoRow helper ───────────────────────────────────────────────────────────

function InfoRow({
  icon: Icon,
  label,
  value,
}: {
  icon: React.ElementType
  label: string
  value: string
}) {
  return (
    <div className="flex items-start gap-2">
      <Icon size={14} className="text-muted-foreground shrink-0 mt-0.5" aria-hidden="true" />
      <div className="min-w-0">
        <p className="text-xs text-muted-foreground">{label}</p>
        <p className="text-sm font-medium text-foreground truncate">{value}</p>
      </div>
    </div>
  )
}

// ─── Página Principal ─────────────────────────────────────────────────────────

export default function QualidadePage() {
  const [prioridade, setPrioridade] = useState<Prioridade>("p1")
  const [busca, setBusca] = useState("")
  const [filtroSelo, setFiltroSelo] = useState("all")
  const [vistoriaSelecionada, setVistoriaSelecionada] = useState<VistoriaQualidade | null>(null)

  const dados = useMemo(() => {
    const termo = busca.toLowerCase()
    return VISTORIAS_QUALIDADE.filter((v) => {
      const matchPrioridade = v.prioridade === prioridade
      const matchBusca = !termo || [v.id, v.imobiliaria, v.endereco, v.vistoriadorNome, v.cidade]
        .some((s) => s.toLowerCase().includes(termo))
      const matchSelo = filtroSelo === "all" || v.selo === filtroSelo
      return matchPrioridade && matchBusca && matchSelo
    })
  }, [prioridade, busca, filtroSelo])

  // Contadores por selo na aba atual
  const contagemSelos = useMemo(() => {
    const base = VISTORIAS_QUALIDADE.filter((v) => v.prioridade === prioridade)
    return {
      green:  base.filter((v) => v.selo === "green").length,
      yellow: base.filter((v) => v.selo === "yellow").length,
      red:    base.filter((v) => v.selo === "red").length,
    }
  }, [prioridade])

  return (
    <AdminDashboardLayout
      profile="cliente"
      title="Qualidade"
      breadcrumbs={[{ label: "Minha Empresa", href: "/admin/cliente/empresa" }]}
    >
      <div className="space-y-4">
        {/* Cards resumo por selo */}
        <div className="grid grid-cols-3 gap-3">
          <div className="flex items-center gap-3 p-4 bg-green-50 border border-green-100 rounded-lg">
            <CheckCircle2 size={20} className="text-green-600 shrink-0" aria-hidden="true" />
            <div>
              <p className="text-xl font-bold text-green-700">{contagemSelos.green}</p>
              <p className="text-xs text-green-600">Green Pass</p>
            </div>
          </div>
          <div className="flex items-center gap-3 p-4 bg-amber-50 border border-amber-100 rounded-lg">
            <AlertTriangle size={20} className="text-amber-600 shrink-0" aria-hidden="true" />
            <div>
              <p className="text-xl font-bold text-amber-700">{contagemSelos.yellow}</p>
              <p className="text-xs text-amber-600">Pendência Leve</p>
            </div>
          </div>
          <div className="flex items-center gap-3 p-4 bg-red-50 border border-red-100 rounded-lg">
            <XCircle size={20} className="text-red-600 shrink-0" aria-hidden="true" />
            <div>
              <p className="text-xl font-bold text-red-700">{contagemSelos.red}</p>
              <p className="text-xs text-red-600">Pendência Grave</p>
            </div>
          </div>
        </div>

        {/* Abas P1 / P2 / P3 */}
        <AdminTabs
          value={prioridade}
          onChange={(v) => { setPrioridade(v as Prioridade); setFiltroSelo("all"); setBusca("") }}
          tabs={PRIORIDADE_ABAS.map((a) => ({ id: a.id, label: a.label }))}
        />

        {/* Filtros */}
        <div className="flex flex-wrap items-center gap-3">
          <div className="flex-1 min-w-[200px]">
            <AdminInput
              variant="form"
              placeholder="Buscar por imobiliária, endereço ou vistoriador..."
              value={busca}
              onChange={(e) => setBusca(e.target.value)}
              icon={<Search size={15} aria-hidden="true" />}
            />
          </div>
          <div className="w-48">
            <AdminSelect
              placeholder="Todos os selos"
              value={filtroSelo}
              onValueChange={setFiltroSelo}
            >
              <AdminSelectContent>
                <AdminSelectItem value="all">Todos os selos</AdminSelectItem>
                <AdminSelectItem value="green">Green Pass</AdminSelectItem>
                <AdminSelectItem value="yellow">Pendência Leve</AdminSelectItem>
                <AdminSelectItem value="red">Pendência Grave</AdminSelectItem>
              </AdminSelectContent>
            </AdminSelect>
          </div>
        </div>

        {/* Contador */}
        <p className="text-sm text-muted-foreground">
          <span className="font-semibold text-foreground">{dados.length}</span>{" "}
          vistoria{dados.length !== 1 ? "s" : ""} encontrada{dados.length !== 1 ? "s" : ""}
        </p>

        {/* Lista de vistorias */}
        {dados.length === 0 ? (
          <div className="flex flex-col items-center justify-center py-16 gap-3">
            <Search size={32} className="text-muted-foreground opacity-30" aria-hidden="true" />
            <p className="text-sm text-muted-foreground">Nenhuma vistoria encontrada.</p>
          </div>
        ) : (
          <div className="space-y-2">
            {dados.map((v) => (
              <CardVistoria
                key={v.id}
                vistoria={v}
                onClick={() => setVistoriaSelecionada(v)}
              />
            ))}
          </div>
        )}
      </div>

      {/* Modal de detalhe */}
      {vistoriaSelecionada && (
        <ModalDetalhe
          vistoria={vistoriaSelecionada}
          onClose={() => setVistoriaSelecionada(null)}
        />
      )}
    </AdminDashboardLayout>
  )
}
