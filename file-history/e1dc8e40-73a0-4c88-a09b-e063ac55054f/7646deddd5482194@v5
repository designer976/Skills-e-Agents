              size="sm"
              icon={<CheckCircle2 size={14} />}
              className={cn("h-8 w-8 p-0", podeAprovar ? "text-green-600 hover:bg-green-50" : "opacity-40 cursor-not-allowed")}
              title={podeAprovar ? "Aprovar" : "Pagamento pendente — necessário confirmação Neofin para aprovar"}
              onClick={() => podeAprovar && handleAprovar(p)}
              disabled={!podeAprovar}
            />
            <AdminButton variant="ghost" size="sm" icon={<XCircle size={14} />} className="h-8 w-8 p-0 text-red-500 hover:bg-red-50" title="Rejeitar" onClick={() => setPedidoRejeitar(p)} />
            <AdminButton variant="ghost" size="sm" icon={<Download size={14} />} className="h-8 w-8 p-0" title="Baixar recibo" onClick={() => {}} />
          </div>
        )
      },
    },
  ]

  // ─── Colunas Aceito ───────────────────────────────────────────────────────
  const colunasAceito: ColumnDef<Pedido>[] = [
    {
      accessorKey: "id",
      header: ({ column }) => <AdminTableSortHeader column={column} label="Pedido" />,
      meta: { className: "w-[110px]" },
      cell: ({ row }) => <span className="font-mono text-xs text-gray-500 truncate block">{row.original.id}</span>,
    },
    {
      accessorKey: "dataVistoria",
      header: ({ column }) => <AdminTableSortHeader column={column} label="Data / Hora" />,
      meta: { className: "w-[100px]" },
      cell: ({ row }) => (
        <div>
          <p className="text-sm font-medium text-gray-800">{row.original.dataVistoria}</p>
          <p className="text-xs text-gray-400">{row.original.horaVistoria}</p>
        </div>
      ),
    },
    {
      accessorKey: "clienteNome",
      header: ({ column }) => <AdminTableSortHeader column={column} label="Cliente" />,
      meta: { className: "w-[160px] max-w-[160px]" },
      cell: ({ row }) => (
        <div className="min-w-0">
          <p className="text-sm font-medium text-gray-800 truncate">{row.original.clienteNome}</p>
          <span className="text-xs text-gray-400 truncate block">{row.original.tipoCliente}</span>
        </div>
      ),
    },
    {
      accessorKey: "logradouro",
      header: "Endereço",
      meta: { className: "hidden lg:table-cell w-[180px] max-w-[180px]" },
      cell: ({ row }) => (
        <span className="text-sm text-gray-600 truncate block">
          {row.original.logradouro}, {row.original.numero} — {row.original.cidade}/{row.original.uf}
        </span>
      ),
    },
    {
      accessorKey: "tipoVistoria",
      header: "Tipo",
      meta: { className: "w-[110px] max-w-[110px]" },
      cell: ({ row }) => <span className="text-sm text-gray-600 truncate block">{row.original.tipoVistoria}</span>,
    },
    {
      accessorKey: "valor",
      header: "Valor",
      meta: { className: "w-[90px]" },
      cell: ({ row }) => <span className="text-sm font-semibold text-gray-800">{row.original.valor}</span>,
    },
    {
      accessorKey: "statusPagamento",
      header: "Pagamento",
      meta: { className: "w-[110px]" },
      cell: ({ row }) => <BadgePagamento status={row.original.statusPagamento} />,
    },
    {
      accessorKey: "quemAprovou",
      header: "Aprovado por",
      meta: { className: "hidden xl:table-cell w-[120px] max-w-[120px]" },
      cell: ({ row }) => <span className="text-xs text-gray-400 truncate block">{row.original.quemAprovou ?? "—"}</span>,
    },
    {
      id: "acoes",
      header: "",
      meta: { className: "w-[52px] min-w-[52px]" },
      cell: ({ row }) => (
        <div className="flex justify-end">
          <AdminButton variant="ghost" size="sm" icon={<Eye size={14} />} className="h-8 w-8 p-0" title="Visualizar" onClick={() => setPedidoVisualizar(row.original)} />
        </div>
      ),
    },
  ]

  // ─── Colunas Não Aceito ───────────────────────────────────────────────────
  const colunasNaoAceito: ColumnDef<Pedido>[] = [
    {
      accessorKey: "id",
      header: ({ column }) => <AdminTableSortHeader column={column} label="Pedido" />,
      meta: { className: "w-[110px]" },
      cell: ({ row }) => <span className="font-mono text-xs text-gray-500 truncate block">{row.original.id}</span>,
    },
    {
      accessorKey: "clienteNome",
      header: ({ column }) => <AdminTableSortHeader column={column} label="Cliente" />,
      meta: { className: "w-[160px] max-w-[160px]" },
      cell: ({ row }) => (
        <div className="min-w-0">
          <p className="text-sm font-medium text-gray-800 truncate">{row.original.clienteNome}</p>
          <span className="text-xs text-gray-400 truncate block">{row.original.tipoCliente}</span>
        </div>
      ),
    },
    {
      accessorKey: "logradouro",
      header: "Endereço",
      meta: { className: "hidden lg:table-cell w-[180px] max-w-[180px]" },
      cell: ({ row }) => (
        <span className="text-sm text-gray-600 truncate block">
          {row.original.logradouro}, {row.original.numero} — {row.original.cidade}/{row.original.uf}
        </span>
      ),
    },
    {
      accessorKey: "tipoVistoria",
      header: "Tipo",
      meta: { className: "w-[110px] max-w-[110px]" },
      cell: ({ row }) => <span className="text-sm text-gray-600 truncate block">{row.original.tipoVistoria}</span>,
    },
    {
      accessorKey: "motivoRejeicao",
      header: "Motivo",
      meta: { className: "max-w-[200px]" },
      cell: ({ row }) => (
        <span className="text-sm text-red-600 truncate block">{row.original.motivoRejeicao ?? "—"}</span>
      ),
    },
    {
      accessorKey: "quemRejeitou",
      header: "Rejeitado por",
      meta: { className: "hidden xl:table-cell w-[120px] max-w-[120px]" },
      cell: ({ row }) => <span className="text-xs text-gray-400 truncate block">{row.original.quemRejeitou ?? "—"}</span>,
    },
    {
      id: "acoes",
      header: "",
      meta: { className: "w-[84px] min-w-[84px]" },
      cell: ({ row }) => (
        <div className="flex items-center justify-end gap-1">
          <AdminButton variant="ghost" size="sm" icon={<Eye size={14} />} className="h-8 w-8 p-0" title="Visualizar" onClick={() => setPedidoVisualizar(row.original)} />
          <AdminButton variant="ghost" size="sm" icon={<RotateCcw size={14} />} className="h-8 w-8 p-0 text-[#0B7A8F]" title="Replicar pedido" onClick={() => setPedidoReplicar(row.original)} />
        </div>
      ),
    },
  ]

  // ─── Colunas Cancelado ────────────────────────────────────────────────────
  const colunasCancelado: ColumnDef<Pedido>[] = [
    {
      accessorKey: "id",
      header: ({ column }) => <AdminTableSortHeader column={column} label="Pedido" />,
      meta: { className: "w-[110px]" },
      cell: ({ row }) => <span className="font-mono text-xs text-gray-500 truncate block">{row.original.id}</span>,
    },
    {
      accessorKey: "clienteNome",
      header: ({ column }) => <AdminTableSortHeader column={column} label="Cliente" />,
      meta: { className: "w-[160px] max-w-[160px]" },
      cell: ({ row }) => (
        <div className="min-w-0">
          <p className="text-sm font-medium text-gray-800 truncate">{row.original.clienteNome}</p>
          <span className="text-xs text-gray-400 truncate block">{row.original.tipoCliente}</span>
        </div>
      ),
    },
    {
      accessorKey: "logradouro",
      header: "Endereço",
      meta: { className: "hidden lg:table-cell w-[180px] max-w-[180px]" },
      cell: ({ row }) => (
        <span className="text-sm text-gray-600 truncate block">
          {row.original.logradouro}, {row.original.numero} — {row.original.cidade}/{row.original.uf}
        </span>
      ),
    },
    {
      accessorKey: "tipoVistoria",
      header: "Tipo",
      meta: { className: "w-[110px] max-w-[110px]" },
      cell: ({ row }) => <span className="text-sm text-gray-600 truncate block">{row.original.tipoVistoria}</span>,
    },
    {
      accessorKey: "motivoCancelamento",
      header: "Motivo",
      meta: { className: "max-w-[200px]" },
      cell: ({ row }) => <span className="text-sm text-gray-600 truncate block">{row.original.motivoCancelamento ?? "—"}</span>,
    },
    {
      accessorKey: "quemCancelou",
      header: "Cancelado por",
      meta: { className: "hidden xl:table-cell w-[120px] max-w-[120px]" },
      cell: ({ row }) => <span className="text-xs text-gray-400 truncate block">{row.original.quemCancelou ?? "—"}</span>,
    },
    {
      id: "taxa",
      header: "Taxa",
      meta: { className: "hidden xl:table-cell w-[80px]" },
      cell: ({ row }) => (
        row.original.taxaCancelamentoAplicada
          ? <span className="text-xs font-medium text-orange-600 bg-orange-50 px-2 py-0.5 rounded">Aplicada</span>
          : <span className="text-xs text-gray-400">—</span>
      ),
    },
    {
      id: "acoes",
      header: "",
      meta: { className: "w-[84px] min-w-[84px]" },
      cell: ({ row }) => (
        <div className="flex items-center justify-end gap-1">
          <AdminButton variant="ghost" size="sm" icon={<Eye size={14} />} className="h-8 w-8 p-0" title="Visualizar" onClick={() => setPedidoVisualizar(row.original)} />
          <AdminButton variant="ghost" size="sm" icon={<RotateCcw size={14} />} className="h-8 w-8 p-0 text-[#0B7A8F]" title="Replicar pedido" onClick={() => setPedidoReplicar(row.original)} />
        </div>
      ),
    },
  ]

  const colunasMap: Record<AbaStatus, ColumnDef<Pedido>[]> = {
    PENDENTE:   colunasPendente,
    ACEITO:     colunasAceito,
    NAO_ACEITO: colunasNaoAceito,
    CANCELADO:  colunasCancelado,
  }

  // ─── Aviso pagamento ──────────────────────────────────────────────────────
  const pedidosPFSemPagamento = useMemo(
    () => aba === "PENDENTE"
      ? dadosAba.filter((p) => p.requerPagamentoAntecipado && !p.temSelo && p.statusPagamento === "AGUARDANDO").length
      : 0,
    [aba, dadosAba]
  )

  return (
    <AdminDashboardLayout
      profile="backoffice"
      title="Pedidos de Vistoria"
      breadcrumbs={[
        { label: "Vistorias", href: "/admin/backoffice/vistorias/pedidos" },
        { label: "Pedidos" },
      ]}
    >
      <div className="space-y-4">
        {/* Abas */}
        <AdminTabs value={aba} onChange={(v) => { setAba(v as AbaStatus); setBusca("") }} tabs={abas} />

        {/* Aviso PF sem pagamento */}
        {pedidosPFSemPagamento > 0 && (
          <div className="flex items-center gap-3 px-4 py-3 bg-yellow-50 border border-yellow-100 rounded-lg">
            <AlertCircle size={16} className="text-yellow-600 shrink-0" />
            <p className="text-sm text-yellow-700">
              <span className="font-semibold">{pedidosPFSemPagamento} pedido{pedidosPFSemPagamento > 1 ? "s" : ""}</span>{" "}
              de cliente{pedidosPFSemPagamento > 1 ? "s" : ""} PF aguardando pagamento — aprovação bloqueada até confirmação Neofin.
            </p>
          </div>
        )}

        {/* Busca */}
        <div className="flex items-center gap-3">
          <div className="flex-1 min-w-[250px]">
            <AdminInput
              variant="form"
              placeholder="Buscar por ID, endereço ou cliente..."
              value={busca}
              onChange={(e) => setBusca(e.target.value)}
              icon={<Search size={15} />}
            />
          </div>
        </div>

        <p className="text-sm text-muted-foreground">
          <span className="font-semibold text-foreground">{dadosAba.length}</span>{" "}
          pedido{dadosAba.length !== 1 ? "s" : ""} encontrado{dadosAba.length !== 1 ? "s" : ""}
        </p>

        {/* Tabela */}
        <AdminTable
          data={dadosAba}
          columns={colunasMap[aba]}
          filterValue={busca}
          showSearch={false}
          emptyMessage={`Nenhum pedido ${ABA_CONFIG[aba].label.toLowerCase()} encontrado.`}
          emptyIcon={<Copy size={32} className="opacity-30" />}
        />
      </div>

      {/* Modais */}
      {pedidoVisualizar && (
        <ModalVisualizar pedido={pedidoVisualizar} onClose={() => setPedidoVisualizar(null)} />
      )}
      {pedidoRejeitar && (
        <ModalRejeitar pedido={pedidoRejeitar} onClose={() => setPedidoRejeitar(null)} onConfirm={handleRejeitar} />
      )}
      {pedidoReplicar && (
        <ModalReplicar pedido={pedidoReplicar} onClose={() => setPedidoReplicar(null)} onConfirm={handleReplicar} />
      )}
    </AdminDashboardLayout>
  )
}
