"use client"

import { useMemo, useState } from "react"
import Link from "next/link"
import { AdminDashboardLayout } from "@/components/admin/admin-dashboard-layout"
import { AdminButton } from "@/components/admin/admin-button"
import { AdminTable } from "@/components/admin/admin-table"
import { AdminModal, AdminModalHeader, AdminModalBody, AdminModalFooter } from "@/components/admin/admin-modal"
import { AdminInput } from "@/components/admin/admin-input"
import { Textarea } from "@/components/ui/textarea"
import { vistorias, type Vistoria } from "@/lib/mock-vistorias"
import { type ColumnDef } from "@tanstack/react-table"
import { Eye, Plus, CheckCircle2, Copy, MapPin, FileText, Calendar, Search } from "lucide-react"
import { RadioGroup, RadioGroupItem } from "@/components/ui/radio-group"
import { Label } from "@/components/ui/label"
import { AdminSelect, AdminSelectContent, AdminSelectItem } from "@/components/admin/admin-select"

type TipoCategoria = "Entrada" | "Saída"

const MODELOS_ENTRADA = ["Entrada", "Saída Completa", "Transferência", "Acompanhamento", "Final de obra", "Entrega de Chaves"] as const
const MODELOS_SAIDA = ["Saída Padrão", "Conferência"] as const

function gerarCodigo() {
  const ano = new Date().getFullYear()
  const num = Math.floor(1000 + Math.random() * 9000)
  return `V-${ano}-${num}`
}

const columns: ColumnDef<Vistoria, unknown>[] = [
  {
    accessorKey: "id",
    meta: { className: "w-[110px]" },
    header: "Código",
    cell: ({ row }) => (
      <span className="font-mono text-xs text-muted-foreground truncate block">{row.original.id}</span>
    ),
  },
  {
    accessorKey: "endereco",
    meta: { className: "w-[280px]" },
    header: "Endereço",
    cell: ({ row }) => (
      <span className="text-sm text-foreground truncate block">{row.original.endereco}</span>
    ),
  },
  {
    accessorKey: "tipo",
    meta: { className: "hidden lg:table-cell w-[110px]" },
    header: "Tipo",
    cell: ({ row }) => (
      <span className="text-sm text-muted-foreground truncate block">{row.original.tipo}</span>
    ),
  },
  {
    id: "status",
    meta: { className: "w-[110px]" },
    header: "Status",
    cell: () => (
      <span className="px-2.5 py-1 rounded-full text-xs font-semibold text-yellow-700 bg-yellow-50">
        Aguardando
      </span>
    ),
  },
  {
    id: "acoes",
    meta: { className: "w-[52px] min-w-[52px]" },
    header: "",
    cell: ({ row }) => (
      <Link href={`/admin/cliente/vistorias/${row.original.id}`}>
        <AdminButton variant="ghost" size="sm" icon={<Eye size={14} aria-hidden="true" />} className="h-8 w-8 p-0" aria-label="Ver vistoria" />
      </Link>
    ),
  },
]

export default function VistoriasPedidosPage() {
  const data = useMemo(() => vistorias.filter((v) => v.status === "Pedido"), [])
  const [searchValue, setSearchValue] = useState("")

  // Modal
  const [showModal, setShowModal] = useState(false)
  const [etapa, setEtapa] = useState<"formulario" | "sucesso">("formulario")
  const [codigoGerado, setCodigoGerado] = useState("")
  const [copiado, setCopiado] = useState(false)

  // Campos
  const [endereco, setEndereco] = useState("")
  const [complemento, setComplemento] = useState("")
  const [cidade, setCidade] = useState("")
  const [tipoCategoria, setTipoCategoria] = useState<TipoCategoria | "">("")
  const [modelo, setModelo] = useState("")
  const [dataVistoria, setDataVistoria] = useState("")
  const [hora, setHora] = useState("")
  const [obs, setObs] = useState("")

  const modelos = tipoCategoria === "Entrada"
    ? MODELOS_ENTRADA
    : tipoCategoria === "Saída"
      ? MODELOS_SAIDA
      : []

  const formValido = !!(endereco && cidade && tipoCategoria && modelo && dataVistoria && hora)

  function abrirModal() {
    setEtapa("formulario")
    setCodigoGerado("")
    setEndereco(""); setComplemento(""); setCidade("")
    setTipoCategoria(""); setModelo(""); setDataVistoria(""); setHora(""); setObs("")
    setShowModal(true)
  }

  function handleTipoChange(v: TipoCategoria) {
    setTipoCategoria(v)
    setModelo("")
  }

  function solicitar() {
    setCodigoGerado(gerarCodigo())
    setEtapa("sucesso")
  }

  function copiarCodigo() {
    navigator.clipboard.writeText(codigoGerado)
    setCopiado(true)
    setTimeout(() => setCopiado(false), 2000)
  }

  return (
    <AdminDashboardLayout
      profile="cliente"
      title="Vistorias Solicitadas"
      breadcrumbs={[{ label: "Vistorias", href: "/admin/cliente/vistorias/pedidos" }]}
    >
      <div className="space-y-4">
        {/* Busca + Novo Pedido na mesma linha */}
        <div className="flex flex-wrap items-end gap-3">
          <div className="flex-1 min-w-[250px]">
            <AdminInput
              variant="form"
              placeholder="Buscar por código ou endereço..."
              value={searchValue}
              onChange={(e) => setSearchValue(e.target.value)}
              icon={<Search size={15} aria-hidden="true" />}
            />
          </div>
          <div>
            <AdminButton variant="primary" icon={<Plus size={16} aria-hidden="true" />} onClick={abrirModal}>
              Nova Vistoria
            </AdminButton>
          </div>
        </div>

        {/* Tabela sem search interno */}
        <AdminTable
          data={data}
          columns={columns}
          filterValue={searchValue}
          onFilterChange={setSearchValue}
          showSearch={false}
          emptyMessage="Nenhuma vistoria solicitada aguardando agendamento."
        />
      </div>

      {showModal && (
        <AdminModal onClose={() => setShowModal(false)} size="sm">
          {etapa === "formulario" ? (
            <>
              <AdminModalHeader
                title="Solicitar Nova Vistoria"
                subtitle="Preencha os dados para registrar sua solicitação"
                onClose={() => setShowModal(false)}
              />
              <AdminModalBody>
                {/* Endereço */}
                <div className="space-y-3">
                  <p className="text-xs font-semibold text-muted-foreground flex items-center gap-1.5 uppercase tracking-wide">
                    <MapPin size={13} className="text-[#0B7A8F]" aria-hidden="true" /> Endereço do Imóvel
                  </p>
                  <AdminInput
                    variant="form"
                    label="Endereço"
                    placeholder="Rua, número..."
                    value={endereco}
                    onChange={(e) => setEndereco(e.target.value)}
                  />
                  <AdminInput
                    variant="form"
                    label="Complemento"
                    placeholder="Apto, bloco... (opcional)"
                    value={complemento}
                    onChange={(e) => setComplemento(e.target.value)}
                  />
                  <AdminInput
                    variant="form"
                    label="Cidade / UF"
                    placeholder="São Paulo, SP"
                    value={cidade}
                    onChange={(e) => setCidade(e.target.value)}
                  />
                </div>

                {/* Tipo de Vistoria */}
                <div className="space-y-3">
                  <p className="text-xs font-semibold text-muted-foreground flex items-center gap-1.5 uppercase tracking-wide">
                    <FileText size={13} className="text-[#0B7A8F]" aria-hidden="true" /> Tipo de Vistoria
                  </p>
                  <RadioGroup
                    value={tipoCategoria}
                    onValueChange={(v) => handleTipoChange(v as TipoCategoria)}
                    className="grid grid-cols-2 gap-2"
                  >
                    {(["Entrada", "Saída"] as const).map((t) => (
                      <div
                        key={t}
                        className={`flex items-center gap-2 p-3 border rounded-lg cursor-pointer transition-colors ${
                          tipoCategoria === t
                            ? "border-[#0B7A8F] bg-[#0B7A8F]/5"
                            : "border-border hover:border-[#0B7A8F]/40"
                        }`}
                      >
                        <RadioGroupItem value={t} id={`tipo-${t}`} />
                        <Label htmlFor={`tipo-${t}`} className="cursor-pointer text-sm">{t}</Label>
                      </div>
                    ))}
                  </RadioGroup>

                  {/* Modelo — aparece ao selecionar categoria */}
                  {tipoCategoria !== "" && (
                    <AdminSelect
                      label="Modelo"
                      placeholder="Selecione o modelo..."
                      value={modelo}
                      onValueChange={setModelo}
                      variant="form"
                    >
                      <AdminSelectContent>
                        {modelos.map((m) => (
                          <AdminSelectItem key={m} value={m}>{m}</AdminSelectItem>
                        ))}
                      </AdminSelectContent>
                    </AdminSelect>
                  )}
                </div>

                {/* Data e Hora */}
                <div className="space-y-3">
                  <p className="text-xs font-semibold text-muted-foreground flex items-center gap-1.5 uppercase tracking-wide">
                    <Calendar size={13} className="text-[#0B7A8F]" aria-hidden="true" /> Data e Hora Desejada
                  </p>
                  <div className="grid grid-cols-2 gap-3">
                    <AdminInput
                      variant="form"
                      label="Data"
                      type="date"
                      value={dataVistoria}
                      onChange={(e) => setDataVistoria(e.target.value)}
                    />
                    <AdminSelect
                      label="Horário"
                      placeholder="Selecione"
                      value={hora}
                      onValueChange={setHora}
                      variant="form"
                    >
                      <AdminSelectContent>
                        {["08:00","09:00","10:00","11:00","13:00","14:00","15:00","16:00","17:00"].map((h) => (
                          <AdminSelectItem key={h} value={h}>{h}</AdminSelectItem>
                        ))}
                      </AdminSelectContent>
                    </AdminSelect>
                  </div>
                </div>

                {/* Observações */}
                <div className="space-y-1.5">
                  <label className="text-sm font-medium text-foreground">Observações (opcional)</label>
                  <Textarea
                    className="h-20 resize-none"
                    placeholder="Informações adicionais sobre o imóvel ou acesso..."
                    value={obs}
                    onChange={(e) => setObs(e.target.value)}
                  />
                </div>
              </AdminModalBody>
              <AdminModalFooter>
                <AdminButton variant="outline" onClick={() => setShowModal(false)}>Cancelar</AdminButton>
                <AdminButton variant="primary" onClick={solicitar} disabled={!formValido}>
                  Solicitar Vistoria
                </AdminButton>
              </AdminModalFooter>
            </>
          ) : (
            <>
              <AdminModalHeader title="Solicitação Enviada" onClose={() => setShowModal(false)} />
              <AdminModalBody>
                <div className="flex flex-col items-center text-center py-2 gap-4">
                  <div className="w-14 h-14 rounded-full bg-emerald-100 flex items-center justify-center">
                    <CheckCircle2 size={28} className="text-emerald-600" aria-hidden="true" />
                  </div>
                  <div>
                    <h3 className="text-base font-semibold text-foreground">Vistoria solicitada com sucesso!</h3>
                    <p className="text-sm text-muted-foreground mt-1">Em breve entraremos em contato para confirmar o agendamento.</p>
                  </div>

                  {/* Código */}
                  <div className="w-full p-4 bg-muted rounded-lg">
                    <p className="text-xs text-muted-foreground mb-1">Código da solicitação</p>
                    <div className="flex items-center justify-center gap-2">
                      <span className="text-2xl font-bold tracking-widest text-[#0B7A8F] font-mono">{codigoGerado}</span>
                      <AdminButton
                        variant="ghost"
                        size="sm"
                        className="h-8 w-8 p-0"
                        aria-label="Copiar código"
                        onClick={copiarCodigo}
                        icon={
                          copiado
                            ? <CheckCircle2 size={16} className="text-emerald-600" aria-hidden="true" />
                            : <Copy size={16} className="text-muted-foreground" aria-hidden="true" />
                        }
                      />
                    </div>
                  </div>

                  {/* Resumo */}
                  <div className="w-full p-4 bg-[#0B7A8F]/5 border border-[#0B7A8F]/10 rounded-lg text-left space-y-2">
                    <p className="text-sm text-foreground">
                      <span className="text-muted-foreground">Endereço: </span>
                      <span className="font-medium">{endereco}{complemento ? `, ${complemento}` : ""} — {cidade}</span>
                    </p>
                    <p className="text-sm text-foreground">
                      <span className="text-muted-foreground">Tipo: </span>
                      <span className="font-medium">{tipoCategoria} — {modelo}</span>
                    </p>
                    <p className="text-sm text-foreground">
                      <span className="text-muted-foreground">Data/Hora: </span>
                      <span className="font-medium">
                        {new Date(dataVistoria + "T00:00:00").toLocaleDateString("pt-BR")} às {hora}
                      </span>
                    </p>
                  </div>
                </div>
              </AdminModalBody>
              <AdminModalFooter>
                <AdminButton variant="primary" onClick={() => setShowModal(false)} className="w-full">
                  Entendi
                </AdminButton>
              </AdminModalFooter>
            </>
          )}
        </AdminModal>
      )}
    </AdminDashboardLayout>
  )
}
