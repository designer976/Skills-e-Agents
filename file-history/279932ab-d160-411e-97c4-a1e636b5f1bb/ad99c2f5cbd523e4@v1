import { Dialog, DialogContent, DialogHeader, DialogTitle, DialogBody } from "@/components/ui/dialog";
import { AdminSpecialtyForm } from "@/components/forms/AdminSpecialtyForm";
import { Specialty, CreateSpecialtyDto } from "@/types/specialty";

interface AdminSpecialtyModalProps {
  isOpen: boolean;
  onClose: () => void;
  specialty?: Specialty;
  onSave: (data: CreateSpecialtyDto) => void;
  isSaving?: boolean;
}

export function AdminSpecialtyModal({ isOpen, onClose, specialty, onSave, isSaving }: AdminSpecialtyModalProps) {
  const isEditing = !!specialty;

  const handleSave = (data: CreateSpecialtyDto) => {
    // Always ensure requestOnly is false for admin
    const adminData = {
      ...data,
      requestOnly: false
    };
    onSave(adminData);
  };

  const handleCancel = () => {
    onClose();
  };

  const initialData = specialty ? {
    name: specialty.name,
    description: specialty.description,
    displayOrder: specialty.displayOrder,
    isActive: specialty.isActive,
    requestOnly: false // Always false for admin
  } : undefined;

  return (
    <Dialog open={isOpen} onOpenChange={onClose}>
      <DialogContent
        className="w-[95vw] md:max-w-lg max-h-[90vh] md:max-h-[85vh] p-0 gap-0 rounded-lg border-none shadow-2xl overflow-hidden flex flex-col"
        aria-describedby="specialty-modal-description"
      >
        <DialogHeader className="px-6 pt-6 pb-4 border-b shrink-0">
          <DialogTitle className="text-xl font-semibold">
            {isEditing ? "Editar Especialidade" : "Nova Especialidade"}
          </DialogTitle>
          <div id="specialty-modal-description" className="sr-only">
            {isEditing ? "Formulário para editar uma especialidade existente" : "Formulário para criar uma nova especialidade"}
          </div>
        </DialogHeader>

        <DialogBody className="px-6">
          <AdminSpecialtyForm
            initialData={initialData}
            onSave={handleSave}
            onCancel={handleCancel}
            isEditing={isEditing}
            isSaving={isSaving}
          />
        </DialogBody>
      </DialogContent>
    </Dialog>
  );
}