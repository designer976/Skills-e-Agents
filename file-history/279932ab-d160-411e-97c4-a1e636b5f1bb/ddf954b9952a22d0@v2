import {
  Tooltip,
  TooltipContent,
  TooltipProvider,
  TooltipTrigger,
} from "@/components/ui/tooltip";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import { LoadingSpinner } from "@/components/ui/loading-spinner";
import { TimezoneCombobox } from "@/components/forms/TimezoneCombobox";
import { Info } from "lucide-react";
import { salonService } from "@/services/salonService";
import { formatPhone, formatCNPJ, unformatCNPJ } from "@/utils/formatters";
import { cnpjService } from "@/services/cnpjService";
import { useState } from "react";
import { SalonFormData } from "@/components/forms/SalonForm.types";

export type { SalonFormData } from "@/components/forms/SalonForm.types";
export { SALON_FORM_INITIAL_DATA } from "@/components/forms/SalonForm.types";

interface SalonFormProps {
  data: SalonFormData;
  onChange: (data: SalonFormData | ((prev: SalonFormData) => SalonFormData)) => void;
  disabled?: boolean;
}

export function SalonForm({ data, onChange, disabled }: SalonFormProps) {
  const [isFetchingCNPJ, setIsFetchingCNPJ] = useState(false);

  const handleChange = async (field: keyof SalonFormData, value: string): Promise<void> => {
    if (field === "cnpj") {
      const formatted = formatCNPJ(value);
      onChange((prev) => ({ ...prev, cnpj: formatted }));

      const clean = unformatCNPJ(formatted);
      if (clean.length === 14 && !isFetchingCNPJ) {
        setIsFetchingCNPJ(true);
        try {
          const cnpjData = await cnpjService.fetchCompanyData(clean);
          if (cnpjData?.razao_social) {
            onChange((prev) => ({
              ...prev,
              cnpj: formatted,
              razaoSocial: cnpjData.razao_social,
              nomeFantasia: prev.nomeFantasia || cnpjData.nome_fantasia || cnpjData.razao_social || "",
            }));
          }
        } catch {
          // silently ignore lookup errors
        } finally {
          setIsFetchingCNPJ(false);
        }
      }
    } else {
      onChange((prev) => ({ ...prev, [field]: value }));
    }
  };

  return (
    <div className="space-y-6">
      {/* Nome Fantasia */}
      <TooltipProvider>
        <div className="space-y-2">
          <Label htmlFor="sf-nomeFantasia">
            Nome Fantasia (como seus clientes o conhecem) *
          </Label>
          <Input
            id="sf-nomeFantasia"
            value={data.nomeFantasia}
            onChange={(e) => { void handleChange("nomeFantasia", e.target.value); }}
            placeholder="Nome do seu salão"
            maxLength={100}
            disabled={disabled}
          />
          <div className="flex items-center gap-2 text-xs text-muted-foreground">
            <span>Esse nome será usado na URL pública do salão</span>
            <Tooltip>
              <TooltipTrigger asChild>
                <Info className="w-4 h-4 cursor-help" />
              </TooltipTrigger>
              <TooltipContent>
                <p>A URL pública do seu salão será:</p>
                <p className="font-mono">
                  https://app.easysalon.com.br/
                  {salonService.generateSlug(data.nomeFantasia) || "nome-salao-nesse-formato"}
                </p>
              </TooltipContent>
            </Tooltip>
          </div>
        </div>
      </TooltipProvider>

      {/* CNPJ + Razão Social */}
      <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div className="space-y-2">
          <Label htmlFor="sf-cnpj">CNPJ</Label>
          <div className="relative">
            <Input
              id="sf-cnpj"
              value={data.cnpj}
              onChange={(e) => { void handleChange("cnpj", e.target.value); }}
              placeholder="XX.XXX.XXX/XXXX-XX"
              maxLength={18}
              disabled={disabled}
            />
            {isFetchingCNPJ && (
              <div className="absolute right-2 top-1/2 -translate-y-1/2">
                <LoadingSpinner size="sm" inline />
              </div>
            )}
          </div>
        </div>

        <div className="space-y-2">
          <Label htmlFor="sf-razaoSocial">Razão Social</Label>
          <Input
            id="sf-razaoSocial"
            value={data.razaoSocial}
            onChange={(e) => { void handleChange("razaoSocial", e.target.value); }}
            placeholder="Razão social da empresa"
            maxLength={150}
            disabled={disabled}
          />
        </div>
      </div>

      {/* Telefone + E-mail */}
      <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div className="space-y-2">
          <Label htmlFor="sf-telefone">Telefone/WhatsApp *</Label>
          <Input
            id="sf-telefone"
            value={data.telefoneComercial}
            onChange={(e) => { void handleChange("telefoneComercial", formatPhone(e.target.value)); }}
            placeholder="(XX) XXXXX-XXXX"
            maxLength={15}
            disabled={disabled}
          />
        </div>

        <div className="space-y-2">
          <Label htmlFor="sf-email">E-mail de Contato</Label>
          <Input
            id="sf-email"
            type="email"
            value={data.emailContato}
            onChange={(e) => { void handleChange("emailContato", e.target.value); }}
            placeholder="contato@seusalao.com"
            maxLength={100}
            disabled={disabled}
          />
        </div>
      </div>

      {/* Timezone */}
      <div className="space-y-2">
        <div className="flex items-center gap-2">
          <Label htmlFor="sf-timezone">Localidade *</Label>
          <TooltipProvider>
            <Tooltip>
              <TooltipTrigger asChild>
                <Info className="h-4 w-4 text-muted-foreground cursor-help" />
              </TooltipTrigger>
              <TooltipContent>
                <p className="max-w-xs">
                  Selecione a localidade do seu salão. Isso garante que os
                  horários de agendamento sejam exibidos corretamente para
                  clientes em qualquer parte do mundo.
                </p>
              </TooltipContent>
            </Tooltip>
          </TooltipProvider>
        </div>
        <TimezoneCombobox
          value={data.timezone}
          onValueChange={(value) => { void handleChange("timezone", value); }}
          disabled={disabled}
        />
      </div>

      {/* Link útil */}
      <div className="space-y-4">
        <Label className="text-base font-semibold">Link útil (Ex: Site)</Label>
        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div className="space-y-2">
            <Label htmlFor="sf-nomeLinkUtil">Nome do link</Label>
            <Input
              id="sf-nomeLinkUtil"
              value={data.nomeLinkUtil}
              onChange={(e) => { void handleChange("nomeLinkUtil", e.target.value); }}
              placeholder="Site, Instagram, Facebook..."
              maxLength={50}
              disabled={disabled}
            />
          </div>

          <div className="space-y-2">
            <Label htmlFor="sf-urlLinkUtil">URL</Label>
            <Input
              id="sf-urlLinkUtil"
              value={data.urlLinkUtil}
              onChange={(e) => { void handleChange("urlLinkUtil", e.target.value); }}
              placeholder="https://seusite.com"
              maxLength={200}
              disabled={disabled}
            />
          </div>
        </div>
      </div>
    </div>
  );
}
