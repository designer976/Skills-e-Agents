import { useState, useEffect, useCallback } from 'react';
import { format, startOfMonth } from 'date-fns';
import { LoadingSpinner } from "@/components/ui/loading-spinner";
import { Calendar as CalendarIcon, Building2 as Building2, Users as Users, Scissors as Scissors, ClipboardList as ClipboardList, MessageSquare as MessageSquare, TrendingUp as TrendingUp, ChevronLeft as ChevronLeft, ChevronRight as ChevronRight, Search as Search } from "lucide-react";
const Calendar = CalendarIcon;
import { EasySalonLayout } from '@/components/layout/EasySalonLayout';
import { PageHeader } from '@/components/layout/PageHeader';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Calendar as CalendarPicker } from '@/components/ui/calendar';
import { Popover, PopoverContent, PopoverTrigger } from '@/components/ui/popover';
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from '@/components/ui/select';
import { DataTable } from '@/components/ui/data-table';
import { cn } from '@/lib/utils';
import { getAdminNavItems } from '@/config/navigation';
import { useAuth } from '@/contexts/AuthContext';
import { useDebouncedValue } from '@/hooks/useDebouncedValue';
import {
  dashboardService,
  type AdminFunnelStats,
  type TenantFunnelRow,
  type AdminDashboardResponse,
} from '@/services/dashboardService';
import { toast } from 'sonner';
import { ResponsivePagination, DEFAULT_PAGE_SIZE_OPTIONS } from "@/components/ui/responsive-pagination";


type ConversionRate = {
  label: string;
  value: number;
  total: number;
};

function calcPercent(value: number, total: number): string {
  if (total === 0) return '0%';
  return `${Math.round((value / total) * 100)}%`;
}

type FunnelCardProps = {
  title: string;
  value: number;
  icon: React.ReactNode;
  description?: string;
  highlight?: boolean;
};

function FunnelCard({ title, value, icon, description, highlight }: FunnelCardProps) {
  return (
    <div className={`bg-card border rounded-lg p-4 ${highlight ? 'border-primary' : 'border-border'}`}>
      <div className="flex flex-row items-center justify-between pb-2">
        <p className="text-body font-medium text-foreground">{title}</p>
        <span className="text-muted-foreground">{icon}</span>
      </div>
      <div className="text-2xl font-bold">{value.toLocaleString('pt-BR')}</div>
      {description && <p className="text-xs text-muted-foreground mt-1">{description}</p>}
    </div>
  );
}

type FunnelBarProps = {
  steps: ConversionRate[];
};

function FunnelBars({ steps }: FunnelBarProps) {
  return (
    <div className="bg-card border border-border rounded-lg p-4">
      <div className="mb-4">
        <p className="text-body font-medium flex items-center gap-2">
          <TrendingUp className="h-4 w-4" />
          Funil de Conversão por Tenant
        </p>
      </div>
      <div className="space-y-4">
        {steps.map((step) => (
          <div key={step.label}>
            <div className="flex items-center justify-between mb-1">
              <span className="text-body text-muted-foreground">{step.label}</span>
              <span className="text-body font-semibold">
                {step.value} / {step.total} ({calcPercent(step.value, step.total)})
              </span>
            </div>
            <div className="w-full bg-secondary rounded-full h-2">
              <div
                className="bg-primary h-2 rounded-full transition-all"
                style={{ width: step.total > 0 ? `${Math.round((step.value / step.total) * 100)}%` : '0%' }}
              />
            </div>
          </div>
        ))}
      </div>
    </div>
  );
}

type TenantColumn = {
  key: keyof TenantFunnelRow;
  header: string;
  render?: (value: TenantFunnelRow[keyof TenantFunnelRow], row: TenantFunnelRow) => React.ReactNode;
};

export default function AdminDashboardPage() {
  const { user } = useAuth();
  const today = new Date();
  const tomorrow = new Date();
  tomorrow.setDate(today.getDate() + 1);

  const [dateFrom, setDateFrom] = useState<Date>(startOfMonth(new Date()));
  const [dateTo, setDateTo] = useState<Date>(tomorrow);
  const [allPeriods, setAllPeriods] = useState(false);
  const [statusFilter, setStatusFilter] = useState<'all' | 'active' | 'inactive'>('all');
  const [searchTerm, setSearchTerm] = useState('');
  const [currentPage, setCurrentPage] = useState(1);
  const [pageSize, setPageSize] = useState(DEFAULT_PAGE_SIZE_OPTIONS[0]);

  const [data, setData] = useState<AdminDashboardResponse | null>(null);
  const [loading, setLoading] = useState(true);

  const debouncedSearch = useDebouncedValue(searchTerm, 500);

  const fetchData = useCallback(async () => {
    try {
      setLoading(true);
      const result = await dashboardService.getAdminLeadFunnel({
        startDate: allPeriods ? undefined : format(dateFrom, 'yyyy-MM-dd'),
        endDate: allPeriods ? undefined : format(dateTo, 'yyyy-MM-dd'),
        status: statusFilter,
        search: debouncedSearch.trim() || undefined,
        page: currentPage,
        limit: pageSize,
      });
      setData(result);
    } catch {
      toast.error('Erro ao carregar dados do dashboard');
    } finally {
      setLoading(false);
    }
  }, [dateFrom, dateTo, allPeriods, statusFilter, debouncedSearch, currentPage, pageSize]);

  useEffect(() => {
    void fetchData();
  }, [fetchData]);

  useEffect(() => {
    setCurrentPage(1);
  }, [debouncedSearch, statusFilter, dateFrom, dateTo, allPeriods]);

  const funnel = data?.funnel;
  const tenants = data?.tenants;
  const totalPages = tenants?.totalPages ?? 0;
  const totalItems = tenants?.total ?? 0;

  const funnelSteps: ConversionRate[] = funnel
    ? [
      { label: 'Cadastraram um Salão', value: funnel.tenantsWithSalon, total: funnel.totalTenants },
      { label: 'Cadastraram Profissionais', value: funnel.tenantsWithProfessionals, total: funnel.totalTenants },
      { label: 'Possuem Clientes', value: funnel.tenantsWithClients, total: funnel.totalTenants },
      { label: 'Realizaram Agendamentos', value: funnel.tenantsWithAppointments, total: funnel.totalTenants },
    ]
    : [];

  const columns: TenantColumn[] = [
    {
      key: 'tenantName',
      header: 'Tenant',
      render: (value) => <span className="font-medium">{value as string}</span>,
    },
    {
      key: 'ownerName',
      header: 'Proprietário',
      render: (value, row) => (
        <div>
          <div className="font-medium">{(value as string) ?? '-'}</div>
          <div className="text-xs text-muted-foreground">{row.ownerEmail ?? '-'}</div>
        </div>
      ),
    },
    {
      key: 'tenantActive',
      header: 'Status',
      render: (value) => (
        <Badge className={value ? 'salon-badge-active' : 'salon-badge-inactive'}>{value ? 'Ativo' : 'Inativo'}</Badge>
      ),
    },
    {
      key: 'createdAt',
      header: 'Cadastro',
      render: (value) => {
        const date = new Date(value as string);
        if (isNaN(date.getTime())) return '-';
        return (
          <div>
            <div className="font-medium">{format(date, 'dd/MM/yyyy')}</div>
            <div className="text-xs text-muted-foreground">{format(date, 'HH:mm:ss')}</div>
          </div>
        );
      },
    },
    {
      key: 'salonCount',
      header: 'Salões',
      render: (value) => (
        <span className={Number(value) === 0 ? 'text-muted-foreground' : 'font-medium'}>
          {value as number}
        </span>
      ),
    },
    {
      key: 'professionalCount',
      header: 'Profissionais',
      render: (value) => (
        <span className={Number(value) === 0 ? 'text-muted-foreground' : 'font-medium'}>
          {value as number}
        </span>
      ),
    },
    {
      key: 'clientCount',
      header: 'Clientes',
      render: (value) => (
        <span className={Number(value) === 0 ? 'text-muted-foreground' : 'font-medium'}>
          {value as number}
        </span>
      ),
    },
    {
      key: 'appointmentCount',
      header: 'Agendamentos',
      render: (value) => (
        <span className={Number(value) === 0 ? 'text-muted-foreground' : 'font-medium'}>
          {value as number}
        </span>
      ),
    },
    {
      key: 'requestCount',
      header: 'Solicitações',
      render: (value) => (
        <span className={Number(value) === 0 ? 'text-muted-foreground' : 'font-medium'}>
          {value as number}
        </span>
      ),
    },
    {
      key: 'whatsappAppointmentCount',
      header: 'WhatsApp / IA',
      render: (value, row) => {
        const total = row.whatsappAppointmentCount + row.whatsappRequestCount;
        return (
          <div>
            <span className={total === 0 ? 'text-muted-foreground' : 'font-medium text-green-600'}>
              {total}
            </span>
            {total > 0 && (
              <div className="text-xs text-muted-foreground">
                {row.whatsappAppointmentCount} agend. · {row.whatsappRequestCount} sol.
              </div>
            )}
          </div>
        );
      },
    },
  ];

  const navItems = getAdminNavItems(user?.role ?? 'Easy Salon');

  if (loading && !data) {
    return (
      <EasySalonLayout
        sideNavItems={navItems}
        sideNavTitle="Easy Salon"
        sideNavSubtitle="Área Easy Salon"
      >
        <PageHeader
          title="Dashboard de Leads"
          subtitle="Acompanhe o funil de adoção da plataforma por tenant"
        />
        <div className="flex items-center justify-center h-64">
          <LoadingSpinner size="md" />
        </div>
      </EasySalonLayout>
    );
  }

  return (
    <EasySalonLayout
      sideNavItems={navItems}
      sideNavTitle="Easy Salon"
      sideNavSubtitle="Área Easy Salon"
    >
      <PageHeader
        title="Dashboard de Leads"
        subtitle="Acompanhe o funil de adoção da plataforma por tenant"
      />

      {/* Filters */}
      <div className="mb-6 flex flex-col gap-3 md:flex-row md:flex-wrap md:items-center">

        {/* De + Até — lado a lado no mobile */}
        <div className="flex items-center gap-2 flex-wrap">
          <div className="flex items-center gap-2">
            <span className="text-body font-medium">De:</span>
            <Popover>
              <PopoverTrigger asChild>
                <Button
                  variant="outline"
                  disabled={allPeriods}
                  className={cn('w-[140px] justify-start text-left font-normal', allPeriods && 'opacity-40')}
                >
                  <CalendarIcon className="mr-2 h-4 w-4" />
                  {format(dateFrom, 'dd/MM/yyyy')}
                </Button>
              </PopoverTrigger>
              <PopoverContent className="w-auto p-0" align="start">
                <CalendarPicker
                  mode="single"
                  selected={dateFrom}
                  onSelect={(date) => {
                    if (date) {
                      setDateFrom(date);
                      if (date > dateTo) setDateTo(date);
                    }
                  }}
                  initialFocus
                  className="p-3 pointer-events-auto"
                />
              </PopoverContent>
            </Popover>
          </div>

          <div className="flex items-center gap-2">
            <span className="text-body font-medium">Até:</span>
            <Popover>
              <PopoverTrigger asChild>
                <Button
                  variant="outline"
                  disabled={allPeriods}
                  className={cn('w-[140px] justify-start text-left font-normal', allPeriods && 'opacity-40')}
                >
                  <CalendarIcon className="mr-2 h-4 w-4" />
                  {format(dateTo, 'dd/MM/yyyy')}
                </Button>
              </PopoverTrigger>
              <PopoverContent className="w-auto p-0" align="start">
                <CalendarPicker
                  mode="single"
                  selected={dateTo}
                  onSelect={(date) => { if (date) setDateTo(date); }}
                  disabled={(date) => date < dateFrom}
                  initialFocus
                  className="p-3 pointer-events-auto"
                />
              </PopoverContent>
            </Popover>
          </div>
        </div>

        {/* Todos os períodos + Status — lado a lado no mobile */}
        <div className="flex items-center gap-2">
          <Button
            variant={allPeriods ? 'default' : 'outline'}
            size="sm"
            onClick={() => setAllPeriods((v) => !v)}
          >
            Todos os períodos
          </Button>

          <Select value={statusFilter} onValueChange={(v) => setStatusFilter(v as 'all' | 'active' | 'inactive')}>
            <SelectTrigger className="w-[130px]">
              <SelectValue placeholder="Status" />
            </SelectTrigger>
            <SelectContent>
              <SelectItem value="all">Todos</SelectItem>
              <SelectItem value="active">Ativos</SelectItem>
              <SelectItem value="inactive">Inativos</SelectItem>
            </SelectContent>
          </Select>
        </div>

        {/* Search — full width no mobile */}
        <div className="relative w-full md:w-auto">
          <Search className="absolute left-3 top-1/2 -translate-y-1/2 text-muted-foreground h-4 w-4" />
          <Input
            type="text"
            placeholder="Buscar por nome ou e-mail..."
            value={searchTerm}
            onChange={(e) => setSearchTerm(e.target.value)}
            className="pl-10 w-full md:w-[260px]"
          />
        </div>

        {loading && <LoadingSpinner size="sm" inline />}
      </div>

      {funnel && (
        <>
          {/* KPI Cards */}
          <div className="grid gap-4 grid-cols-2 md:grid-cols-4 mb-6">
            <FunnelCard
              title="Total de Tenants"
              value={funnel.totalTenants}
              icon={<Users className="h-4 w-4" />}
              highlight
            />
            <FunnelCard
              title="Com Salão Cadastrado"
              value={funnel.tenantsWithSalon}
              icon={<Building2 className="h-4 w-4" />}
              description={`${calcPercent(funnel.tenantsWithSalon, funnel.totalTenants)} dos tenants`}
            />
            <FunnelCard
              title="Com Profissionais"
              value={funnel.tenantsWithProfessionals}
              icon={<Scissors className="h-4 w-4" />}
              description={`${calcPercent(funnel.tenantsWithProfessionals, funnel.totalTenants)} dos tenants`}
            />
            <FunnelCard
              title="Total de Profissionais"
              value={funnel.totalProfessionals}
              icon={<Scissors className="h-4 w-4" />}
            />
            <FunnelCard
              title="Total de Clientes"
              value={funnel.totalClients}
              icon={<Users className="h-4 w-4" />}
              description={`${calcPercent(funnel.tenantsWithClients, funnel.totalTenants)} dos tenants possuem clientes`}
            />
            <FunnelCard
              title="Total de Agendamentos"
              value={funnel.totalAppointments}
              icon={<Calendar className="h-4 w-4" />}
              description={`${calcPercent(funnel.tenantsWithAppointments, funnel.totalTenants)} dos tenants agendaram`}
            />
            <FunnelCard
              title="Total de Solicitações"
              value={funnel.totalRequests}
              icon={<ClipboardList className="h-4 w-4" />}
            />
            <FunnelCard
              title="Via WhatsApp / IA"
              value={funnel.whatsappAppointments + funnel.whatsappRequests}
              icon={<MessageSquare className="h-4 w-4" />}
              description={`${funnel.whatsappAppointments} agend. · ${funnel.whatsappRequests} sol.`}
            />
          </div>

          {/* Funnel conversion bars */}
          <div className="mb-6">
            <FunnelBars steps={funnelSteps} />
          </div>
        </>
      )}

      {/* Tenants table */}
      <DataTable
        data={tenants?.data ?? []}
        columns={columns}
        mobileView="cards"
        mobileCardConfig={{
          title: "tenantName",
          subtitle: (row) => `${row.ownerEmail ?? '-'}`,
          badge: (row) => row.tenantActive ? "Ativo" : "Inativo",
          excludeFromGrid: ["ownerName", "createdAt", "tenantActive", "tenantName"],
        }}
      />

      <ResponsivePagination
        currentPage={currentPage}
        totalPages={totalPages}
        totalItems={totalItems}
        pageSize={pageSize}
        onPageChange={setCurrentPage}
        onPageSizeChange={(size) => { setPageSize(size); setCurrentPage(1); }}
        itemLabel="tenants"
        pageSizeOptions={DEFAULT_PAGE_SIZE_OPTIONS}
      />
    </EasySalonLayout>
  );
}
