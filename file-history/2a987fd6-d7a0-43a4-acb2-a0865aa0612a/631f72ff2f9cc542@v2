  header?: {
    showLogo?: boolean
    showDate?: boolean
    customText?: string
    logoSize?: { width: number; height: number }
  }
  footer?: {
    showLogo?: boolean
    showPageNumber?: boolean
    customText?: string
    companyInfo?: {
      name?: string
      cnpj?: string
      website?: string
      email?: string
      phone?: string
    }
  }
}

// Interface para validação de dados
interface ValidationError {
  field: string
  message: string
}

interface ValidationResult {
  valid: boolean
  errors: ValidationError[]
  warnings: string[]
}

// Interface para os dados da proposta
interface WaProjectProposalData {
  projeto: {
    nome: string
  }
  data_emissao: string
  validade_dias: string
  cliente: {
