    <script>
        // Função para imprimir com configurações otimizadas
        function printDocument() {
            // Mostrar dicas antes de imprimir
            const confirmPrint = confirm(`📋 DICAS PARA PDF PERFEITO:

✅ Configure no preview:
• Destino: "Salvar como PDF"
• Papel: A4
• Margens: Mínimas (ou 15mm personalizadas)
• ☑️ Gráficos de plano de fundo

Continuar para impressão?`);

            if (confirmPrint) {
                window.print();
            }
        }

        // Script para melhorar a experiência de impressão
        document.addEventListener('DOMContentLoaded', function() {
            // Detectar quando o usuário vai imprimir
            window.addEventListener('beforeprint', function() {
                document.body.classList.add('printing');
                console.log('🖨️ Preparando para impressão...');

                // Ajustar página para impressão
                document.documentElement.style.setProperty('--print-mode', '1');
            });

            window.addEventListener('afterprint', function() {
                document.body.classList.remove('printing');
                document.documentElement.style.removeProperty('--print-mode');
                console.log('✅ Impressão finalizada');
            });

            // Atalho de teclado
            document.addEventListener('keydown', function(e) {
                if ((e.ctrlKey || e.metaKey) && e.key === 'p') {
                    e.preventDefault();
                    printDocument();
                }
            });

            // Adicionar indicador visual de que é otimizado para impressão
            console.log('🎯 Template de Proposta Wa Project carregado');
            console.log('🖨️ Use Ctrl+P ou clique no botão para gerar PDF');
            console.log('📋 Configurações recomendadas: A4, Margens mínimas, Gráficos ativados');

            // Mostrar aviso inicial
            setTimeout(() => {
                const banner = document.createElement('div');
                banner.innerHTML = `
                    <div style="
                        position: fixed;
                        top: 80px;
                        right: 20px;
                        background: #E8F0FE;
                        border: 2px solid #003B71;
                        padding: 15px;
                        border-radius: 8px;
                        z-index: 999;
                        max-width: 250px;
                        font-size: 12px;
                        line-height: 1.4;
                        box-shadow: 0 4px 12px rgba(0,59,113,0.2);
                    ">
                        <strong style="color: #003B71;">💡 Dica:</strong><br>
                        Para PDF perfeito:<br>
                        • Ctrl+P<br>
                        • Margens: Mínimas<br>
                        • ☑️ Gráficos de fundo<br>
                        <button onclick="this.parentElement.parentElement.remove()"
                                style="margin-top: 8px; background: #003B71; color: white; border: none; padding: 4px 8px; border-radius: 4px; cursor: pointer;">
                            Entendi
                        </button>
                    </div>
                `;
                document.body.appendChild(banner);

                // Auto-remover após 10 segundos
                setTimeout(() => {
                    if (banner.parentElement) {
                        banner.remove();
                    }
                }, 10000);
            }, 2000);
        });
    </script>
