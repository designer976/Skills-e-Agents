    expect(result).toContain("A definir")
    expect(result).toContain("<p><strong>Prazo total:</strong>")
  })
})

// ── buildProposalTokens ────────────────────────────────────────────────────

describe("buildProposalTokens", () => {
  const mockSections: ProposalSection[] = [
    {
      key: "sobre-projeto",
      title: "Sobre o Projeto",
      content: "### Sistema de Gestão\nUm sistema completo para salões de beleza.\n\n**Principal benefício** da solução.\n**Entrega garantida** ao cliente."
    },
    {
      key: "escopo-funcionalidades",
      title: "Funcionalidades",
      content: "1. **Agendamento Online** — Interface para clientes marcarem horários.\n2. **Dashboard Administrativo** — Painel para gestão do salão."
    },
    {
      key: "cronograma",
      title: "Cronograma",
      content: "Fase 1 - Planejamento | 2 semanas\nFase 2 - Desenvolvimento | 6 semanas\nPrazo total: 8 semanas"
    },
    {
      key: "investimento",
      title: "Investimento",
      content: "Frontend: R$ 15.000\nBackend: R$ 20.000\nTotal: R$ 35.000"
    },
    {
      key: "pagamento",
      title: "Condições de Pagamento",
      content: "1ª parcela: R$ 11.667 na assinatura\n2ª parcela: R$ 11.667 após 30 dias\n3ª parcela: R$ 11.666 pós-homologação"
    },
    {
      key: "entregaveis",
      title: "Entregáveis",
      content: "- Protótipos no Figma\n- Código fonte no repositório\n- Sistema em produção"
    }
  ]

  const params = {
    empresa: "Easy Salon",
    para: "João Silva",
    projeto: "Sistema de Gestão para Salão",
    modeloTrabalho: "Escopo Fechado" as ProposalModelo,
    dataCriacao: new Date(2026, 2, 30).getTime(),
    sections: mockSections
  }

  it("deve mapear informações da capa corretamente", () => {
    const tokens = buildProposalTokens(params)

    expect(tokens.NOME_CLIENTE).toBe("Easy Salon")
    expect(tokens.CLIENTE_EMPRESA).toBe("João Silva")
    expect(tokens.TIPO_ESCOPO).toBe("Escopo Fechado")
    expect(tokens.NOME_EMPRESA).toBe("Wa Project")
    expect(tokens.TITULO_PROPOSTA).toBe("Proposta Comercial")
    expect(tokens.DIAS_VALIDADE).toBe("30")
  })

  it("deve mapear projeto e funcionalidades com HTML estruturado", () => {
    const tokens = buildProposalTokens(params)

    expect(tokens.SUBTITULO_PROJETO).toBe("Sistema de Gestão para Salão")
    expect(tokens.DESCRICAO_PROJETO).toContain("<p>Um sistema completo para salões de beleza.</p>")
    expect(tokens.LISTA_FUNCIONALIDADES).toContain('<div class="func-item">')
    expect(tokens.LISTA_FUNCIONALIDADES).toContain("Agendamento Online")
    expect(tokens.LISTA_FUNCIONALIDADES).toContain("Dashboard Administrativo")
  })

  it("deve mapear cronograma e investimento", () => {
    const tokens = buildProposalTokens(params)

    expect(tokens.LISTA_FASES).toContain('<div class="phase">')
    expect(tokens.LISTA_FASES).toContain("Planejamento – 2 semanas")
    expect(tokens.PRAZO_TOTAL).toContain("8 semanas")
    expect(tokens.VALOR_TOTAL).toContain("R$ 35.000")
    expect(tokens.VALOR_TOTAL).toContain('<p class="investment-total">')
  })

  it("deve mapear condições de pagamento estruturadas", () => {
    const tokens = buildProposalTokens(params)

    expect(tokens.CONDICOES_PAGAMENTO).toContain('<div class="payment-condition">')
    expect(tokens.CONDICOES_PAGAMENTO).toContain("R$ 11.667")
    expect(tokens.CONDICOES_PAGAMENTO).toContain("pós-homolog")
  })

  it("deve mapear entregáveis como lista HTML", () => {
    const tokens = buildProposalTokens(params)

    expect(tokens.LISTA_ENTREGAVEIS).toContain("<ul>")
    expect(tokens.LISTA_ENTREGAVEIS).toContain("Protótipos no Figma")
    expect(tokens.LISTA_ENTREGAVEIS).toContain("Sistema em produção")
  })

  it("deve usar fallbacks quando dados estão ausentes", () => {
    const emptyParams = {
      empresa: "Empresa Teste",
      para: undefined,
      projeto: undefined,
      modeloTrabalho: undefined,
      dataCriacao: Date.now(),
      sections: []
    }

    const tokens = buildProposalTokens(emptyParams)

    expect(tokens.CLIENTE_EMPRESA).toBe("Empresa Teste") // fallback para empresa
    expect(tokens.TIPO_ESCOPO).toBe("Escopo Fechado") // fallback default
    expect(tokens.VALOR_TOTAL).toContain("A definir")
    expect(tokens.LISTA_ENTREGAVEIS).toContain("Protótipos de Alta Fidelidade") // lista padrão
  })

  it("deve usar conteúdo dinâmico quando disponível", () => {
    const tokens = buildProposalTokens(params)

    expect(tokens.TITULO_SOBRE_EMPRESA).toBe("Sobre a Wa Project")
    expect(tokens.DESCRICAO_EMPRESA).toContain("Um sistema completo para salões de beleza") // conteúdo dinâmico
    expect(tokens.SECAO_SERVICOS).toContain("Desenvolvimento de Software")
    expect(tokens.LISTA_CLIENTES).toContain("Easy Salon")
    expect(tokens.CITACAO_ENCERRAMENTO).toContain("transformar sua visão em realidade digital")
  })
})