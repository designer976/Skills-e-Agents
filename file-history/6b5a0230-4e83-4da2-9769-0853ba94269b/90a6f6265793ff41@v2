// ── gerarCondicoesPagamentoHTML ────────────────────────────────────────────

describe("gerarCondicoesPagamentoHTML", () => {
  it("deve extrair 3 parcelas nomeadas com R$ para HTML estruturado", () => {
    const content = [
      "1ª parcela: R$ 6.667 na assinatura",
      "2ª parcela: R$ 6.667 após 30 dias",
      "3ª parcela: R$ 6.666 pós-homologação",
    ].join("\n")
    const result = gerarCondicoesPagamentoHTML(content)
    expect(result).toContain('<div class="payment-condition">')
    expect(result).toContain("<strong>1ª parcela:</strong> R$ 6.667")
    expect(result).toContain("<strong>2ª parcela:</strong> R$ 6.667")
    expect(result).toContain("<strong>3ª parcela:</strong> R$ 6.666")
    expect(result).toContain("pós-homolog")
  })

  it("deve usar fallback de valores em ordem quando não há labels de parcela", () => {
    const content = "Pagamento: R$ 10.000 na entrada e R$ 15.000 no final"
    const result = gerarCondicoesPagamentoHTML(content)
    expect(result).toContain("R$ 10.000")
    expect(result).toContain("R$ 15.000")
    expect(result).toContain("30 dias após a assinatura") // fallback
  })

  it("deve retornar 'A definir' para parcelas ausentes", () => {
    const result = gerarCondicoesPagamentoHTML("")
    expect(result).toContain("A definir")
    expect(result).toContain('<div class="payment-condition">')
  })
})

// ── extractValorTotal ──────────────────────────────────────────────────────

describe("extractValorTotal", () => {
  it("deve extrair valor da linha que contém 'Total' e 'R$' e envolver em HTML", () => {
    const content = "Frontend | 1 | R$ 15.000\nBackend | 1 | R$ 20.000\nTotal | | R$ 35.000"
    const result = extractValorTotal(content)
    expect(result).toContain('<p class="investment-total">')
    expect(result).toContain("Investimento total: R$ 35.000")
    expect(result).toContain("</p>")
  })

  it("deve extrair primeiro R$ quando não há linha de total", () => {
    const result = extractValorTotal("Investimento de R$ 50.000")
    expect(result).toContain("R$ 50.000")
    expect(result).toContain('<p class="investment-total">')
  })

  it("deve retornar HTML com 'A definir' quando não há valor", () => {
    const result = extractValorTotal("Sem valor definido")
    expect(result).toContain("A definir")
    expect(result).toContain('<p class="investment-total">')
  })
})

// ── extractSubtitulo ───────────────────────────────────────────────────────

describe("extractSubtitulo", () => {
