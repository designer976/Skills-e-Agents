// ── extractDescricao ───────────────────────────────────────────────────────

describe("extractDescricao", () => {
  it("deve retornar parágrafos HTML ignorando headings e bullets", () => {
    const content = "## Heading\n- bullet\nEste é o parágrafo real.\nOutro parágrafo aqui.\n- outro bullet"
    const result = extractDescricao(content)
    expect(result).toContain("<p>Este é o parágrafo real.</p>")
    expect(result).toContain("<p>Outro parágrafo aqui.</p>")
  })

  it("deve ignorar linhas que começam com *", () => {
    const content = "**bold line**\nParágrafo limpo."
    const result = extractDescricao(content)
    expect(result).toContain("<p>Parágrafo limpo.</p>")
    expect(result).not.toContain("bold line")
  })

  it("deve ignorar listas numeradas", () => {
    const content = "1. item da lista\nTexto descritivo aqui."
    const result = extractDescricao(content)
    expect(result).toContain("<p>Texto descritivo aqui.</p>")
  })

  it("deve retornar string vazia quando só há bullets e headings", () => {
    const content = "## Título\n- item1\n- item2"
    const result = extractDescricao(content)
    expect(result).toBe("")
  })
})

