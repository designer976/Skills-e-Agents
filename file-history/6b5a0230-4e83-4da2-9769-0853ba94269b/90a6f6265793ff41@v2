describe("extractPrazoTotal", () => {
  it("deve extrair prazo após palavra-chave 'Prazo total' e envolver em HTML", () => {
    const result = extractPrazoTotal("Prazo total estimado: 4,5 semanas")
    expect(result).toContain("<p><strong>Prazo total:</strong> 4,5 semanas</p>")
  })

  it("deve extrair duração simples no texto", () => {
    const result = extractPrazoTotal("O projeto dura 3 meses no total.")
