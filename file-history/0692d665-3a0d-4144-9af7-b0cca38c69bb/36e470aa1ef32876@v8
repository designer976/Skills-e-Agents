<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Proposta Comercial — {{NOME_CLIENTE}}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --blue: #0047ba;
            --text: #2e2e2e;
            --text-muted: #374151;
            --gray: #6B7280;
            --border: #E5E7EB;
            --page-padding: 56px;
            --footer-height: 120px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
            background: #D1D5DB;
            color: var(--text);
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
            font-size: 13px;
            line-height: 1.75;
            counter-reset: page;
        }

        /* ── DYNAMIC DOCUMENT CONTAINER ── */
        .document {
            max-width: 210mm;
            margin: 0 auto;
            padding: 24px 0;
            position: relative;
        }

        /* ── DYNAMIC CONTENT FLOW ── */
        .content-flow {
            width: 210mm;
            background: #fcfcfc;
            margin: 0 auto;
            position: relative;
            overflow: visible;
            box-shadow: 0 2px 12px rgba(0,0,0,0.12);
        }

        /* ── BACKGROUND FOR ALL PAGES ── */
        .content-flow::before {
            content: '';
            position: fixed;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 210mm;
            height: 100vh;
            background: url('fundo-center.png') center center no-repeat;
            background-size: 602px auto;
            opacity: 0.035;
            pointer-events: none;
            z-index: 0;
        }

        /* ── PAGE STRUCTURE ── */
        .page-content {
            position: relative;
            z-index: 1;
            padding: var(--page-padding) var(--page-padding) var(--footer-height);
            min-height: 297mm;
            page-break-after: always;
        }

        /* ── COVER PAGE SPECIFIC ── */
        .cover-page {
            page-break-after: always;
            position: relative;
        }

        .cover-page .page-content {
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
        }

        /* ── CONTINUOUS CONTENT PAGES ── */
        .flow-page {
            page-break-inside: auto;
        }

        .flow-page:last-of-type {
            page-break-after: auto;
        }

        /* ── HEADER (COVER PAGE) ── */
        .header {
            margin-bottom: 40px;
        }

        .logo {
            display: inline-block;
            margin-bottom: 64px;
        }
        .logo img {
            width: 100px;
            height: 37px;
            display: block;
        }

        .cover-title {
            margin-bottom: 40px;
        }
        .cover-title h1 {
            font-size: 32px;
            font-weight: 700;
            color: var(--blue);
            line-height: 1.2;
            margin-bottom: 0;
        }
        .cover-title h2 {
            font-size: 32px;
            font-weight: 700;
            color: var(--blue);
            margin-top: 0;
            margin-bottom: 40px;
        }

        .cover-info {
            margin-bottom: 40px;
        }
        .cover-info .cover-date {
            font-size: 14px;
            font-weight: 500;
            color: var(--text);
            margin-bottom: 8px;
        }
        .cover-info p {
            font-size: 14px;
            color: var(--text);
            margin-bottom: 4px;
        }
        .cover-info strong {
            font-weight: 600;
        }

        /* ── TYPOGRAPHY ── */
        h2 {
            font-size: 18px;
            font-weight: 700;
            color: var(--blue);
            margin: 32px 0 16px 0;
            page-break-after: avoid;
            break-after: avoid;
        }
        h2:first-of-type,
        .flow-page h2:first-child {
            margin-top: 0;
        }

        h3 {
            font-size: 13px;
            font-weight: 700;
            color: var(--text);
            margin: 24px 0 8px 0;
            page-break-after: avoid;
            break-after: avoid;
        }

        h4 {
            font-size: 13px;
            font-weight: 700;
            color: var(--text);
            margin: 16px 0 8px 0;
            page-break-after: avoid;
            break-after: avoid;
        }

        /* ── BODY TEXT WITH FLOW CONTROL ── */
        p {
            font-size: 13px;
            line-height: 1.75;
            color: var(--text-muted);
            margin-bottom: 12px;
            orphans: 3;
            widows: 3;
            break-inside: avoid-page;
        }

        strong {
            color: var(--text);
            font-weight: 700;
        }

        /* ── LISTS WITH FLOW CONTROL ── */
        ul, ol {
            margin-bottom: 16px;
            break-inside: avoid-page;
            page-break-inside: avoid;
        }

        ul {
            list-style: disc;
            padding-left: 20px;
        }

        ol {
            list-style: decimal;
            padding-left: 20px;
        }

        ul li, ol li {
            font-size: 13px;
            line-height: 1.75;
            color: var(--text-muted);
            margin-bottom: 4px;
            break-inside: avoid;
        }

        /* ── FUNCTIONAL SECTIONS WITH FLOW CONTROL ── */
        .func-item {
            margin-bottom: 16px;
            break-inside: avoid-page;
            page-break-inside: avoid;
        }
        .func-item strong {
            color: var(--text);
        }

        .phase {
            margin-bottom: 8px;
            break-inside: avoid;
            page-break-inside: avoid;
            font-size: 13px;
            line-height: 1.75;
            color: var(--text-muted);
        }
        .phase strong {
            color: var(--blue);
            font-weight: 700;
        }

        .team-role {
            margin-bottom: 20px;
            break-inside: avoid-page;
            page-break-inside: avoid;
        }
        .team-role h4 {
            color: var(--blue);
            margin-bottom: 8px;
        }

        .investment-total {
            font-size: 16px;
            font-weight: 700;
            color: var(--text);
            margin: 20px 0 16px 0;
        }

        .payment-condition {
            margin-bottom: 8px;
            font-size: 13px;
            line-height: 1.75;
            color: var(--text-muted);
        }

        /* ── SECTIONS FOR BETTER FLOW CONTROL ── */
        .content-section {
            break-inside: avoid-page;
            margin-bottom: 24px;
        }

        .content-section.allow-break {
            break-inside: auto;
        }

        /* ── CLOSING SECTION ── */
        .closing {
            margin-top: 40px;
            break-inside: avoid-page;
            page-break-inside: avoid;
        }
        .closing-quote {
            font-size: 16px;
            font-weight: 700;
            color: var(--blue);
            margin-bottom: 8px;
        }
        .company-info {
            margin-top: 24px;
        }
        .company-info p {
            font-size: 13px;
            color: var(--text-muted);
            margin-bottom: 4px;
        }
        .validity {
            margin-top: 16px;
            font-size: 12px;
            color: var(--text-muted);
        }

        /* ── FOOTER WITH AUTO PAGE NUMBERING ── */
        .footer {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 24px 0 0;
            z-index: 10;
            background: rgba(252, 252, 252, 0.95);
            backdrop-filter: blur(2px);
            counter-increment: page;
        }
        .footer-line {
            height: 2px;
            background: #e5e7eb80;
            margin-bottom: 24px;
        }
        .footer-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .footer-logo {
            display: inline-block;
        }
        .footer-logo img {
            width: 74px;
            height: 27px;
            display: block;
        }
        .pg-num::after {
            content: counter(page);
            font-size: 12.5px;
            color: var(--blue);
            font-weight: 700;
        }

        /* JavaScript override - quando JS estiver ativo, remove counter CSS */
        .js-pagination .pg-num::after {
            content: none;
        }

        /* ── PRINT STYLES ── */
        @media print {
            body {
                background: #fcfcfc;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }

            .document {
                padding: 0;
            }

            .content-flow {
                margin: 0;
                box-shadow: none;
            }

            .page-content {
                page-break-after: always;
                padding: 0 0 var(--footer-height) 0;
            }

            .flow-page:last-of-type .page-content {
                page-break-after: auto;
            }

            .footer {
                position: fixed;
                bottom: 0;
                left: 0;
                right: 0;
                background: #fcfcfc;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
                z-index: 999;
                padding: 24px 0 0;
            }

            /* Enhanced page break controls */
            h2, h3, h4 {
                page-break-after: avoid;
                break-after: avoid;
            }
            .func-item, .team-role, .phase, .content-section {
                page-break-inside: avoid;
                break-inside: avoid;
            }
            .closing {
                page-break-inside: avoid;
                break-inside: avoid;
            }
            ul, ol {
                page-break-inside: avoid;
                break-inside: avoid;
            }
            p {
                orphans: 3;
                widows: 3;
            }

            /* Background for print */
            .content-flow::before {
                position: fixed;
                background-attachment: fixed;
            }
        }

        @page {
            size: A4;
            margin: 56px;
            /* Remove headers/footers do navegador */
            @top-left { content: ""; }
            @top-center { content: ""; }
            @top-right { content: ""; }
            @bottom-left { content: ""; }
            @bottom-center { content: ""; }
            @bottom-right { content: ""; }
        }

        /* ── JAVASCRIPT FALLBACK STYLES ── */
        .js-page-break {
            page-break-before: always;
            break-before: page;
        }

        /* ── PREFERS REDUCED MOTION ── */
        @media (prefers-reduced-motion: reduce) {
            .content-flow::before {
                background-attachment: scroll;
            }
        }

        /* ── RESPONSIVE ADAPTATIONS ── */
        @media screen and (max-width: 220mm) {
            .document {
                padding: 12px;
            }

            .content-flow {
                width: 100%;
                max-width: 210mm;
            }

            :root {
                --page-padding: 24px;
            }
        }
    </style>
</head>
<body>

<div class="document">
    <div class="content-flow">

        <!-- COVER PAGE -->
        <div class="cover-page">
            <div class="page-content">
                <div class="header">
                    <div class="logo">
                        <img src="Logo completa.png" alt="{{NOME_EMPRESA}}">
                    </div>

                    <div class="cover-title">
                        <h1>{{TITULO_PROPOSTA}}</h1>
                        <h2>{{NOME_CLIENTE}}</h2>
                    </div>

                    <div class="cover-info">
                        <div class="cover-date">{{DATA_PROPOSTA}} | Válido por {{DIAS_VALIDADE}} dias</div>
                        <p><strong>Para:</strong> {{CLIENTE_EMPRESA}}</p>
                        <p><strong>Tipo:</strong> {{TIPO_ESCOPO}}</p>
                        {{INFORMACOES_ADICIONAIS_CAPA}}
                    </div>
                </div>

                <!-- CONTEÚDO INICIAL DA CAPA (se houver) -->
                <div class="content-section allow-break">
                    {{CONTEUDO_INICIAL_CAPA}}
                </div>
            </div>
        </div>

        <!-- CONTEÚDO CONTÍNUO -->
        <div class="flow-page">
            <div class="page-content">

                <!-- SOBRE A EMPRESA -->
                <div class="content-section">
                    <h2>{{TITULO_SOBRE_EMPRESA}}</h2>
                    <p>{{DESCRICAO_EMPRESA}}</p>

                    {{SECAO_SERVICOS}}

                    <h2>{{TITULO_CLIENTES}}</h2>
                    {{LISTA_CLIENTES}}

                    {{INFORMACOES_ADICIONAIS_EMPRESA}}
                </div>

                <!-- SOBRE O PROJETO -->
                <div class="content-section allow-break">
                    <h2>{{TITULO_PROJETO}}</h2>
                    <h3>{{SUBTITULO_PROJETO}}</h3>

                    {{DESCRICAO_PROJETO}}
                </div>

                <!-- FUNCIONALIDADES -->
                <div class="content-section allow-break">
                    <h2>{{TITULO_FUNCIONALIDADES}}</h2>
                    {{LISTA_FUNCIONALIDADES}}
                    {{FUNCIONALIDADES_ADICIONAIS}}
                </div>

                <!-- INTEGRAÇÕES -->
                <div class="content-section">
                    <h2>{{TITULO_INTEGRACOES}}</h2>
                    {{DESCRICAO_INTEGRACOES}}
                </div>

                <!-- MODELO DE TRABALHO -->
                <div class="content-section allow-break">
                    <h2>{{TITULO_MODELO_TRABALHO}}</h2>
                    {{DESCRICAO_MODELO}}

                    <h3>{{TITULO_FASES}}</h3>
                    {{LISTA_FASES}}
                </div>

                <!-- EQUIPE -->
                <div class="content-section allow-break">
                    <h2>{{TITULO_EQUIPE}}</h2>
                    {{DESCRICAO_EQUIPE}}
                    {{LISTA_MEMBROS_EQUIPE}}
                </div>

                <!-- CRONOGRAMA -->
                <div class="content-section">
                    <h2>{{TITULO_CRONOGRAMA}}</h2>
                    {{PRAZO_TOTAL}}
                    {{CRONOGRAMA_DETALHADO}}
                    {{OBSERVACOES_CRONOGRAMA}}
                </div>

                <!-- INVESTIMENTO -->
                <div class="content-section">
                    <h2>{{TITULO_INVESTIMENTO}}</h2>
                    {{VALOR_TOTAL}}

                    <h3>{{TITULO_CONDICOES_PAGAMENTO}}</h3>
                    {{CONDICOES_PAGAMENTO}}
                </div>

                <!-- ENTREGÁVEIS -->
                <div class="content-section">
                    <h2>{{TITULO_ENTREGAVEIS}}</h2>
                    {{LISTA_ENTREGAVEIS}}
                </div>

                <!-- PRÓXIMOS PASSOS -->
                <div class="content-section">
                    <h2>{{TITULO_PROXIMOS_PASSOS}}</h2>
                    {{LISTA_PROXIMOS_PASSOS}}
                    {{MENSAGEM_FINAL_PASSOS}}
                </div>

                <!-- ENCERRAMENTO -->
                <div class="closing">
                    {{CITACAO_ENCERRAMENTO}}

                    <div class="company-info">
                        {{INFORMACOES_EMPRESA_COMPLETA}}
                    </div>

                    <div class="validity">
                        {{TEXTO_VALIDADE}}
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>

<!-- FOOTER UNIVERSAL -->
<div class="footer">
    <div class="footer-line"></div>
    <div class="footer-row">
        <div class="footer-logo">
            <img src="Logo completa.png" alt="{{NOME_EMPRESA}}">
        </div>
        <span class="pg-num"></span>
    </div>
</div>

<!-- SCRIPT PARA CONTROLE DINÂMICO DE PÁGINAS (OPCIONAL) -->
<script>
// Sistema de paginação JavaScript - substitui contadores CSS que não funcionam no preview
document.addEventListener('DOMContentLoaded', function() {
    // Função principal para numerar páginas
    function setupPageNumbers() {
        // Aguarda fontes e imagens carregarem
        setTimeout(function() {
            calculateAndSetPageNumbers();
        }, 200);

        // Recalcula na mudança de tamanho
        window.addEventListener('resize', function() {
            setTimeout(calculateAndSetPageNumbers, 100);
        });
    }

    function calculateAndSetPageNumbers() {
        const pageHeight = window.innerHeight; // Altura da janela/página
        const footerHeight = 120; // Altura estimada do footer
        const availableHeight = pageHeight - footerHeight;

        // Encontra todas as seções de conteúdo
        const sections = document.querySelectorAll('.content-section');
        const pageBreaks = document.querySelectorAll('.cover-page, .flow-page');

        let pageCount = 1;
        let currentHeight = 0;

        // Método 1: Conta com base nas quebras de página existentes
        if (pageBreaks.length > 0) {
            pageCount = pageBreaks.length;
        } else {
            // Método 2: Calcula com base na altura do conteúdo
            const totalContent = document.querySelector('.content-flow');
            if (totalContent) {
                const totalHeight = totalContent.offsetHeight;
                pageCount = Math.ceil(totalHeight / availableHeight) || 1;
            }
        }

        // Método 3: Detecção mais precisa usando elementos page-break
        const pageBreakElements = document.querySelectorAll('[style*="page-break"], .js-page-break, .cover-page, .flow-page');
        if (pageBreakElements.length > pageCount) {
            pageCount = pageBreakElements.length;
        }

        // Aplica numeração em todos os elementos .pg-num
        applyPageNumbering(pageCount);
    }

    function applyPageNumbering(totalPages) {
        // Força atualização imediata do elemento .pg-num
        const pageNumElements = document.querySelectorAll('.pg-num');

        pageNumElements.forEach(function(element) {
            // Remove o ::after do CSS e substitui por conteúdo JavaScript
            element.innerHTML = '1'; // Sempre começa com página 1
            element.style.fontSize = '12.5px';
            element.style.color = 'var(--blue)';
            element.style.fontWeight = '700';
        });

        // Sistema de incremento para múltiplas páginas
        setTimeout(function() {
            attemptMultiPageNumbering(totalPages);
        }, 100);
    }

    function attemptMultiPageNumbering(totalPages) {
        // Cria um sistema de contadores manuais
        let currentPageNumber = 1;

        // Intercepta eventos de quebra de página
        const observer = new MutationObserver(function(mutations) {
            mutations.forEach(function(mutation) {
                if (mutation.type === 'childList') {
                    updatePageNumbers();
                }
            });
        });

        // Observa mudanças no DOM
        observer.observe(document.body, {
            childList: true,
            subtree: true
        });

        // Força atualização inicial
        updatePageNumbers();
    }

    function updatePageNumbers() {
        // Estratégia simples: conta elementos com quebra de página
        const pageBreakElements = document.querySelectorAll('.cover-page, .flow-page, .js-page-break');
        const pageCount = Math.max(pageBreakElements.length, 2);

        // Atualiza todos os .pg-num encontrados
        const pageNumElements = document.querySelectorAll('.pg-num');
        pageNumElements.forEach(function(element, index) {
            // Para o primeiro elemento, mantém "1"
            // Para elementos subsequentes (se houver), incrementa
            const pageNum = index + 1;
            element.textContent = Math.min(pageNum, pageCount).toString();
        });

        // Se estamos em modo de impressão/preview, cria numeração por página
        if (window.matchMedia('print').matches || isInPrintPreview()) {
            createSequentialPageNumbers(pageCount);
        }
    }

    function isInPrintPreview() {
        // Detecta se estamos em preview de impressão
        return window.location.href.includes('print-preview') ||
               document.body.classList.contains('print-preview') ||
               window.matchMedia('print').matches;
    }

    function createSequentialPageNumbers(totalPages) {
        // Remove numerações anteriores
        const oldNums = document.querySelectorAll('.sequential-page-num');
        oldNums.forEach(el => el.remove());

        // Cria numeração sequencial
        for (let i = 1; i <= totalPages; i++) {
            const numElement = document.createElement('span');
            numElement.className = 'sequential-page-num';
            numElement.textContent = i.toString();
            numElement.style.cssText = `
                position: absolute;
                bottom: 10px;
                right: 10px;
                font-size: 12.5px;
                color: var(--blue);
                font-weight: 700;
                z-index: 9999;
                page-break-inside: avoid;
            `;

            // Anexa ao final do body para cada página
            document.body.appendChild(numElement);
        }
    }

    // Função para recriar numeração em contexto de impressão
    function handlePrintMode() {
        // Detecta quando entra em modo de impressão
        if (window.matchMedia) {
            const mediaQueryList = window.matchMedia('print');
            mediaQueryList.addListener(function(mq) {
                if (mq.matches) {
                    // Entrando em modo impressão
                    setTimeout(function() {
                        createMultiplePageFooters();
                    }, 50);
                }
            });
        }

        // Detecta preview de impressão via beforeprint
        window.addEventListener('beforeprint', function() {
            setTimeout(function() {
                createMultiplePageFooters();
            }, 10);
        });
    }

    function createMultiplePageFooters() {
        // Abordagem simplificada: cria vários elementos de página numerados
        const pageElements = document.querySelectorAll('.cover-page, .flow-page');
        let pageCount = Math.max(pageElements.length, 2); // Mínimo 2 páginas

        // Se não encontrou elementos de página, estima pela altura
        if (pageElements.length === 0) {
            const totalHeight = document.documentElement.scrollHeight;
            const pageHeight = Math.max(window.innerHeight, 1056); // Altura da página
            pageCount = Math.ceil(totalHeight / pageHeight);
        }

        // Cria elementos de numeração para cada página
        const footer = document.querySelector('.footer');
        if (!footer) return;

        // Remove numerações antigas
        const oldNumbers = document.querySelectorAll('.page-number-js');
        oldNumbers.forEach(el => el.remove());

        // Cria numeração para cada página
        for (let i = 1; i <= pageCount; i++) {
            const pageNumDiv = document.createElement('div');
            pageNumDiv.className = 'page-number-js';
            pageNumDiv.textContent = i.toString();
            pageNumDiv.style.cssText = `
                position: fixed;
                bottom: 32px;
                right: 56px;
                font-size: 12.5px;
                color: var(--blue);
                font-weight: 700;
                z-index: 1000;
                page: page-${i};
            `;
            document.body.appendChild(pageNumDiv);
        }

        // Força atualização do layout
        setTimeout(() => {
            window.dispatchEvent(new Event('resize'));
        }, 10);
    }

    // Função para otimizar quebras de página (mantida do sistema original)
    function optimizePageBreaks() {
        const sections = document.querySelectorAll('.content-section');
        const pageHeight = 297; // mm - altura da página A4
        const footerHeight = 120; // mm
        const availableHeight = pageHeight - footerHeight;

        let currentHeight = 0;

        sections.forEach(function(section) {
            const sectionHeight = section.offsetHeight * 0.352778; // px to mm conversion

            // Se a seção não cabe na página atual, força quebra
            if (currentHeight + sectionHeight > availableHeight) {
                section.classList.add('js-page-break');
                currentHeight = sectionHeight;
            } else {
                currentHeight += sectionHeight;
            }
        });
    }

    // Inicialização
    setupPageNumbers();
    handlePrintMode();

    // Marca que JavaScript está ativo para override do CSS
    document.body.classList.add('js-pagination');

    // Executar otimização se solicitado
    if (window.location.search.includes('optimize=true')) {
        setTimeout(optimizePageBreaks, 100);
    }
});

// Função para exportar variáveis utilizadas (para debugging)
function getTemplateVariables() {
    const content = document.documentElement.outerHTML;
    const variables = content.match(/\{\{[A-Z_]+\}\}/g) || [];
    return [...new Set(variables)].sort();
}
</script>

