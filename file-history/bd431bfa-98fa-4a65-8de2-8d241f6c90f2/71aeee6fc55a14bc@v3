<!-- SCRIPT PARA CONTROLE DINÂMICO DE PÁGINAS (OPCIONAL) -->
<script>
// Sistema avançado para controle dinâmico de quebras de página
// Otimizado para evitar cortes de conteúdo e melhor distribuição
document.addEventListener('DOMContentLoaded', function() {
    // Função para ajustar quebras de página dinamicamente
    function optimizePageBreaks() {
        const sections = document.querySelectorAll('.content-section');
        const blocks = document.querySelectorAll('.content-block');
        const pageHeight = 297; // mm - altura da página A4
        const footerHeight = 120; // mm
        const availableHeight = pageHeight - footerHeight;

        let currentHeight = 0;

        // Otimizar seções principais
        sections.forEach(function(section) {
            const sectionHeight = section.offsetHeight * 0.352778; // px to mm conversion

            // Se a seção não cabe na página atual, força quebra
            if (currentHeight + sectionHeight > availableHeight) {
                section.classList.add('page-break-before');
                currentHeight = sectionHeight;
            } else {
                currentHeight += sectionHeight;
            }
        });

        // Otimizar blocos de conteúdo para evitar quebras orphan/widow
        blocks.forEach(function(block) {
            const blockHeight = block.offsetHeight * 0.352778;

            // Blocos muito pequenos (< 20mm) devem ficar juntos com o próximo
            if (blockHeight < 20) {
                block.classList.add('avoid-page-break');
            }

            // Blocos de títulos seguidos de conteúdo
            const nextBlock = block.nextElementSibling;
            if (block.querySelector('h2, h3, h4') && nextBlock) {
                const combinedHeight = blockHeight + (nextBlock.offsetHeight * 0.352778);
                if (combinedHeight < 60) { // Manter título com pelo menos um pouco de conteúdo
                    block.classList.add('avoid-page-break');
                    nextBlock.classList.add('avoid-page-break');
                }
            }
        });
    }

    // Função para detectar elementos órfãos/viúvos
    function preventOrphansWidows() {
        const paragraphs = document.querySelectorAll('p');
        const lists = document.querySelectorAll('ul, ol');

        paragraphs.forEach(function(p) {
            if (p.offsetHeight > 60) { // Parágrafos altos
                p.style.orphans = '4';
                p.style.widows = '4';
            }
        });

        lists.forEach(function(list) {
            const items = list.querySelectorAll('li');
            if (items.length > 3) { // Listas longas
                list.classList.add('avoid-page-break');
            }
        });
    }

    // Executar otimizações
    if (window.location.search.includes('optimize=true') ||
        document.documentElement.classList.contains('print-optimize')) {
        setTimeout(function() {
            optimizePageBreaks();
            preventOrphansWidows();
        }, 100);
    }

    // Otimização automática para impressão
    window.addEventListener('beforeprint', function() {
        setTimeout(function() {
            optimizePageBreaks();
            preventOrphansWidows();
        }, 50);
    });
});

// Função para exportar variáveis utilizadas (para debugging)
function getTemplateVariables() {
    const content = document.documentElement.outerHTML;
    const variables = content.match(/\{\{[A-Z_]+\}\}/g) || [];
    return [...new Set(variables)].sort();
}
</script>

