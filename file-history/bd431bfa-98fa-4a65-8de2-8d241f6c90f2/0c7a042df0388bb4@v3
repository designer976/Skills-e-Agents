<script>
// Sistema para fluxo contínuo de conteúdo com padding especial para páginas 2+
document.addEventListener('DOMContentLoaded', function() {
    // Função para permitir fluxo natural do conteúdo
    function enableContinuousFlow() {
        const sections = document.querySelectorAll('.content-section');
        const pageContent = document.querySelector('.page-content');
        const flowPages = document.querySelectorAll('.flow-page');

        // Remove qualquer quebra forçada de seções anteriores
        sections.forEach(function(section) {
            section.classList.remove('js-page-break');
            section.style.pageBreakBefore = 'auto';
            section.style.breakBefore = 'auto';
            section.style.pageBreakInside = 'auto';
            section.style.breakInside = 'auto';
        });

        // Permite que o conteúdo flua naturalmente
        if (pageContent) {
            pageContent.style.pageBreakAfter = 'auto';
            pageContent.style.breakAfter = 'auto';
        }

        // Garante padding-top nas páginas de fluxo (2+)
        flowPages.forEach(function(page) {
            const content = page.querySelector('.page-content');
            if (content) {
                content.style.paddingTop = '32px';
            }
        });

        // Remove quebras forçadas de elementos funcionais
        const functionalItems = document.querySelectorAll('.func-item, .team-role, .phase');
        functionalItems.forEach(function(item) {
            item.style.pageBreakInside = 'auto';
            item.style.breakInside = 'auto';
        });

        // Permite que listas fluam naturalmente
        const lists = document.querySelectorAll('ul, ol');
        lists.forEach(function(list) {
            list.style.pageBreakInside = 'auto';
            list.style.breakInside = 'auto';
        });
    }

    // Aplicar fluxo contínuo automaticamente
    setTimeout(enableContinuousFlow, 100);

    // Reforçar ao imprimir
    window.addEventListener('beforeprint', enableContinuousFlow);
});
</script>

</body>
</html>