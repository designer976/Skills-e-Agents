import { useState } from 'react';
import { Dialog, DialogContent, DialogHeader, DialogTitle } from '@/components/ui/dialog';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { Calendar } from '@/components/ui/calendar';
import { Popover, PopoverContent, PopoverTrigger } from '@/components/ui/popover';
import { IconCalendar as CalendarIcon, IconClock as Clock, IconPhone as Phone, IconMail as Mail, IconUser as User } from "@tabler/icons-react";
import { SolicitacaoItem } from '@/types/solicitacoes';
import { format } from 'date-fns';
import { ptBR } from 'date-fns/locale';
import { cn } from '@/lib/utils';
import { getUserDisplayName } from '@/utils/userHelpers';

interface SolicitacaoModalProps {
  isOpen: boolean;
  onClose: () => void;
  solicitacao: SolicitacaoItem | null;
  onSave: (solicitacao: SolicitacaoItem) => void;
}

const mockProfessionals = [
  { id: '1', name: 'Carla Mendes' },
  { id: '2', name: 'Roberto Silva' },
  { id: '3', name: 'Ana Paula' },
  { id: '4', name: 'João Costa' },
];

const timeSlots = [
  '08:00', '08:30', '09:00', '09:30', '10:00', '10:30',
  '11:00', '11:30', '14:00', '14:30', '15:00', '15:30',
  '16:00', '16:30', '17:00', '17:30'
];

export function SolicitacaoModal({ isOpen, onClose, solicitacao, onSave }: SolicitacaoModalProps) {
  const [assignedProfessionalId, setAssignedProfessionalId] = useState(solicitacao?.assignedProfessionalId || '');
  const [finalDate, setFinalDate] = useState<Date | undefined>(solicitacao?.finalDate || undefined);
  const [finalTime, setFinalTime] = useState(solicitacao?.finalTime || '');

  if (!solicitacao) return null;

  const handleSave = () => {
    const professional = mockProfessionals.find(p => p.id === assignedProfessionalId);
    
    const updatedSolicitacao: SolicitacaoItem = {
      ...solicitacao,
      assignedProfessionalId: assignedProfessionalId || undefined,
      assignedProfessionalName: professional?.name || undefined,
      finalDate: finalDate || undefined,
      finalTime: finalTime || undefined,
    };

    onSave(updatedSolicitacao);
    onClose();
  };

  const isReadOnly = solicitacao.status === 'scheduled';

  return (
    <Dialog open={isOpen} onOpenChange={onClose}>
      <DialogContent className="w-[95vw] md:max-w-2xl max-h-[90vh] md:max-h-[85vh] p-0 gap-0 rounded-xl md:rounded-lg border-none shadow-2xl overflow-hidden flex flex-col">
        <DialogHeader className="sticky top-0 z-10 bg-background px-4 md:px-6 pt-4 pb-3 border-b shrink-0">
          <DialogTitle className="text-xl font-semibold">
            Detalhes da Solicitação - {solicitacao.customerName}
          </DialogTitle>
        </DialogHeader>

        <div className="flex-1 overflow-y-auto px-4 md:px-6 py-4 custom-scrollbar">
          <div className="space-y-6">
            {/* Informações do Cliente */}
            <div className="border rounded-lg p-4 bg-muted">
              <h3 className="font-semibold mb-3 flex items-center gap-2">
                <User className="h-4 w-4" />
                Dados do Cliente
              </h3>
              
              <div className="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                <div className="flex items-center gap-2">
                  <User className="h-4 w-4 text-muted-foreground" />
                  <span>{solicitacao.customerName}</span>
                </div>
                
                <div className="flex items-center gap-2">
                  <Phone className="h-4 w-4 text-muted-foreground" />
                  <span>{solicitacao.customerPhone}</span>
                </div>
                
                {solicitacao.customerEmail && (
                  <div className="flex items-center gap-2">
                    <Mail className="h-4 w-4 text-muted-foreground" />
                    <span>{solicitacao.customerEmail}</span>
                  </div>
                )}
              </div>
            </div>

            {/* Informações do Serviço */}
            <div className="border rounded-lg p-4 bg-muted">
              <h3 className="font-semibold mb-3">Serviço Solicitado</h3>
              
              <div className="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                <div>
                  <Label className="text-xs text-muted-foreground">Serviço</Label>
                  <p className="font-medium">{solicitacao.serviceName}</p>
                </div>
                
                <div>
                  <Label className="text-xs text-muted-foreground">Categoria</Label>
                  <p>{solicitacao.serviceCategory}</p>
                </div>
                
                <div>
                  <Label className="text-xs text-muted-foreground">Duração</Label>
                  <p>{solicitacao.duration} minutos</p>
                </div>
                
                <div>
                  <Label className="text-xs text-muted-foreground">Valor</Label>
                  <p className="font-semibold salon-primary">R$ {solicitacao.price.toFixed(2)}</p>
                </div>
              </div>

              {solicitacao.observations && (
                <div className="mt-4">
                  <Label className="text-xs text-muted-foreground">Observações</Label>
                  <p className="text-sm italic">"{solicitacao.observations}"</p>
                </div>
              )}
            </div>

            {/* Preferências do Cliente */}
            <div className="border rounded-lg p-4 bg-secondary">
              <h3 className="font-semibold mb-3">Preferências Informadas</h3>
              
              <div className="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                <div className="flex items-center gap-2">
                  <CalendarIcon className="h-4 w-4 text-muted-foreground" />
                  <span>
                    {format(solicitacao.preferredDate, "dd/MM/yyyy", { locale: ptBR })}
                  </span>
                </div>
                
                <div className="flex items-center gap-2">
                  <Clock className="h-4 w-4 text-muted-foreground" />
                  <span>{solicitacao.preferredTime}</span>
                </div>
              </div>
            </div>

            {/* Agendamento Final - só aparece se não for status aberto */}
            {solicitacao.status !== 'open' && (
              <div className="border rounded-lg p-4 bg-green-50">
                <h3 className="font-semibold mb-3">Agendamento Definido</h3>
                
                <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div>
                    <Label>Profissional Responsável</Label>
                    <Select 
                      value={assignedProfessionalId} 
                      onValueChange={setAssignedProfessionalId}
                      disabled={isReadOnly}
                    >
                      <SelectTrigger className="text-base md:text-sm sm:h-9">
                        <SelectValue placeholder="Selecione um profissional" />
                      </SelectTrigger>
                      <SelectContent>
                        {mockProfessionals.map((professional) => (
                          <SelectItem key={professional.id} value={professional.id}>
                            {getUserDisplayName(professional)}
                          </SelectItem>
                        ))}
                      </SelectContent>
                    </Select>
                  </div>

                  <div>
                    <Label>Data Final</Label>
                    <Popover>
                      <PopoverTrigger asChild>
                        <Button
                          variant="outline"
                          className={cn(
                            "w-full justify-start text-left font-normal text-base md:text-sm sm:h-9",
                            !finalDate && "text-muted-foreground"
                          )}
                          disabled={isReadOnly}
                        >
                          <CalendarIcon className="mr-2 h-4 w-4" />
                          {finalDate ? (
                            format(finalDate, "dd/MM/yyyy", { locale: ptBR })
                          ) : (
                            "Selecione uma data"
                          )}
                        </Button>
                      </PopoverTrigger>
                      <PopoverContent className="w-auto p-0" align="start">
                        <Calendar
                          mode="single"
                          selected={finalDate}
                          onSelect={setFinalDate}
                          disabled={(date) => date < new Date()}
                          locale={ptBR}
                        />
                      </PopoverContent>
                    </Popover>
                  </div>

                  <div>
                    <Label>Horário Final</Label>
                    <Select 
                      value={finalTime} 
                      onValueChange={setFinalTime}
                      disabled={isReadOnly}
                    >
                      <SelectTrigger className="text-base md:text-sm sm:h-9">
                        <SelectValue placeholder="Selecione um horário" />
                      </SelectTrigger>
                      <SelectContent>
                        {timeSlots.map((time) => (
                          <SelectItem key={time} value={time}>
                            {time}
                          </SelectItem>
                        ))}
                      </SelectContent>
                    </Select>
                  </div>
                </div>
              </div>
            )}
          </div>
        </div>

        <div className="sticky bottom-0 z-10 bg-background px-4 md:px-6 pt-3 pb-4 border-t shrink-0 flex flex-col-reverse sm:flex-row sm:justify-end gap-2 sm:gap-3">
          <Button variant="outline" onClick={onClose} className="w-full sm:w-auto min-h-[44px]">
            {isReadOnly ? 'Fechar' : 'Cancelar'}
          </Button>
          
          {!isReadOnly && (
            <Button 
              onClick={handleSave}
              className="w-full sm:w-auto min-h-[44px] salon-button-primary"
              disabled={!assignedProfessionalId || !finalDate || !finalTime}
            >
              Salvar Alterações
            </Button>
          )}
        </div>
      </DialogContent>
    </Dialog>
  );
}