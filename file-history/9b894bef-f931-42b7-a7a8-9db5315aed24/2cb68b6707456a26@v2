import { motion } from 'framer-motion';
import { format } from 'date-fns';
import { ptBR } from 'date-fns/locale';
import { Clock, User as UserIcon } from 'lucide-react';
import { CalendarEvent } from '@/components/ui/EasyCalendar';
import { cn } from '@/lib/utils';

interface EventCardProps {
    event: CalendarEvent;
    onClick: () => void;
    index?: number;
    isCompact?: boolean;
    isHighlighted?: boolean;
}

/**
 * Card de evento com design minimalista
 * - Barra lateral colorida por status
 * - Modo compacto para slots pequenos
 * - Animação de entrada escalonada
 * - Sombras suaves
 */
export function EventCard({ event, onClick, index = 0, isCompact = false, isHighlighted = false }: EventCardProps) {
    const startTime = new Date(event.start);
    const endTime = new Date(event.end);

    const duration = (endTime.getTime() - startTime.getTime()) / (1000 * 60);
    const isSmallSlot = duration <= 15;

    // Cores por status
    const getStatusColor = () => {
        if (event.variant === 'ausencia') return 'bg-gray-400';

        switch (event.status) {
            case 'Pago':
                return 'bg-green-500';
            case 'Atendendo':
                return 'bg-yellow-500';
            case 'Cancelado':
                return 'bg-red-500';
            default:
                return 'bg-primary';
        }
    };

    const getBackgroundColor = () => {
        if (event.variant === 'ausencia') return 'bg-gray-50';

        switch (event.status) {
            case 'Pago':
                return 'bg-green-50';
            case 'Atendendo':
                return 'bg-yellow-50';
            case 'Cancelado':
                return 'bg-red-50';
            default:
                return 'bg-primary/10';
        }
    };

    return (
        <motion.button
            initial={{ opacity: 0, scale: 0.95, y: 10 }}
            animate={{ opacity: 1, scale: 1, y: 0 }}
            transition={{
                delay: index * 0.03,
                type: "spring",
                stiffness: 300,
                damping: 25
            }}
            whileTap={{ scale: 0.98 }}
            onClick={onClick}
            className={cn(
                "w-full text-left rounded-xl shadow-sm hover:shadow-md transition-all overflow-hidden relative",
                getBackgroundColor(),
                isHighlighted && "ring-2 ring-primary ring-offset-1"
            )}
        >
            {/* Ping overlay — visível apenas quando highlighted */}
            {isHighlighted && (
                <span className="absolute inset-0 rounded-xl ring-2 ring-primary animate-ping opacity-75 pointer-events-none" />
            )}

            <div className="flex h-full relative z-10">
                {/* Barra lateral colorida */}
                <div className={cn("w-1", getStatusColor())} />

                {/* Conteúdo */}
                <div className="flex-1 p-3">
                    {isSmallSlot || isCompact ? (
                        // Modo compacto (≤15min)
                        <div className="flex items-center gap-2">
                            <UserIcon className="h-3.5 w-3.5 text-muted-foreground flex-shrink-0" />
                            <span className="text-sm font-semibold text-foreground truncate">
                                {event.clientName || 'Cliente'}
                            </span>
                        </div>
                    ) : (
                        // Modo normal
                        <>
                            {/* Horário */}
                            <div className="flex items-center gap-1.5 text-xs text-muted-foreground mb-2">
                                <Clock className="h-3.5 w-3.5" />
                                <span className="font-medium">
                                    {format(startTime, 'HH:mm')} - {format(endTime, 'HH:mm')}
                                </span>
                            </div>

                            {/* Cliente */}
                            {event.variant !== 'ausencia' && (
                                <>
                                    <div className="flex items-center gap-1.5 mb-1">
                                        <UserIcon className="h-3.5 w-3.5 text-muted-foreground flex-shrink-0" />
                                        <span className="text-sm font-semibold text-foreground truncate">
                                            {event.clientName || 'Cliente não informado'}
                                        </span>
                                    </div>

                                    {/* Serviço */}
                                    <div className="text-xs text-muted-foreground truncate ml-5">
                                        {event.serviceName || 'Serviço não informado'}
                                    </div>
                                </>
                            )}

                            {/* Ausência */}
                            {event.variant === 'ausencia' && (
                                <div className="text-sm font-medium text-foreground">
                                    Ausência
                                </div>
                            )}
                        </>
                    )}
                </div>
            </div>
        </motion.button>
    );
}
