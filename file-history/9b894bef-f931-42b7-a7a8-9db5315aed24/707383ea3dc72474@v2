import { zodResolver } from "@hookform/resolvers/zod";
import { Loader2 } from "lucide-react";
import { useEffect, useState } from "react";
import { useForm } from "react-hook-form";
import { Link, useNavigate } from "react-router-dom";
import * as z from "zod";

import { AuthLayout } from "@/components/AuthLayout";
import { PasswordRequirements } from "@/components/PasswordRequirements";
import { Button } from "@/components/ui/button";

import {
  Form,
  FormControl,
  FormField,
  FormItem,
  FormLabel,
} from "@/components/ui/form";
import { Input } from "@/components/ui/input";
import { PasswordInput } from "@/components/ui/password-input";
import { useToast } from "@/components/ui/use-toast";
import { useAuth } from "@/contexts/AuthContext";
import { analytics } from "@/lib/analytics";
import { pushSignUpEvent } from "@/lib/dataLayer";
import { cn } from "@/lib/utils";
import { getRegisterErrorMessage } from "@/utils/error";
import { formatCPF, formatPhone } from "@/utils/formatters";
import { validateCPF, validatePassword } from "@/utils/validation";

// Schema de validação
const registerSchema = z
  .object({
    userName: z.string().min(3, "O nome deve ter pelo menos 3 caracteres"),
    whatsapp: z
      .string()
      .min(1, "WhatsApp é obrigatório")
      .transform((val) => val.replace(/\D/g, ""))
      .refine((val) => val.length >= 11, "WhatsApp incompleto"),
    email: z.string().email("Formato de e-mail inválido"),
    cpf: z
      .string()
      .transform((val) => val.replace(/\D/g, ""))
      .refine((val) => !val || validateCPF(val), "CPF inválido")
      .optional(),
    tenantName: z
      .string()
      .min(3, "O nome do estabelecimento deve ter pelo menos 3 caracteres"),
    password: z
      .string()
      .min(8, "A senha deve ter pelo menos 8 caracteres")
      .refine((val) => validatePassword(val).isValid, "A senha não atende aos requisitos de segurança"),
    confirmPassword: z.string(),
  })
  .refine((data) => data.password === data.confirmPassword, {
    message: "As senhas não coincidem",
    path: ["confirmPassword"],
  });

type RegisterFormValues = z.infer<typeof registerSchema>;

export default function Register() {
  const [isLoading, setIsLoading] = useState(false);
  const navigate = useNavigate();
  const { register } = useAuth();
  const { toast } = useToast();

  useEffect(() => {
    analytics.trackEvent('registration_page_viewed', {});
  }, []);

  const form = useForm<RegisterFormValues>({
    resolver: zodResolver(registerSchema),
    defaultValues: {
      userName: "",
      email: "",
      whatsapp: "",
      cpf: "",
      tenantName: "",
      password: "",
      confirmPassword: "",
    },
    mode: "onChange",
  });

  const onSubmit = async (data: RegisterFormValues) => {
    setIsLoading(true);
    try {
      const registeredUser = await register(
        data.userName,
        data.email,
        data.password,
        data.confirmPassword,
        { name: data.tenantName },
        data.whatsapp,
        data.cpf || undefined
      );

      pushSignUpEvent({
        email: data.email,
        phone: data.whatsapp,
        userName: data.userName,
      });
      analytics.trackEvent('registration_completed', {
        hasWhatsapp: !!data.whatsapp,
        hasCpf: !!data.cpf,
      });

      toast({
        title: "Conta criada com sucesso!",
        description: "Bem-vindo ao Easy Salon.",
      });

      navigate("/onboarding");

    } catch (error: any) {
      console.error(error);
      const errorMessage = getRegisterErrorMessage(error);
      analytics.trackEvent('registration_failed', { error_type: errorMessage });
      toast({
        title: "Erro ao criar conta",
        description: errorMessage,
        variant: "destructive",
      });
    } finally {
      setIsLoading(false);
    }
  };

  const password = form.watch("password");
  const confirmPassword = form.watch("confirmPassword");

  return (
    <AuthLayout maxWidth="xl" imagePosition="center top">
      <div className="w-full">
        <div className="text-center mb-4">
          <h1 className="text-2xl font-bold text-foreground">Comece Grátis</h1>
          <p className="text-muted-foreground text-sm">
            Crie sua conta e configure seu salão
          </p>
        </div>

        <div className="bg-card border border-border rounded-3xl">
          <div className="p-4">
            <Form {...form}>
              <form
                onSubmit={form.handleSubmit(onSubmit)}
                className="space-y-4"
              >
                {/* Dados Pessoais - Nome e WhatsApp */}
                <div className="grid grid-cols-1 md:grid-cols-2 gap-3">
                  <FormField
                    control={form.control}
                    name="userName"
                    render={({ field, fieldState }) => (
                      <FormItem>
                        <FormLabel>
                          Nome Completo <span className="text-red-500">*</span>
                        </FormLabel>
                        <FormControl>
                          <Input
                            placeholder="Digite seu nome"
                            {...field}
                            className={cn(fieldState.error && "border-red-500 focus-visible:ring-red-500")}
                          />
                        </FormControl>
                      </FormItem>
                    )}
                  />

                  <FormField
                    control={form.control}
                    name="whatsapp"
                    render={({ field: { onChange, ...field }, fieldState }) => (
                      <FormItem>
                        <FormLabel>
                          WhatsApp <span className="text-red-500">*</span>
                        </FormLabel>
                        <FormControl>
                          <Input
                            placeholder="(XX) XXXXX-XXXX"
                            maxLength={15}
                            {...field}
                            onChange={(e) => {
                              const formatted = formatPhone(e.target.value);
                              onChange(formatted);
                            }}
                            className={cn(fieldState.error && "border-red-500 focus-visible:ring-red-500")}
                          />
                        </FormControl>
                      </FormItem>
                    )}
                  />
                </div>

                {/* E-mail e CPF */}
                <div className="grid grid-cols-1 md:grid-cols-2 gap-3">
                  <FormField
                    control={form.control}
                    name="email"
                    render={({ field, fieldState }) => (
                      <FormItem>
                        <FormLabel>
                          E-mail <span className="text-red-500">*</span>
                        </FormLabel>
                        <FormControl>
                          <Input
                            type="email"
                            placeholder="seuemail@exemplo.com"
                            {...field}
                            className={cn(fieldState.error && "border-red-500 focus-visible:ring-red-500")}
                          />
                        </FormControl>
                      </FormItem>
                    )}
                  />

                  <FormField
                    control={form.control}
                    name="cpf"
                    render={({ field: { onChange, ...field }, fieldState }) => (
                      <FormItem>
                        <FormLabel>CPF</FormLabel>
                        <FormControl>
                          <Input
                            placeholder="000.000.000-00"
                            maxLength={14}
                            {...field}
                            onChange={(e) => {
                              const formatted = formatCPF(e.target.value);
                              onChange(formatted);
                            }}
                            className={cn(fieldState.error && "border-red-500 focus-visible:ring-red-500")}
                          />
                        </FormControl>
                      </FormItem>
                    )}
                  />
                </div>

                {/* Dados do Negócio */}
                <div className="grid grid-cols-1 gap-3">
                  <FormField
                    control={form.control}
                    name="tenantName"
                    render={({ field, fieldState }) => (
                      <FormItem>
                        <FormLabel>
                          Nome da rede <span className="text-red-500">*</span>
                        </FormLabel>
                        <FormControl>
                          <Input
                            placeholder="Ex: Barbearia Silva"
                            {...field}
                            className={cn(fieldState.error && "border-red-500 focus-visible:ring-red-500")}
                          />
                        </FormControl>
                      </FormItem>
                    )}
                  />
                </div>

                {/* Senha */}
                <div className="grid grid-cols-1 md:grid-cols-2 gap-3">
                  <FormField
                    control={form.control}
                    name="password"
                    render={({ field, fieldState }) => (
                      <FormItem>
                        <FormLabel>
                          Senha <span className="text-red-500">*</span>
                        </FormLabel>
                        <FormControl>
                          <PasswordInput
                            placeholder="Crie sua senha"
                            {...field}
                            className={cn(fieldState.error && "border-red-500 focus-visible:ring-red-500")}
                          />
                        </FormControl>
                      </FormItem>
                    )}
                  />

                  <FormField
                    control={form.control}
                    name="confirmPassword"
                    render={({ field, fieldState }) => (
                      <FormItem>
                        <FormLabel>
                          Confirmar Senha <span className="text-red-500">*</span>
                        </FormLabel>
                        <FormControl>
                          <PasswordInput
                            placeholder="Repita a senha"
                            {...field}
                            className={cn(fieldState.error && "border-red-500 focus-visible:ring-red-500")}
                          />
                        </FormControl>
                      </FormItem>
                    )}
                  />
                </div>

                {/* Password Requirements - Compact */}
                <div className="text-xs text-muted-foreground">
                  <PasswordRequirements
                    password={password}
                    confirmPassword={confirmPassword}
                  />
                </div>

                {/* Submit */}
                <div className="pt-2">
                  <Button
                    type="submit"
                    className="w-full salon-button-primary"
                    id="btn-formulario-cadastro"
                    disabled={isLoading || !form.formState.isValid}
                  >
                    {isLoading ? (
                      <>
                        <Loader2 className="mr-2 h-4 w-4 animate-spin" />
                        Criando...
                      </>
                    ) : (
                      "Criar Conta Grátis"
                    )}
                  </Button>

                  <div className="text-center mt-3">
                    <Link
                      to="/login"
                      className="text-sm text-primary hover:underline"
                    >
                      Já tem uma conta? Faça login
                    </Link>
                  </div>
                </div>
              </form>
            </Form>
          </div>
        </div>
      </div>
    </AuthLayout>
  );
}