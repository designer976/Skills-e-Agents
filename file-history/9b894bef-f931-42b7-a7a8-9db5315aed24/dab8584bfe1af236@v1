import { NavItem, NavSection } from "@/types/navigation";
import { IconBarChart3 as BarChart3, IconBriefcase as Briefcase, IconBuilding as Building2, IconCalendar as Calendar, IconClipboardList as ClipboardList, IconCog as Cog, IconScissors as Scissors, IconUserCircle as UserCircle, IconUsers as Users } from "@tabler/icons-react";

// Função para obter navegação da área admin baseada no perfil do usuário
export const getAdminNavItems = (userRole: string): NavItem[] => {
  const baseItems: NavItem[] = [
    {
      title: "Salões",
      href: "/admin/salons",
      icon: Building2,
    },
  ];

  if (userRole === "Easy Salon" || userRole === "Tenant Admin") {
    const items: NavItem[] = [...baseItems];

    if (userRole === "Easy Salon") {
      // Dashboard first (only for Super Admin)
      items.unshift({
        title: "Dashboard",
        href: "/admin/dashboard",
        icon: BarChart3,
      });
    }

    items.push({
      title: "Gestão de Acesso",
      href: "/admin/users",
      icon: Users,
    });

    if (userRole === "Easy Salon") {
      items.push({
        title: "Gestão de Especialidades",
        href: "/admin/specialties",
        icon: Briefcase,
      });
    }

    // TODO: Módulo financeiro não lançado ainda — remover comentário quando pronto
    // items.push({
    //   title: "Financeiro",
    //   href: "/admin/financial",
    //   icon: Wallet,
    // });

    return items;
  }

  return baseItems;
};

// Navegação da Área de Gestão da Plataforma (Admin) - mantido para compatibilidade
export const adminNavItems: NavItem[] = getAdminNavItems("Easy Salon");

