<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Proposta Comercial — {{NOME_CLIENTE}}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --blue: #003B71;
            --secondary: #0056A3;
            --text: #2e2e2e;
            --text-muted: #374151;
            --gray: #6B7280;
            --border: #E5E7EB;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
            background: #D1D5DB;
            color: var(--text);
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
            font-size: 13px;
            line-height: 1.75;
        }

        /* ── PAGES CONTAINER ── */
        .document {
            max-width: 210mm;
            margin: 0 auto;
            padding: 24px 0;
        }

        .page {
            width: 210mm;
            min-height: 297mm;
            background: #fcfcfc;
            margin: 0 auto 24px;
            padding: 46px 56px 120px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 2px 12px rgba(0,0,0,0.12);
            page-break-after: always;
        }

        .page:last-child {
            page-break-after: auto;
            margin-bottom: 0;
        }

        /* ── BACKGROUND ── */
        .page::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('fundo-center.png') center center no-repeat;
            background-size: 602px auto;
            opacity: 0.035;
            pointer-events: none;
            z-index: 0;
        }

        /* ── CONTENT ── */
        .content {
            position: relative;
            z-index: 1;
            height: 100%;
            overflow: visible;
        }

        /* ── HEADER (PRIMEIRA PÁGINA) ── */
        .header {
            margin-bottom: 32px;
        }

        .logo {
            display: inline-block;
            margin-bottom: 64px;
        }
        .logo img {
            width: 100px;
            height: auto;
            display: block;
        }

        .cover-title {
            margin-bottom: 40px;
        }
        .cover-title h1 {
            font-size: 32px;
            font-weight: 700;
            color: var(--blue);
            line-height: 1.2;
            margin-bottom: 0;
        }
        .cover-title h2 {
            font-size: 32px;
            font-weight: 700;
            color: var(--blue);
            margin-top: 0;
            margin-bottom: 40px;
        }

        .cover-info {
            margin-bottom: 32px;
        }
        .cover-info .cover-date {
            font-size: 14px;
            font-weight: 500;
            color: var(--text);
            margin-bottom: 8px;
        }
        .cover-info p {
            font-size: 14px;
            color: var(--text);
            margin-bottom: 4px;
        }
        .cover-info strong {
            font-weight: 600;
        }

        /* ── HEADINGS ── */
        h2 {
            font-size: 18px;
            font-weight: 700;
            color: var(--blue);
            margin: 32px 0 16px 0;
            page-break-after: avoid;
        }
        h2:first-of-type,
        .flow-content h2:first-child {
            margin-top: 0;
        }

        h3 {
            font-size: 13px;
            font-weight: 700;
            color: var(--text);
            margin: 24px 0 8px 0;
            page-break-after: avoid;
        }

        h4 {
            font-size: 13px;
            font-weight: 700;
            color: var(--text);
            margin: 16px 0 8px 0;
            page-break-after: avoid;
        }

        /* ── BODY TEXT ── */
        p {
            font-size: 13px;
            line-height: 1.75;
            color: var(--text-muted);
            margin-bottom: 12px;
            orphans: 2;
            widows: 2;
        }

        strong {
            color: var(--text);
            font-weight: 700;
        }

        /* ── LISTS ── */
        ul {
            list-style: disc;
            padding-left: 20px;
            margin-bottom: 16px;
            page-break-inside: avoid;
        }
        ul li {
            font-size: 13px;
            line-height: 1.75;
            color: var(--text-muted);
            margin-bottom: 4px;
        }

        ol {
            list-style: decimal;
            padding-left: 20px;
            margin-bottom: 16px;
            page-break-inside: avoid;
        }
        ol li {
            font-size: 13px;
            line-height: 1.75;
            color: var(--text-muted);
            margin-bottom: 8px;
        }

        /* ── FUNCTIONAL SECTIONS ── */
        .func-item {
            margin-bottom: 16px;
            page-break-inside: avoid;
        }
        .func-item strong {
            color: var(--text);
        }

        .phase {
            margin-bottom: 8px;
            page-break-inside: avoid;
            font-size: 13px;
            line-height: 1.75;
            color: var(--text-muted);
        }
        .phase strong {
            color: var(--blue);
            font-weight: 700;
        }

        .team-role {
            margin-bottom: 20px;
            page-break-inside: avoid;
        }
        .team-role h4 {
            color: var(--blue);
            margin-bottom: 8px;
        }

        .investment-total {
            font-size: 16px;
            font-weight: 700;
            color: var(--text);
            margin: 20px 0 16px 0;
        }

        .payment-condition {
            margin-bottom: 8px;
            font-size: 13px;
            line-height: 1.75;
            color: var(--text-muted);
        }

        /* ── CONTINUOUS FLOW ── */
        .flow-content {
            column-fill: auto;
        }

        /* ── CLOSING ── */
        .closing {
            margin-top: 40px;
            page-break-inside: avoid;
        }
        .closing-quote {
            font-size: 16px;
            font-weight: 700;
            color: var(--blue);
            margin-bottom: 8px;
        }
        .company-info {
            margin-top: 24px;
        }
        .company-info p {
            font-size: 13px;
            color: var(--text-muted);
            margin-bottom: 4px;
        }
        .validity {
            margin-top: 16px;
            font-size: 12px;
            color: var(--text-muted);
        }

        /* ── FOOTER ── */
        .footer {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 24px 56px 32px;
            z-index: 10;
            background: rgba(252, 252, 252, 0.95);
            backdrop-filter: blur(2px);
        }
        .footer-line {
            height: 2px;
            background: #e5e7eb80;
            margin-bottom: 24px;
        }
        .footer-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .footer-logo {
            display: inline-block;
        }
        .footer-logo img {
            width: 74px;
            height: auto;
            display: block;
        }
        .pg-num {
            font-size: 12.5px;
            color: var(--blue);
            font-weight: 700;
        }

        /* ── PRINT ── */
        @media print {
            body {
                background: #fcfcfc;
                -webkit-print-color-adjust: exact;
            }

            .document {
                padding: 0;
            }

            .page {
                margin: 0;
                box-shadow: none;
                page-break-after: always;
                padding-bottom: 120px;
            }

            .footer {
                position: absolute;
                bottom: 0;
                background: #fcfcfc;
                -webkit-print-color-adjust: exact;
            }

            .page:last-child {
                page-break-after: auto;
            }

            /* Page breaks */
            h2 { page-break-after: avoid; }
            h3 { page-break-after: avoid; }
            h4 { page-break-after: avoid; }
            .func-item { page-break-inside: avoid; }
            .team-role { page-break-inside: avoid; }
            .phase { page-break-inside: avoid; }
            .closing { page-break-inside: avoid; }
            ul, ol { page-break-inside: avoid; }
            p { orphans: 2; widows: 2; }
        }

        @page {
            size: A4;
            margin: 0;
        }
    </style>
</head>
<body>

<div class="document">
    <!-- PÁGINA 1: CAPA + SOBRE A EMPRESA -->
    <div class="page">
        <div class="content">
            <div class="header">
                <div class="logo">
                    <img src="Logo completa.png" alt="{{NOME_EMPRESA}}">
                </div>

                <div class="cover-title">
                    <h1>{{TITULO_PROPOSTA}}</h1>
                    <h2>{{NOME_CLIENTE}}</h2>
                </div>

                <div class="cover-info">
                    <div class="cover-date">{{DATA_PROPOSTA}} | Válido por {{DIAS_VALIDADE}} dias</div>
                    <p><strong>Para:</strong> {{CLIENTE_EMPRESA}}</p>
                    <p><strong>Empresa:</strong> {{NOME_EMPRESA}}</p>
                    <p><strong>Tipo:</strong> {{TIPO_ESCOPO}}</p>
                    {{INFORMACOES_ADICIONAIS_CAPA}}
                </div>
            </div>

            <div class="flow-content">
                <!-- CONTEÚDO INICIAL DA CAPA (se houver) -->
                {{CONTEUDO_INICIAL_CAPA}}

                <!-- SOBRE A EMPRESA -->
                <h2>{{TITULO_SOBRE_EMPRESA}}</h2>
                <p>{{DESCRICAO_EMPRESA}}</p>

                {{SECAO_SERVICOS}}

                <h2>{{TITULO_CLIENTES}}</h2>
                {{LISTA_CLIENTES}}

                {{INFORMACOES_ADICIONAIS_EMPRESA}}
            </div>
        </div>

        <div class="footer">
            <div class="footer-line"></div>
            <div class="footer-row">
                <div class="footer-logo">
                    <img src="Logo completa.png" alt="{{NOME_EMPRESA}}">
                </div>
                <span class="pg-num">1</span>
            </div>
        </div>
    </div>

    <!-- PÁGINA 2: SOBRE O PROJETO + FUNCIONALIDADES -->
    <div class="page">
        <div class="content">
            <div class="flow-content">
                <!-- SOBRE O PROJETO -->
                <h2>{{TITULO_PROJETO}}</h2>
                <h3>{{SUBTITULO_PROJETO}}</h3>

                {{DESCRICAO_PROJETO}}

                <!-- FUNCIONALIDADES -->
                <h2>{{TITULO_FUNCIONALIDADES}}</h2>
                {{LISTA_FUNCIONALIDADES}}
                {{FUNCIONALIDADES_ADICIONAIS}}

                <!-- INTEGRAÇÕES -->
                <h2>{{TITULO_INTEGRACOES}}</h2>
                {{DESCRICAO_INTEGRACOES}}
            </div>
        </div>

        <div class="footer">
            <div class="footer-line"></div>
            <div class="footer-row">
                <div class="footer-logo">
                    <img src="Logo completa.png" alt="{{NOME_EMPRESA}}">
                </div>
                <span class="pg-num">2</span>
            </div>
        </div>
    </div>

    <!-- PÁGINA 3: MODELO DE TRABALHO + EQUIPE + CRONOGRAMA -->
    <div class="page">
        <div class="content">
            <div class="flow-content">
                <!-- MODELO DE TRABALHO -->
                <h2>{{TITULO_MODELO_TRABALHO}}</h2>
                {{DESCRICAO_MODELO}}

                <h3>{{TITULO_FASES}}</h3>
                {{LISTA_FASES}}

                <!-- EQUIPE -->
                <h2>{{TITULO_EQUIPE}}</h2>
                {{DESCRICAO_EQUIPE}}
                {{LISTA_MEMBROS_EQUIPE}}

                <!-- CRONOGRAMA -->
                <h2>{{TITULO_CRONOGRAMA}}</h2>
                {{PRAZO_TOTAL}}
                {{CRONOGRAMA_DETALHADO}}
                {{OBSERVACOES_CRONOGRAMA}}
            </div>
        </div>

        <div class="footer">
            <div class="footer-line"></div>
            <div class="footer-row">
                <div class="footer-logo">
                    <img src="Logo completa.png" alt="{{NOME_EMPRESA}}">
                </div>
                <span class="pg-num">3</span>
            </div>
        </div>
    </div>

    <!-- PÁGINA 4: INVESTIMENTO + ENTREGÁVEIS + PRÓXIMOS PASSOS -->
    <div class="page">
        <div class="content">
            <div class="flow-content">
                <!-- INVESTIMENTO -->
                <h2>{{TITULO_INVESTIMENTO}}</h2>
                {{VALOR_TOTAL}}

                <h3>{{TITULO_CONDICOES_PAGAMENTO}}</h3>
                {{CONDICOES_PAGAMENTO}}

                <!-- ENTREGÁVEIS -->
                <h2>{{TITULO_ENTREGAVEIS}}</h2>
                {{LISTA_ENTREGAVEIS}}

                <!-- PRÓXIMOS PASSOS -->
                <h2>{{TITULO_PROXIMOS_PASSOS}}</h2>
                {{LISTA_PROXIMOS_PASSOS}}
                {{MENSAGEM_FINAL_PASSOS}}
            </div>
        </div>

        <div class="footer">
            <div class="footer-line"></div>
            <div class="footer-row">
                <div class="footer-logo">
                    <img src="Logo completa.png" alt="{{NOME_EMPRESA}}">
                </div>
                <span class="pg-num">4</span>
            </div>
        </div>
    </div>

    <!-- PÁGINA 5: ENCERRAMENTO -->
    <div class="page">
        <div class="content">
            <div class="flow-content">
                <!-- ENCERRAMENTO -->
                <div class="closing">
                    {{CITACAO_ENCERRAMENTO}}

                    <div class="company-info">
                        {{INFORMACOES_EMPRESA_COMPLETA}}
                    </div>

                    <div class="validity">
                        {{TEXTO_VALIDADE}}
                    </div>
                </div>
            </div>
        </div>

        <div class="footer">
            <div class="footer-line"></div>
            <div class="footer-row">
                <div class="footer-logo">
                    <img src="Logo completa.png" alt="{{NOME_EMPRESA}}">
                </div>
                <span class="pg-num">5</span>
            </div>
        </div>
    </div>
</div>

</body>
</html>