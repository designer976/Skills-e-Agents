import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { Card, CardContent } from "@/components/ui/card";
import { Subscription } from "@/types/subscription";
import { format, parseISO } from "date-fns";
import { ptBR } from "date-fns/locale";
import { RefreshCw as RefreshCw, CircleX as XCircle, Clock as Clock } from "lucide-react";

interface SubscriptionStatusCardProps {
    subscription: Subscription;
    actions: {
        canCancel: boolean;
        canChangePlan: boolean;
        canUpdatePayment: boolean;
    };
    onCancel: () => void;
    onChangePlan: () => void;
    isCanceling?: boolean;
    remainingDays?: number;
}

export function SubscriptionStatusCard({
    subscription,
    actions,
    onCancel,
    onChangePlan,
    isCanceling = false,
    remainingDays = 0
}: SubscriptionStatusCardProps) {
    // Safe extract plan amount from plan relation or subscription helper if any
    const amount = subscription.plan?.amount || subscription.amount || 0;
    const planName = subscription.plan?.name || "Plano Desconhecido";

    return (
        <div className="space-y-4">
            <h2 className="text-xl font-semibold text-foreground">Plano e Status</h2>
            <div className="bg-card border border-border p-6 rounded-3xl">
                <div className="flex items-start justify-between gap-4 mb-0">
                    <div className="flex flex-col gap-2">
                        <div className="flex items-center gap-3">
                            <h2 className="text-xl font-semibold text-foreground">{planName}</h2>
                            <StatusBadge status={isCanceling ? 'canceling_period' : subscription.status} />
                            {isCanceling && (
                                <span className="text-xs text-muted-foreground">
                                    ({remainingDays} dias restantes até {subscription.validUntil ? format(parseISO(subscription.validUntil.toString()), 'dd/MM/yyyy') : ''})
                                </span>
                            )}
                        </div>
                        <p className="text-sm text-muted-foreground">
                            Próxima cobrança: {subscription.currentPeriodEnd ? format(parseISO(subscription.currentPeriodEnd.toString()), 'dd/MM/yyyy', { locale: ptBR }) : '-'}
                        </p>
                        <p className="text-sm text-foreground">
                            {subscription.status === 'trialing' ? (
                                <>
                                    Gratuíto por {subscription.plan?.trialDays || 0} dias depois <span className="font-medium">{new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(Number(amount))}</span>
                                </>
                            ) : (
                                <>
                                    Valor: <span className="font-medium">{new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(Number(amount))}</span>
                                </>
                            )}
                        </p>
                    </div>

                    <div className="flex gap-2">
                        {actions.canChangePlan && (
                            <Button variant="default" size="sm" className="transition-all cursor-pointer gap-1.5 shadow-xs" onClick={onChangePlan}>
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className="tabler-icon tabler-icon-refresh w-4 h-4 mr-2">
                                    <path d="M20 11a8.1 8.1 0 0 0 -15.5 -2m-.5 -4v4h4"></path>
                                    <path d="M4 13a8.1 8.1 0 0 0 15.5 2m.5 4v-4h-4"></path>
                                </svg>
                                Alterar plano
                            </Button>
                        )}
                        {actions.canCancel && !isCanceling && (
                            <Button variant="outline" size="sm" className="transition-all cursor-pointer gap-1.5 shadow-xs text-red-500 hover:text-red-600" onClick={onCancel}>
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className="tabler-icon tabler-icon-x w-4 h-4 mr-2">
                                    <path d="M18 6l-12 12"></path>
                                    <path d="M6 6l12 12"></path>
                                </svg>
                                Cancelar assinatura
                            </Button>
                        )}
                        {isCanceling && (
                            <Button variant="outline" size="sm" disabled className="opacity-50 cursor-not-allowed gap-1.5">
                                <Clock className="w-4 h-4 mr-2" />
                                Cancelar assinatura
                            </Button>
                        )}
                    </div>
                </div>
            </div>
        </div>
    );
}

function StatusBadge({ status }: { status: string }) {
    const styles: Record<string, string> = {
        active: 'bg-green-100 text-green-700 hover:bg-green-100',
        canceled: 'bg-muted text-muted-foreground hover:bg-muted',
        past_due: 'bg-red-100 text-red-700 hover:bg-red-100',
        trialing: 'bg-blue-100 text-blue-700 hover:bg-blue-100',
        unpaid: 'bg-red-100 text-red-800 hover:bg-red-100',
        canceling_period: 'bg-amber-100 text-amber-700 hover:bg-amber-100'
    };

    const labels: Record<string, string> = {
        active: 'Ativo',
        canceled: 'Cancelado',
        past_due: 'Pendente',
        trialing: 'Trial',
        unpaid: 'Não Pago',
        canceling_period: 'Em cancelamento'
    };

    const StatusIcon = status === 'canceling_period' ? <Clock className="w-3 h-3 mr-1 inline" /> : null;

    return (
        <Badge className={`${styles[status] || 'bg-muted'} font-medium text-xs px-2 py-0.5 rounded-full border-none shadow-none`}>
            {StatusIcon}
            {labels[status] || status}
        </Badge>
    );
}
