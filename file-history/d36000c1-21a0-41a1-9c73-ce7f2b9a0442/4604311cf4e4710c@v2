import { trackSeverinoEvent } from "@/services/severinoService";
import { AuthLayout } from "@/components/AuthLayout";
import { StepProfessional } from "@/components/onboarding/StepProfessional";
import { StepSchedule } from "@/components/onboarding/StepSchedule";
import { StepServices } from "@/components/onboarding/StepServices";
import {
    StepProfessionalData,
    stepProfessionalSchema,
    StepScheduleData,
    stepScheduleSchema,
    StepServicesData,
    stepServicesSchema,
} from "@/components/onboarding/schemas";
import { useAuth } from "@/contexts/AuthContext";
import { useSelectedSalon } from "@/hooks/useSelectedSalon";
import { analytics } from "@/lib/analytics";
import { onboardingService } from "@/services/onboardingService";
import { getOnboardingErrorMessage } from "@/utils/error";
import { zodResolver } from "@hookform/resolvers/zod";
import { ChevronLeft, ChevronRight } from "lucide-react";
import { useEffect, useState } from "react";
import { FirstAppointmentModal } from "@/components/onboarding/FirstAppointmentModal";
import { useForm } from "react-hook-form";
import { useNavigate } from "react-router-dom";
import { toast } from "sonner";
import { CompleteOnboardingPayload } from "../../../packages/shared-types/src/onboarding.types";
import { WOW_MOMENT_STORAGE_KEY } from "@/hooks/useWowMoment";


export default function OnboardingPage() {
    const navigate = useNavigate();
    const { user, refreshToken } = useAuth();
    const { selectSalon } = useSelectedSalon();
    const [step, setStep] = useState(1);
    const [isSubmitting, setIsSubmitting] = useState(false);
    const [testClient, setTestClient] = useState<{ id: string; name: string; phone: string } | null>(null);
    const [showSuccessModal, setShowSuccessModal] = useState(false);

    useEffect(() => {
        analytics.trackEvent('onboarding_started', {});
    }, []);

    useEffect(() => {
        const stepNames = { 1: 'services', 2: 'professional', 3: 'schedule' } as const;
        analytics.trackEvent('onboarding_step_viewed', { step: step as 1 | 2 | 3, step_name: stepNames[step as 1 | 2 | 3] });
    }, [step]);
    useEffect(() => {
        if (window.innerWidth < 920) {
            window.scrollTo({ top: 0, behavior: "smooth" });
        }
    }, [step]);

    // State lifting - We keep the "committed" data from previous steps here.
    const [payload, setPayload] = useState<Partial<CompleteOnboardingPayload>>({
        services: [],
        professional: {
            name: user?.name || "",
            phone: "",
            services: [],
            bio: "",
        },
        schedule: {
            open: "09:00",
            close: "18:00",
            daysOpen: [1, 2, 3, 4, 5],
        },
    });

    // Step 1 Form
    const servicesForm = useForm<StepServicesData>({
        resolver: zodResolver(stepServicesSchema),
        defaultValues: {
            services: [],
        },
        mode: "onChange",
    });

    const { isValid } = servicesForm.formState;

    // Step 2 Form
    const professionalForm = useForm<StepProfessionalData>({
        resolver: zodResolver(stepProfessionalSchema),
        defaultValues: {
            isMe: true,
            name: user?.name || "",
            phone: "",
            bio: "",
            services: [],
        },
        mode: "onChange",
    });

    const isStep2Valid = professionalForm.formState.isValid;

    // Step 3 Form
    const scheduleForm = useForm<StepScheduleData>({
        resolver: zodResolver(stepScheduleSchema),
        defaultValues: {
            startTime: "09:00",
            endTime: "18:00",
            daysOpen: [1, 2, 3, 4, 5],
        },
    });

    const handleNextStep1 = (data: StepServicesData) => {
        const selectedServices = data.services
            .filter((s) => s.selected)
            .map((s) => ({
                serviceId: s.serviceId,
                price: s.price,
                duration: s.duration,
            }));
        setPayload((prev) => ({ ...prev, services: selectedServices }));
        analytics.trackEvent('onboarding_step_completed', { step: 1, services_count: selectedServices.length });
        setStep(2);
    };

    const handleNextStep2 = (data: StepProfessionalData) => {
        const serviceIds = payload.services?.map((s) => s.serviceId) || [];
        setPayload((prev) => ({
            ...prev,
            professional: {
                name: data.name,
                phone: data.phone,
                bio: data.bio,
                services: serviceIds,
            },
        }));
        analytics.trackEvent('onboarding_step_completed', { step: 2, is_self_professional: data.isMe, services_assigned: serviceIds.length });
        setStep(3);
    };

    const handleFinalSubmit = async (data: StepScheduleData) => {
        setIsSubmitting(true);
        try {
            const finalPayload: CompleteOnboardingPayload = {
                services: payload.services!,
                professional: payload.professional!,
                schedule: {
                    open: data.startTime,
                    close: data.endTime,
                    daysOpen: data.daysOpen,
                },
            };

            const response = await onboardingService.completeOnboarding(finalPayload);

            if (response.success && response.salonId) {
                await refreshToken();
                await selectSalon(response.salonId);

                analytics.trackEvent('onboarding_step_completed', { step: 3, days_open_count: data.daysOpen.length, open_time: data.startTime, close_time: data.endTime });
                analytics.trackEvent('onboarding_completo', {});
                trackSeverinoEvent('onboarding_completo', { description: 'Onboarding concluído com sucesso' });

                navigate('/salon/agenda', {
                    state: {
                        fromOnboarding: true,
                        testClient: response.testClient || null,
                        professionalId: response.professionalId
                    }
                });
            }
        } catch (error) {
            const errorMessage = getOnboardingErrorMessage(error);
            analytics.trackEvent('onboarding_failed', { error_type: 'api_error' });
            toast.error(errorMessage);
            console.error(error);
        } finally {
            setIsSubmitting(false);
        }
    };

    return (
        <AuthLayout maxWidth="2xl" bannerWidth="lg:w-[40%]" imagePosition="center">
            <div className="w-full flex-1 flex flex-col">
                {/* Mobile Header - Visible only on LG screens and below according to prototype hidden on lg? lg:hidden */}
                <div className="lg:hidden mb-6 flex justify-center">
                    <div className="text-2xl font-semibold text-foreground">
                        EASY <span className="text-primary">*</span> SALON
                    </div>
                </div>

                <div className="text-center mb-6">
                    <h2 className="font-semibold text-foreground text-2xl">Pré Cadastro do salão</h2>
                </div>

                {/* Stepper */}
                <div className="flex items-center justify-center gap-2 mb-8">
                    {/* Step 1 */}
                    <div className="flex items-center gap-2">
                        <div
                            className={`w-8 h-8 rounded-full flex items-center justify-center text-sm font-medium transition-colors ${step >= 1 ? "bg-primary text-primary-foreground" : "bg-muted text-muted-foreground"
                                }`}
                        >
                            1
                        </div>
                        <div className={`w-12 lg:w-16 h-1 rounded ${step >= 2 ? "bg-primary" : "bg-muted"}`}></div>
                    </div>

                    {/* Step 2 */}
                    <div className="flex items-center gap-2">
                        <div
                            className={`w-8 h-8 rounded-full flex items-center justify-center text-sm font-medium transition-colors ${step >= 2 ? "bg-primary text-primary-foreground" : "bg-muted text-muted-foreground"
                                }`}
                        >
                            2
                        </div>
                        <div className={`w-12 lg:w-16 h-1 rounded ${step >= 3 ? "bg-primary" : "bg-muted"}`}></div>
                    </div>

                    {/* Step 3 */}
                    <div className="flex items-center gap-2">
                        <div
                            className={`w-8 h-8 rounded-full flex items-center justify-center text-sm font-medium transition-colors ${step >= 3 ? "bg-primary text-primary-foreground" : "bg-muted text-muted-foreground"
                                }`}
                        >
                            3
                        </div>
                    </div>
                </div>

                <div className="flex-1">
                    {step === 1 && (
                        <form onSubmit={servicesForm.handleSubmit(handleNextStep1)} className="flex flex-col h-full">
                            <StepServices form={servicesForm} />

                            <div className="flex items-center justify-between mt-8 pt-6 border-t border-border">
                                <button
                                    type="button"
                                    disabled={true}
                                    className="flex items-center gap-2 px-4 py-2 text-sm font-medium text-muted-foreground hover:text-foreground transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                                >
                                    <ChevronLeft className="w-4 h-4" />
                                    Voltar
                                </button>
                                <button
                                    type="submit"
                                    disabled={!isValid || servicesForm.watch("services").filter(s => s.selected).length === 0}
                                    className="flex items-center gap-1.5 md:gap-2 px-4 py-2 md:px-6 bg-primary hover:bg-primary/90 text-primary-foreground text-xs md:text-sm font-medium rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                                >
                                    Próximo
                                    <ChevronRight className="w-4 h-4" />
                                </button>
                            </div>
                        </form>
                    )}

                    {step === 2 && (
                        <form onSubmit={professionalForm.handleSubmit(handleNextStep2)} className="flex flex-col h-full">
                            <StepProfessional
                                form={professionalForm}
                                availableServices={
                                    payload.services?.map(s => ({ serviceId: s.serviceId, name: servicesForm.getValues("services").find(serv => serv.serviceId === s.serviceId)?.name || "" })) || []
                                }
                            />

                            <div className="flex items-center justify-between mt-8 pt-6 border-t border-border">
                                <button
                                    type="button"
                                    onClick={() => setStep(1)}
                                    className="flex items-center gap-2 px-4 py-2 text-sm font-medium text-muted-foreground hover:text-foreground transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                                >
                                    <ChevronLeft className="w-4 h-4" />
                                    Voltar
                                </button>
                                <button
                                    type="submit"
                                    disabled={!isStep2Valid}
                                    className="flex items-center gap-1.5 md:gap-2 px-4 py-2 md:px-6 bg-primary hover:bg-primary/90 text-primary-foreground text-xs md:text-sm font-medium rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                                >
                                    Próximo
                                    <ChevronRight className="w-4 h-4" />
                                </button>
                            </div>
                        </form>
                    )}

                    {step === 3 && (
                        <form onSubmit={scheduleForm.handleSubmit(handleFinalSubmit)} className="flex flex-col h-full">
                            <StepSchedule form={scheduleForm} />

                            <div className="flex items-center justify-between mt-8 pt-6 border-t border-border">
                                <button
                                    type="button"
                                    onClick={() => setStep(2)}
                                    className="flex items-center gap-2 px-4 py-2 text-sm font-medium text-muted-foreground hover:text-foreground transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                                >
                                    <ChevronLeft className="w-4 h-4" />
                                    Voltar
                                </button>
                                <button
                                    type="submit"
                                    disabled={isSubmitting}
                                    className="flex items-center gap-1.5 md:gap-2 px-4 py-2 md:px-6 bg-primary hover:bg-primary/90 text-primary-foreground text-xs md:text-sm font-medium rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                                >
                                    {isSubmitting ? "Finalizando..." : "Finalizar configuração"}
                                    {!isSubmitting && <ChevronRight className="w-4 h-4" />}
                                </button>
                            </div>
                        </form>
                    )}
                </div>
            </div>
        </AuthLayout>
    );
}

function SuccessModal({ onClose }: { onClose: () => void }) {
    const navigate = useNavigate();
    const { selectedSalon } = useSelectedSalon();
    const BOT_NUMBER = import.meta.env.VITE_WHATSAPP_IA || "554192938071";

    // Lock body scroll while modal is open — prevents iOS Safari "scroll-through"
    // position:fixed requires saving/restoring scroll position to avoid page jump
    useEffect(() => {
        const scrollY = window.scrollY;
        document.body.style.top = `-${scrollY}px`;
        document.body.classList.add('body-scroll-locked');
        return () => {
            document.body.classList.remove('body-scroll-locked');
            document.body.style.top = '';
            window.scrollTo({ top: scrollY, behavior: 'instant' as ScrollBehavior });
        };
    }, []);

    const handleTestClick = () => {

        // 1. Persistir intenção ANTES de navegar
        sessionStorage.setItem(WOW_MOMENT_STORAGE_KEY, 'true');

        // 2. Abrir WhatsApp
        const salonName = selectedSalon?.name || "";
        const salonPhone = selectedSalon?.phone || "";
        const message = `Olá, sou do salão ${salonName}${salonPhone ? ` ${salonPhone}` : ""} e gostaria de marcar um agendamento`;
        window.open(`https://wa.me/${BOT_NUMBER}?text=${encodeURIComponent(message)}`, '_blank');

        // 3. Navegar SEM state
        navigate('/salon/agenda');
    };

    return (
        <div className="fixed inset-0 bg-black/50 flex items-center justify-center p-3 sm:p-4 z-50">
            {/* Modal wrapper: max-height com fallback vh→dvh + scroll interno */}
            <div
                className="relative shadow-xl w-full mx-2 sm:mx-4 bg-[#EFE9DD] rounded-3xl flex flex-col modal-max-h overflow-hidden"
                style={{ maxWidth: '716px' }}
            >
                {/* Scrollable body: overscroll-behavior:contain impede scroll chaining no iOS */}
                <div className="modal-scroll-area flex-1">
                    {/* Header Section with decorative background */}
                    <div className="relative pt-6 pb-4 px-6 sm:pt-8 sm:pb-6 sm:px-8 rounded-t-3xl bg-[#EFE9DD]">
                        {/* Decorative background layer */}
                        <div
                            className="absolute top-2 left-2 right-2 bottom-0 opacity-100 rounded-3xl"
                            style={{
                                backgroundColor: '#EADDC6',
                                backgroundImage: 'repeating-linear-gradient(90deg, transparent, transparent 10px, rgba(234, 221, 198, 0.3) 10px, rgba(234, 221, 198, 0.3) 20px)',
                                backgroundSize: 'auto 100%',
                                backgroundPosition: 'center center',
                                backgroundRepeat: 'repeat-x'
                            }}
                        ></div>

                        {/* Content */}
                        <div className="relative z-10">
                            <h2 className="text-[#C74634] text-xl sm:text-2xl md:text-3xl font-bold leading-tight mb-2 sm:mb-4" style={{ fontFamily: 'Gyst, serif' }}>
                                Sua IA está prontíssima e pode ser testada agora mesmo no WhatsApp!
                            </h2>
                            <p className="text-[#5A5247] text-sm sm:text-base leading-relaxed">
                                Você vai ver <strong>na prática</strong> como seus clientes poderão agendar horários de forma simples, rápida e automática — sem atrito, sem espera, sem complicação.
                            </p>
                        </div>
                    </div>

                    {/* Center Section with steps */}
                    <div className="relative px-6 py-6 sm:px-8 sm:py-10">
                        {/* Decorative background */}
                        <div
                            className="absolute inset-0 opacity-100"
                            style={{
                                backgroundColor: '#EFE9DD',
                                backgroundImage: 'radial-gradient(circle at center, rgba(234, 221, 198, 0.4) 0%, transparent 70%)',
                                backgroundSize: '479px',
                                backgroundPosition: 'center center',
                                backgroundRepeat: 'no-repeat'
                            }}
                        ></div>

                        {/* Steps — flex-row com flex-1/min-w-0 para dividir espaço igualmente;
                            tamanhos reduzidos na base (mobile ≤390px) e crescem em sm/md */}
                        <div className="relative z-10 flex flex-row items-start justify-center gap-2 sm:gap-4 md:gap-5">
                            {/* Step 01 */}
                            <div className="flex flex-col items-center text-center flex-1 min-w-0">
                                <div className="flex items-center justify-center gap-0.5 sm:gap-1 mb-1.5 sm:mb-3">
                                    <span className="font-medium text-[#AC9671] text-4xl sm:text-6xl md:text-7xl leading-none" style={{ fontWeight: 500, fontFamily: 'Gyst, serif' }}>
                                        01
                                    </span>
                                    <img
                                        alt="IA no celular"
                                        src="/lovable-uploads/f-01.png"
                                        className="w-10 h-10 sm:w-16 sm:h-16 md:w-[98px] md:h-[98px] ml-[-4px] sm:ml-[-6px] md:ml-[-12px] flex-shrink-0"
                                    />
                                </div>
                                <p className="text-[#89724C] text-xs sm:text-sm md:text-xl leading-snug" style={{ fontFamily: 'Gyst, serif' }}>
                                    <strong className="text-[#C74634]">Converse com a IA</strong> e<br />
                                    faça um agendamento
                                </p>
                            </div>

                            {/* Arrow — alinhada ao centro dos ícones, sem crescer nem encolher */}
                            <div className="flex-shrink-0 self-start pt-3 sm:pt-4 md:pt-0">
                                <img
                                    alt="Próximo passo"
                                    src="/lovable-uploads/arrow.png"
                                    className="h-[12px] w-[18px] sm:h-[14px] sm:w-[22px] md:h-[17px] md:w-[26px]"
                                />
                            </div>

                            {/* Step 02 */}
                            <div className="flex flex-col items-center text-center flex-1 min-w-0">
                                <div className="flex items-center justify-center gap-0.5 sm:gap-1 mb-1.5 sm:mb-3">
                                    <span className="text-4xl sm:text-6xl font-medium text-[#AC9671] md:text-7xl leading-none" style={{ fontWeight: 500, fontFamily: 'Gyst, serif' }}>
                                        02
                                    </span>
                                    <img
                                        alt="Calendário IA"
                                        src="/lovable-uploads/f-02.png"
                                        className="w-10 h-10 sm:w-16 sm:h-16 md:w-[98px] md:h-[98px] ml-[-4px] sm:ml-[-6px] md:ml-[-12px] flex-shrink-0"
                                    />
                                </div>
                                <p className="text-[#89724C] text-xs sm:text-sm md:text-xl leading-snug" style={{ fontFamily: 'Gyst, serif' }}>
                                    Veja a <strong className="text-[#C74634]">IA organizando</strong><br />
                                    <strong className="text-[#C74634]">a agenda por você</strong>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                {/* Button Section — fora do scroll, sempre visível na base */}
                <div className="px-6 pb-4 sm:px-8 sm:pb-6 bg-[#EFE9DD]">
                    <button
                        onClick={handleTestClick}
                        className="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-xl text-sm font-semibold transition-all cursor-pointer w-full bg-primary hover:bg-primary/90 text-primary-foreground h-11 px-5 py-2.5"
                        style={{ boxShadow: 'rgba(221, 66, 39, 0px 12px 20px 0px' }}
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="none" className="size-5">
                            <path d="M18.497 4.409a10 10 0 0 1 -10.36 16.828l-.223 -.098l-4.759 .849l-.11 .011a1 1 0 0 1 -.11 0l-.102 -.013l-.108 -.024l-.105 -.037l-.099 -.047l-.093 -.058l-.014 -.011l-.012 -.007l-.086 -.073l-.077 -.08l-.067 -.088l-.056 -.094l-.034 -.07l-.04 -.108l-.028 -.128l-.012 -.102a1 1 0 0 1 0 -.125l.012 -.1l.024 -.11l.045 -.122l1.433 -3.304l-.009 -.014a10 10 0 0 1 1.549 -12.454l.215 -.203a10 10 0 0 1 13.226 -.217m-8.997 3.09a1.5 1.5 0 0 0 -1.5 1.5v1a6 6 0 0 0 6 6h1a1.5 1.5 0 0 0 0 -3h-1l-.144 .007a1.5 1.5 0 0 0 -1.128 .697l-.042 .074l-.022 -.007a4.01 4.01 0 0 1 -2.435 -2.435l-.008 -.023l.075 -.041a1.5 1.5 0 0 0 .704 -1.272v-1a1.5 1.5 0 0 0 -1.5 -1.5"></path>
                        </svg>
                        Quero testar minha IA no WhatsApp
                    </button>
                </div>

                <div className="pb-5 sm:pb-8 text-center bg-[#EFE9DD]">
                    <button
                        onClick={() => {
                            sessionStorage.removeItem(WOW_MOMENT_STORAGE_KEY);
                            navigate('/salon/agenda');
                        }}
                        className="text-[#2E2E2E] text-sm underline hover:text-[#3A3A3A] transition-colors font-bold"
                    >
                        Pular e testar depois
                    </button>
                </div>
            </div>
        </div>
    );
}
