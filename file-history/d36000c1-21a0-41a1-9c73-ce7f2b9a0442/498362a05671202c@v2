import React, { useState } from 'react';
import { useWebSocketContext } from '@/contexts/WebSocketProvider';
import { ConnectionStatus as ConnectionStatusType } from '@/types/websocket';
import { Wifi, WifiOff, RefreshCw, AlertCircle, ChevronDown, Activity, Clock } from "lucide-react";
import { cn } from '@/lib/utils';
import { format } from 'date-fns';
import { ptBR } from 'date-fns/locale';
import {
  Popover,
  PopoverContent,
  PopoverTrigger,
} from '@/components/ui/popover';
import { Button } from '@/components/ui/button';
import { Badge } from '@/components/ui/badge';

const statusConfig: Record<ConnectionStatusType, {
  icon: React.ElementType;
  label: string;
  color: string;
  bgColor: string;
  animate?: string;
}> = {
  connected: {
    icon: Wifi,
    label: 'Conectado',
    color: 'text-green-600',
    bgColor: 'bg-green-100',
  },
  connecting: {
    icon: RefreshCw,
    label: 'Conectando',
    color: 'text-yellow-600',
    bgColor: 'bg-yellow-100',
    animate: 'animate-spin',
  },
  reconnecting: {
    icon: RefreshCw,
    label: 'Reconectando',
    color: 'text-orange-600',
    bgColor: 'bg-orange-100',
    animate: 'animate-spin',
  },
  disconnected: {
    icon: WifiOff,
    label: 'Desconectado',
    color: 'text-red-600',
    bgColor: 'bg-red-100',
  },
};

export function ConnectionStatus() {
  const { connectionStatus, isConnected, isFallbackPolling, metrics, reconnect } = useWebSocketContext();
  const [showDetails, setShowDetails] = useState(false);
  
  const config = statusConfig[connectionStatus];
  const Icon = config.icon;

  const formatDuration = (ms?: number) => {
    if (!ms) return '-';
    if (ms < 1000) return `${ms}ms`;
    return `${(ms / 1000).toFixed(1)}s`;
  };

  const formatTime = (date?: Date) => {
    if (!date) return '-';
    return format(new Date(date), 'HH:mm:ss', { locale: ptBR });
  };

  return (
    <Popover open={showDetails} onOpenChange={setShowDetails}>
      <PopoverTrigger asChild>
        <Button
          variant="ghost"
          size="sm"
          className={cn(
            'h-8 px-2 gap-1.5',
            config.bgColor,
            config.color,
            'hover:opacity-80'
          )}
        >
          <Icon className={cn('h-4 w-4', config.animate)} />
          <span className="text-xs font-medium hidden sm:inline">
            {config.label}
          </span>
          {isFallbackPolling && (
            <Badge variant="secondary" className="ml-1 text-xs px-1 py-0">
              Polling
            </Badge>
          )}
          <ChevronDown className="h-3 w-3 opacity-50" />
        </Button>
      </PopoverTrigger>
      
      <PopoverContent align="end" className="w-80">
        <div className="space-y-3">
          {/* Header */}
          <div className="flex items-center justify-between">
            <h4 className="font-semibold text-sm">Status da Conexão</h4>
            <div className={cn('flex items-center gap-1.5', config.color)}>
              <Icon className={cn('h-4 w-4', config.animate)} />
              <span className="text-sm font-medium">{config.label}</span>
            </div>
          </div>

          {/* Fallback Polling Warning */}
          {isFallbackPolling && (
            <div className="bg-yellow-50 border border-yellow-200 rounded-md p-2">
              <div className="flex items-start gap-2">
                <AlertCircle className="h-4 w-4 text-yellow-600 mt-0.5" />
                <div className="text-xs text-yellow-800">
                  <p className="font-medium">Modo offline ativo</p>
                  <p className="mt-1">
                    As atualizações estão sendo buscadas periodicamente. 
                    Alguns recursos em tempo real podem estar limitados.
                  </p>
                </div>
              </div>
            </div>
          )}

          {/* Connection Metrics */}
          <div className="space-y-2">
            <h5 className="text-xs font-medium text-muted-foreground uppercase">
              Métricas
            </h5>
            
            <div className="grid grid-cols-2 gap-2 text-xs">
              <div className="flex items-center gap-1.5">
                <Activity className="h-3 w-3 text-muted-foreground" />
                <span className="text-muted-foreground">Tempo de conexão:</span>
                <span className="font-medium">
                  {formatDuration(metrics.connectionTime)}
                </span>
              </div>
              
              <div className="flex items-center gap-1.5">
                <RefreshCw className="h-3 w-3 text-muted-foreground" />
                <span className="text-muted-foreground">Reconexões:</span>
                <span className="font-medium">{metrics.reconnectCount}</span>
              </div>
              
              <div className="flex items-center gap-1.5">
                <Activity className="h-3 w-3 text-muted-foreground" />
                <span className="text-muted-foreground">Mensagens enviadas:</span>
                <span className="font-medium">{metrics.messagesSent}</span>
              </div>
              
              <div className="flex items-center gap-1.5">
                <Activity className="h-3 w-3 text-muted-foreground" />
                <span className="text-muted-foreground">Mensagens recebidas:</span>
                <span className="font-medium">{metrics.messagesReceived}</span>
              </div>
              
              <div className="flex items-center gap-1.5">
                <Clock className="h-3 w-3 text-muted-foreground" />
                <span className="text-muted-foreground">Última atividade:</span>
                <span className="font-medium">
                  {formatTime(metrics.lastActivityTime)}
                </span>
              </div>
              
              <div className="flex items-center gap-1.5">
                <AlertCircle className="h-3 w-3 text-muted-foreground" />
                <span className="text-muted-foreground">Erros:</span>
                <span className="font-medium">{metrics.errors.count}</span>
              </div>
            </div>
          </div>

          {/* Actions */}
          {!isConnected && (
            <div className="pt-2 border-t">
              <Button
                size="sm"
                variant="outline"
                className="w-full"
                onClick={reconnect}
              >
                <RefreshCw className="h-4 w-4 mr-2" />
                Tentar Reconectar
              </Button>
            </div>
          )}
        </div>
      </PopoverContent>
    </Popover>
  );
}