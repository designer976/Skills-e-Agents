import { Button } from "@/components/ui/button";
import {
    Dialog,
    DialogContent,
    DialogHeader,
    DialogTitle,
} from "@/components/ui/dialog";
import { cn } from "@/lib/utils";
import { Plan } from "@/types/subscription";
import { Check, Lock, RefreshCw, MessageCircle } from "lucide-react";
import { useState, useEffect } from "react";

interface ChangePlanModalProps {
    isOpen: boolean;
    onClose: () => void;
    onConfirm: (planId: string) => void;
    currentPlanId?: string;
    plans: Plan[];
}

export function ChangePlanModal({ isOpen, onClose, onConfirm, currentPlanId, plans }: ChangePlanModalProps) {
    const [selectedId, setSelectedId] = useState<string>(currentPlanId || "");
    const [isSubmitting, setIsSubmitting] = useState(false);

    useEffect(() => {
        if (currentPlanId) {
            setSelectedId(currentPlanId);
        } else if (plans.length > 0 && !selectedId) {
            setSelectedId(plans[0].id);
        }
    }, [currentPlanId, plans]);

    const selectedPlan = plans.find(p => p.id === selectedId);
    const isConsultation = selectedPlan?.consultationRequired;

    const handleConfirm = async () => {
        if (isConsultation) {
            const phoneNumber = import.meta.env.VITE_WHATSAPP_COMERCIAL || "5541985290866";
            const message = `Olá! Tenho interesse no plano ${selectedPlan.name} do Easy Salon. Poderia me passar mais informações?`;
            window.open(`https://wa.me/${phoneNumber}?text=${encodeURIComponent(message)}`, '_blank');
            onClose();
            return;
        }

        setIsSubmitting(true);
        try {
            await onConfirm(selectedId);
            onClose();
        } finally {
            setIsSubmitting(false);
        }
    };

    return (
        <Dialog open={isOpen} onOpenChange={(open) => !open && onClose()}>
            <DialogContent className="w-[95vw] md:max-w-[500px] max-h-[90vh] md:max-h-[85vh] p-0 gap-0 rounded-xl md:rounded-lg border-none shadow-2xl overflow-hidden flex flex-col">
                <DialogHeader className="sticky top-0 z-10 bg-background px-4 pt-4 pb-3 border-b shrink-0 text-left">
                    <DialogTitle className="text-xl font-bold">Alterar plano</DialogTitle>
                    <p className="text-sm text-muted-foreground mt-1">
                        Escolha o plano que melhor se adequa às suas necessidades.
                    </p>
                </DialogHeader>

                <div className="flex-1 overflow-y-auto px-4 py-4 custom-scrollbar">
                    <div className="space-y-4">
                        {plans.map((plan) => {
                            const isPlanSelected = selectedId === plan.id;
                            const isPlanConsultation = plan.consultationRequired;
                            const price = new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(plan.amount);

                            return (
                                <div
                                    key={plan.id}
                                    onClick={() => setSelectedId(plan.id)}
                                    className={cn(
                                        "group relative flex flex-col p-5 rounded-xl border-2 transition-all cursor-pointer",
                                        isPlanSelected
                                            ? "border-primary bg-primary/5"
                                            : "border-border hover:border-muted-foreground/30"
                                    )}
                                >
                                    <div className="flex justify-between items-start mb-2">
                                        <h3 className="text-lg font-bold text-foreground">{plan.name}</h3>
                                        {isPlanConsultation ? (
                                            <div className="flex items-center gap-1 px-2 py-1 bg-primary/10 rounded text-[10px] uppercase font-bold text-primary">
                                                <MessageCircle className="w-3 h-3" />
                                                Sob Consulta
                                            </div>
                                        ) : isPlanSelected && (
                                            <div className="bg-primary rounded-full p-1">
                                                <Check className="w-4 h-4 text-primary-foreground" />
                                            </div>
                                        )}
                                    </div>

                                    <p className="text-sm text-muted-foreground mb-4 pr-8">
                                        {plan.description}
                                    </p>

                                    <div className="flex items-baseline gap-1">
                                        <span className={cn(
                                            "text-2xl font-bold",
                                            isPlanConsultation ? "text-primary/70" : "text-primary"
                                        )}>
                                            {isPlanConsultation ? "Sob Consulta" : price}
                                        </span>
                                        {!isPlanConsultation && <span className="text-sm text-muted-foreground">/mês</span>}
                                    </div>
                                </div>
                            );
                        })}
                    </div>
                </div>

                <div className="sticky bottom-0 z-10 bg-background px-4 pt-3 pb-4 border-t shrink-0 flex flex-col-reverse sm:flex-row sm:justify-end gap-2 sm:gap-3">
                    <Button
                        variant="default"
                        className="w-full sm:flex-1 h-12 rounded-xl font-semibold min-h-[44px]"
                        onClick={onClose}
                        disabled={isSubmitting}
                    >
                        Cancelar
                    </Button>
                    <Button
                        className="w-full sm:flex-1 h-12 rounded-xl bg-primary hover:bg-primary/90 text-primary-foreground font-semibold border-none min-h-[44px]"
                        onClick={handleConfirm}
                        disabled={isSubmitting || !selectedId}
                    >
                        {isSubmitting ? <RefreshCw className="w-4 h-4 animate-spin mr-2" /> : null}
                        {isConsultation ? "Falar com Consultor" : "Confirmar alteração"}
                    </Button>
                </div>
            </DialogContent>
        </Dialog>
    );
}
