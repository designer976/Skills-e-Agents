import { useState } from "react";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Checkbox } from "@/components/ui/checkbox";
import { BookingService } from "@/types/booking-new";
import { cn } from "@/lib/utils";
import { Trash2 } from "lucide-react";
import { BookingServiceRecommendations } from "@/components/booking/BookingServiceRecommendations";

interface NewServiceSelectionProps {
  services: BookingService[];
  selectedServices: BookingService[];
  primaryColor: string;
  salonSlug: string;
  onAddService: (service: BookingService) => void;
  onRemoveService: (serviceId: string) => void;
  onNext: () => void;
  onBack: () => void;
}

export function NewServiceSelection({
  services,
  selectedServices,
  primaryColor,
  salonSlug,
  onAddService,
  onRemoveService,
  onNext,
  onBack,
}: NewServiceSelectionProps) {
  // Filtrar apenas serviços com profissionais disponíveis ou que sejam de solicitação (requestOnly)
  const [availableServices] = useState(() => services);

  // Agrupar serviços por categoria e filtrar categorias vazias
  const servicesByCategory = availableServices.reduce((acc, service) => {
    if (!acc[service.category]) {
      acc[service.category] = [];
    }
    acc[service.category].push(service);
    return acc;
  }, {} as Record<string, BookingService[]>);

  // Filtrar categorias que ficaram sem serviços válidos
  const categoriesWithServices = Object.entries(servicesByCategory).filter(
    ([_, categoryServices]) => categoryServices.length > 0
  );

  const isServiceSelected = (serviceId: string) => {
    return selectedServices.some((s) => s.id === serviceId);
  };

  const isServiceDisabled = (serviceId: string) => {
    const services = categoriesWithServices
      .map(([_, categoryServices]) => categoryServices)
      .flat();

    const service = services.find((s) => s.id === serviceId);

    return (
      !service ||
      (service?.professionals?.length === 0 && !service?.isRequestOnly) ||
      service.duration === 0
    );
  };

  const handleServiceToggle = (service: BookingService) => {
    if (isServiceSelected(service.id)) {
      onRemoveService(service.id);
    } else {
      onAddService(service);
    }
  };

  const getTotalPrice = () => {
    return selectedServices.reduce(
      (total, service) => total + service.price,
      0
    );
  };

  const getTotalDuration = () => {
    return selectedServices.reduce(
      (total, service) => total + service.duration,
      0
    );
  };

  const handleAddRecommendations = (recommendedServices: BookingService[]): void => {
    recommendedServices.forEach((service) => {
      onAddService(service);
    });
  };

  const selectedServiceIds = selectedServices.map((s) => s.id);

  return (
    <div className="max-w-7xl mx-auto px-4 py-8">
      <div className="text-center mb-8">
        <h2 className="text-2xl font-bold text-gray-900 mb-2">
          Escolha os serviços
        </h2>
        <p className="text-gray-600">
          Selecione os serviços que deseja agendar
        </p>
      </div>

      <div className="grid lg:grid-cols-3 items-start gap-8 relative">
        {/* Lista de Serviços */}
        <div className="lg:col-span-2">
          <div className="space-y-6">
            {categoriesWithServices.length === 0 ? (
              <div className="text-center py-12">
                <p className="text-gray-500">
                  Nenhum serviço disponível para agendamento online no momento.
                </p>
                <p className="text-sm text-gray-400 mt-2">
                  Entre em contato com o salão para mais informações.
                </p>
              </div>
            ) : (
              categoriesWithServices.map(([category, categoryServices]) => (
                <div key={category}>
                  <h3 className="text-lg font-semibold text-gray-900 mb-3">
                    {category}
                  </h3>

                  <div className="space-y-2">
                    {categoryServices.map((service) => {
                      const isSelected = isServiceSelected(service.id);
                      const isDisabled = isServiceDisabled(service.id);


                      return (
                        <Card
                          key={service.id}
                          className={cn(
                            "cursor-pointer transition-all hover:shadow-md",
                            isSelected && "ring-2"
                          )}
                          style={{
                            ...(isSelected &&
                              !isDisabled && { borderColor: primaryColor }),
                            ...(isDisabled && {
                              opacity: 0.5,
                              cursor: "not-allowed",
                            }),
                          }}
                          onClick={() => {
                            if (!isDisabled) {
                              handleServiceToggle(service);
                            }
                          }}
                        >
                          <CardContent className="p-4">
                            <div className="flex items-center gap-3">
                              <Checkbox
                                disabled={
                                  service?.professionals?.length === 0 &&
                                  !service.isRequestOnly
                                }
                                checked={isSelected}
                                style={{
                                  backgroundColor: isSelected
                                    ? primaryColor
                                    : undefined,
                                  borderColor: isSelected
                                    ? primaryColor
                                    : undefined,
                                }}
                              />

                              <div className="flex-1">
                                <div className="flex items-center gap-2">
                                  <h4 className="font-medium text-gray-900">
                                    {service.name}
                                  </h4>
                                  {(service.isActive === false ||
                                    service.isRequestOnly) && (
                                      <span className="text-xs text-orange-600 bg-orange-100 px-2 py-1 rounded">
                                        Apenas Solicitação
                                      </span>
                                    )}
                                </div>
                                <div className="flex items-center gap-4 text-sm text-gray-600 mt-1">
                                  <span>{service.duration} min</span>
                                  <span>
                                    {service.priceType && service.priceType !== "Fixo"
                                      ? "A partir de "
                                      : ""}
                                    R$ {service.price.toFixed(2)}
                                  </span>
                                  {service.professionals &&
                                    service.professionals.length > 0 && (
                                      <span className="text-xs text-green-600">
                                        {service.professionals.length}{" "}
                                        profissiona
                                        {service.professionals.length === 1
                                          ? "l"
                                          : "is"}
                                      </span>
                                    )}

                                  {!service?.professionals ||
                                    (service?.professionals?.length === 0 &&
                                      !service.isRequestOnly && (
                                        <span className="text-xs text-red-600">
                                          Nenhum profissional
                                        </span>
                                      ))}
                                </div>
                                {service.isRequestOnly && (
                                  <p className="text-xs text-orange-600 mt-1">
                                    Este serviço estará sujeito a confirmação de
                                    disponibilidade
                                  </p>
                                )}
                              </div>
                            </div>
                          </CardContent>
                        </Card>
                      );
                    })}
                  </div>
                </div>
              ))
            )}
          </div>
        </div>

        {/* Resumo da Seleção */}
        <div className="lg:col-span-1 sticky top-0 space-y-4">
          <h3 className="text-lg font-semibold text-gray-900 mb-3 pt-4">
            Serviços Selecionados
          </h3>
          <Card className="">
            <CardContent className="px-4 py-4">
              {selectedServices.length === 0 ? (
                <p className="text-gray-500 text-center py-4">
                  Nenhum serviço selecionado
                </p>
              ) : (
                <div className="space-y-3">
                  {selectedServices.map((service) => (
                    <div
                      key={service.id}
                      className="flex items-center justify-between text-sm bg-gray-50 p-2 rounded"
                    >
                      <div className="flex-1">
                        <div className="flex items-center gap-2">
                          <div className="font-medium">{service.name}</div>
                          {(service.isActive === false ||
                            service.isRequestOnly) && (
                              <span className="text-xs text-orange-600 bg-orange-100 px-1 py-0.5 rounded">
                                Solicitação
                              </span>
                            )}
                        </div>
                        <div className="text-gray-600">
                          {service.duration} min •{" "}
                          {service.priceType && service.priceType !== "Fixo" ? "A partir de " : ""}R${" "}
                          {service.price.toFixed(2)}
                        </div>
                      </div>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={(e) => {
                          e.stopPropagation();
                          onRemoveService(service.id);
                        }}
                      >
                        <Trash2 className="h-4 w-4" />
                      </Button>
                    </div>
                  ))}

                  <hr className="my-3" />

                  <div className="space-y-2">
                    <div className="flex justify-between text-sm">
                      <span>Duração total:</span>
                      <span>{getTotalDuration()} min</span>
                    </div>
                    <div className="flex justify-between font-semibold">
                      <span>Total:</span>
                      <span>
                        {selectedServices.some((s) => s.priceType && s.priceType !== "Fixo")
                          ? "A partir de "
                          : ""}
                        R$ {getTotalPrice().toFixed(2)}
                      </span>
                    </div>
                  </div>
                </div>
              )}
            </CardContent>
          </Card>

          {/* Recomendações para o último serviço selecionado */}
          {selectedServices.length > 0 && (
            <BookingServiceRecommendations
              salonSlug={salonSlug}
              serviceId={selectedServices[selectedServices.length - 1].id}
              serviceName={selectedServices[selectedServices.length - 1].name}
              primaryColor={primaryColor}
              onAddRecommendations={handleAddRecommendations}
              selectedServiceIds={selectedServiceIds}
            />
          )}
        </div>

        {/* Navigation */}
        <div className="flex justify-between lg:col-span-2 mt-8">
          <Button variant="default" onClick={onBack}>
            Voltar
          </Button>

          <Button
            disabled={selectedServices.length === 0}
            style={{ backgroundColor: primaryColor }}
            className="text-white"
            onClick={onNext}
          >
            Continuar
          </Button>
        </div>
      </div>
    </div>
  );
}
