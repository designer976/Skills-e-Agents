import { useState } from "react";
import { useNavigate } from "react-router-dom";
import { EasySalonLayout } from "@/components/layout/EasySalonLayout";
import { PageHeader } from "@/components/layout/PageHeader";

import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import { Button } from "@/components/ui/button";
import {
  Tooltip,
  TooltipContent,
  TooltipProvider,
  TooltipTrigger,
} from "@/components/ui/tooltip";
import { getAdminNavItems } from "@/config/navigation";
import { useAuth } from "@/contexts/AuthContext";
import { Info as Info, Loader2 as Loader2 } from "lucide-react";
import { toast } from "sonner";
import { salonService } from "@/services/salonService";
import { CreateSalonDto } from "@/types/salon";
import { formatPhone, formatCNPJ, unformatCNPJ } from "@/utils/formatters";
import { cnpjService } from "@/services/cnpjService";
import { TimezoneCombobox } from "@/components/forms/TimezoneCombobox";
import { trackSeverinoEvent } from "@/services/severinoService";

interface SalonInfo {
  nomeFantasia: string;
  razaoSocial: string;
  cnpj: string;
  telefoneComercial: string;
  emailContato: string;
  nomeLinkUtil: string;
  urlLinkUtil: string;
  timezone: string;
}

export default function CreateSalonPage() {
  const { user } = useAuth();
  const navigate = useNavigate();
  const [isLoading, setIsLoading] = useState(false);
  const [isFetchingCNPJ, setIsFetchingCNPJ] = useState(false);
  const [salonInfo, setSalonInfo] = useState<SalonInfo>({
    nomeFantasia: "",
    razaoSocial: "",
    cnpj: "",
    telefoneComercial: "",
    emailContato: "",
    nomeLinkUtil: "",
    urlLinkUtil: "",
    timezone: "America/Sao_Paulo",
  });

  const handleSalonInfoChange = async (
    field: keyof SalonInfo,
    value: string
  ): Promise<void> => {
    if (field === "cnpj") {
      const formattedCNPJ = formatCNPJ(value);
      setSalonInfo((prev) => ({ ...prev, cnpj: formattedCNPJ }));

      // Verifica se o CNPJ está completo (14 dígitos)
      const cleanCNPJ = unformatCNPJ(formattedCNPJ);
      if (cleanCNPJ.length === 14 && !isFetchingCNPJ) {
        setIsFetchingCNPJ(true);
        try {
          const cnpjData = await cnpjService.fetchCompanyData(cleanCNPJ);
          if (cnpjData && cnpjData.razao_social) {
            setSalonInfo((prev) => ({
              ...prev,
              razaoSocial: cnpjData.razao_social || prev.razaoSocial,
              nomeFantasia:
                prev.nomeFantasia ||
                cnpjData.nome_fantasia ||
                cnpjData.razao_social ||
                "",
            }));
          }
        } catch (error) {
          // Silenciosamente ignora erros
        } finally {
          setIsFetchingCNPJ(false);
        }
      }
    } else {
      setSalonInfo((prev) => ({ ...prev, [field]: value }));
    }
  };

  const handleCreateSalon = async (): Promise<void> => {
    // Validação básica
    if (!salonInfo.nomeFantasia) {
      toast.error("Por favor, preencha o nome fantasia");
      return;
    }
    if (!salonInfo.telefoneComercial) {
      toast.error("Por favor, preencha o telefone");
      return;
    }

    // Validar CNPJ se fornecido
    if (salonInfo.cnpj && !salonService.validateCNPJ(salonInfo.cnpj)) {
      toast.error("CNPJ inválido");
      return;
    }

    setIsLoading(true);

    try {
      // Obter usuário atual do localStorage
      const userStr = localStorage.getItem("currentUser");
      const user = userStr ? JSON.parse(userStr) : null;

      // Preparar dados para criação
      const createData: CreateSalonDto = {
        name: salonInfo.nomeFantasia,
        slug: salonService.generateSlug(salonInfo.nomeFantasia),
        phone: salonService.formatPhone(salonInfo.telefoneComercial),
        email: salonInfo.emailContato || undefined,
        responsible: salonInfo.razaoSocial || undefined,
        cnpj: salonInfo.cnpj
          ? salonService.formatCNPJ(salonInfo.cnpj)
          : undefined,
        timezone: salonInfo.timezone,
        tenantId: user?.tenantId, // Usar tenantId do usuário se disponível
      };

      // Criar salão com rede
      const result = await salonService.createWithNetwork(createData);

      trackSeverinoEvent('cadastro_do_salao', {
        descricao: `Salão cadastrado: ${salonInfo.nomeFantasia} (ID: ${result.salon.id})`,
        nomeSalao: salonInfo.nomeFantasia,
        salonId: result.salon.id,
      });

      toast.success("Salão cadastrado com sucesso e adicionado à sua rede!");

      // Redirecionar para a lista de salões
      navigate("/admin/salons");
    } catch (error: any) {
      const errorMessage =
        error?.response?.data?.message || "Erro ao criar salão";
      toast.error(errorMessage);
    } finally {
      setIsLoading(false);
    }
  };

  return (
    <EasySalonLayout
      sideNavItems={getAdminNavItems(user?.role || "Easy Salon")}
      sideNavTitle="Easy Salon"
      sideNavSubtitle="Área Administrativa"
    >
      <PageHeader
        title="Cadastrar Novo Salão"
        subtitle="Crie um novo salão na plataforma"
      />

      <div className="bg-card border border-border rounded-3xl">
        <div className="p-6">
          <div className="space-y-6">
            <TooltipProvider>
              <div className="space-y-2">
                <Label htmlFor="nomeFantasia">
                  Nome Fantasia (como seus clientes o conhecem) *
                </Label>
                <Input
                  id="nomeFantasia"
                  value={salonInfo.nomeFantasia}
                  onChange={(e) =>
                    handleSalonInfoChange("nomeFantasia", e.target.value)
                  }
                  placeholder="Nome do seu salão"
                  maxLength={100}
                />
                <div className="flex items-center gap-2 text-xs text-muted-foreground">
                  <span>Esse nome será usado na URL pública do salão</span>
                  <Tooltip>
                    <TooltipTrigger asChild>
                      <Info className="w-4 h-4 cursor-help" />
                    </TooltipTrigger>
                    <TooltipContent>
                      <p>A URL pública do seu salão será:</p>
                      <p className="font-mono">
                        https://app.easysalon.com.br/
                        {salonService.generateSlug(salonInfo.nomeFantasia) ||
                          "nome-salao-nesse-formato"}
                      </p>
                    </TooltipContent>
                  </Tooltip>
                </div>
              </div>
            </TooltipProvider>

            <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div className="space-y-2">
                <Label htmlFor="cnpj">CNPJ</Label>
                <div className="relative">
                  <Input
                    id="cnpj"
                    value={salonInfo.cnpj}
                    onChange={(e) =>
                      handleSalonInfoChange("cnpj", e.target.value)
                    }
                    placeholder="XX.XXX.XXX/XXXX-XX"
                    maxLength={18}
                  />
                  {isFetchingCNPJ && (
                    <div className="absolute right-2 top-1/2 -translate-y-1/2">
                      <Loader2 className="h-4 w-4 animate-spin text-muted-foreground" />
                    </div>
                  )}
                </div>
              </div>

              <div className="space-y-2">
                <Label htmlFor="razaoSocial">Razão Social</Label>
                <Input
                  id="razaoSocial"
                  value={salonInfo.razaoSocial}
                  onChange={(e) =>
                    handleSalonInfoChange("razaoSocial", e.target.value)
                  }
                  placeholder="Razão social da empresa"
                  maxLength={150}
                />
              </div>
            </div>

            <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div className="space-y-2">
                <Label htmlFor="telefoneComercial">Telefone/WhatsApp *</Label>
                <Input
                  id="telefoneComercial"
                  value={salonInfo.telefoneComercial}
                  onChange={(e) =>
                    handleSalonInfoChange(
                      "telefoneComercial",
                      formatPhone(e.target.value)
                    )
                  }
                  placeholder="(XX) XXXXX-XXXX"
                  maxLength={15}
                />
              </div>

              <div className="space-y-2">
                <Label htmlFor="emailContato">E-mail de Contato</Label>
                <Input
                  id="emailContato"
                  type="email"
                  value={salonInfo.emailContato}
                  onChange={(e) =>
                    handleSalonInfoChange("emailContato", e.target.value)
                  }
                  placeholder="contato@seusalao.com"
                  maxLength={100}
                />
              </div>
            </div>

            <div className="space-y-2">
              <div className="flex items-center gap-2">
                <Label htmlFor="timezone">Localidade *</Label>
                <TooltipProvider>
                  <Tooltip>
                    <TooltipTrigger asChild>
                      <Info className="h-4 w-4 text-muted-foreground cursor-help" />
                    </TooltipTrigger>
                    <TooltipContent>
                      <p className="max-w-xs">
                        Selecione a localidade do seu salão. Isso garante que os
                        horários de agendamento sejam exibidos corretamente para
                        clientes em qualquer parte do mundo.
                      </p>
                    </TooltipContent>
                  </Tooltip>
                </TooltipProvider>
              </div>
              <TimezoneCombobox
                value={salonInfo.timezone}
                onValueChange={(value) =>
                  handleSalonInfoChange("timezone", value)
                }
              />
            </div>

            <div className="space-y-4">
              <Label className="text-lg font-semibold">
                Link útil (Ex: Site)
              </Label>
              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div className="space-y-2">
                  <Label htmlFor="nomeLinkUtil">Nome do link</Label>
                  <Input
                    id="nomeLinkUtil"
                    value={salonInfo.nomeLinkUtil}
                    onChange={(e) =>
                      handleSalonInfoChange("nomeLinkUtil", e.target.value)
                    }
                    placeholder="Site, Instagram, Facebook..."
                    maxLength={50}
                  />
                </div>

                <div className="space-y-2">
                  <Label htmlFor="urlLinkUtil">URL</Label>
                  <Input
                    id="urlLinkUtil"
                    value={salonInfo.urlLinkUtil}
                    onChange={(e) =>
                      handleSalonInfoChange("urlLinkUtil", e.target.value)
                    }
                    placeholder="https://seusite.com"
                    maxLength={200}
                  />
                </div>
              </div>
            </div>
          </div>

          <div className="flex justify-end mt-8 pt-6 border-t">
            <Button
              onClick={handleCreateSalon}
              disabled={isLoading}
              className="bg-[#dd4227] hover:bg-[#c73a22] text-white px-8"
            >
              {isLoading ? (
                <>
                  <Loader2 className="mr-2 h-4 w-4 animate-spin" />
                  Criando...
                </>
              ) : (
                "Criar Salão"
              )}
            </Button>
          </div>
        </div>
      </div>
    </EasySalonLayout>
  );
}
