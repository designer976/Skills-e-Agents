import { Button } from '@/components/ui/button';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { IconCircleCheck as CheckCircle, IconCalendar as Calendar, IconClock as Clock, IconUser as User, IconPhone as Phone, IconMail as Mail, IconMapPin as MapPin } from "@tabler/icons-react";
import { BookingData, SalonBranding } from '@/types/booking';
import { format } from 'date-fns';
import { ptBR } from 'date-fns/locale';

interface BookingConfirmationProps {
  bookingData: BookingData;
  salon: SalonBranding;
  primaryColor: string;
  onNewBooking: () => void;
}

export function BookingConfirmation({
  bookingData,
  salon,
  primaryColor,
  onNewBooking,
}: BookingConfirmationProps) {
  const getTotalPrice = () => {
    return bookingData.services.reduce((total, service) => total + service.price, 0);
  };

  const getTotalDuration = () => {
    return bookingData.services.reduce((total, service) => total + service.duration, 0);
  };

  const generateCalendarEvent = () => {
    const startDate = new Date(`${bookingData.date}T${bookingData.time}`);
    const endDate = new Date(startDate.getTime() + getTotalDuration() * 60000);
    
    const title = encodeURIComponent(`Agendamento - ${salon.name}`);
    const details = encodeURIComponent(
      `Serviços: ${bookingData.services.map(s => s.name).join(', ')}\n` +
      `Profissional: ${bookingData.professional?.name || 'A definir'}\n` +
      `Local: ${salon.address}`
    );
    
    const startTime = startDate.toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
    const endTime = endDate.toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
    
    return `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${title}&dates=${startTime}/${endTime}&details=${details}&location=${encodeURIComponent(salon.address)}`;
  };

  return (
    <div className="max-w-2xl mx-auto px-4 py-8">
      <div className="text-center mb-8">
        <div 
          className="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4"
          style={{ backgroundColor: primaryColor }}
        >
          <CheckCircle className="w-8 h-8 text-white" />
        </div>
        
        <h2 className="text-2xl font-bold text-gray-900 mb-2">
          Agendamento Confirmado!
        </h2>
        <p className="text-gray-600">
          Seu agendamento foi registrado com sucesso
        </p>
      </div>

      {/* Resumo do Agendamento */}
      <Card className="mb-6">
        <CardHeader>
          <CardTitle>Detalhes do Agendamento</CardTitle>
        </CardHeader>
        <CardContent className="space-y-4">
          {/* Data e Hora */}
          <div className="flex items-center gap-3">
            <Calendar className="h-5 w-5 text-gray-600" />
            <div>
              <span className="font-medium">
                {bookingData.date && format(new Date(bookingData.date), "EEEE, dd 'de' MMMM 'de' yyyy", { locale: ptBR })}
              </span>
            </div>
          </div>

          <div className="flex items-center gap-3">
            <Clock className="h-5 w-5 text-gray-600" />
            <div>
              <span className="font-medium">{bookingData.time}</span>
              <span className="text-gray-600 ml-2">
                ({getTotalDuration()} minutos)
              </span>
            </div>
          </div>

          {/* Profissional */}
          <div className="flex items-center gap-3">
            <User className="h-5 w-5 text-gray-600" />
            <div>
              <span className="font-medium">
                {bookingData.professional?.name || 'Qualquer Profissional'}
              </span>
            </div>
          </div>

          {/* Serviços */}
          <div>
            <h4 className="font-medium mb-2">Serviços:</h4>
            <div className="space-y-2">
              {bookingData.services.map((service) => (
                <div key={service.id} className="flex justify-between text-sm bg-gray-50 p-2 rounded">
                  <span>{service.name}</span>
                  <span>R$ {service.price.toFixed(2)}</span>
                </div>
              ))}
              <div className="flex justify-between font-semibold pt-2 border-t">
                <span>Total:</span>
                <span>R$ {getTotalPrice().toFixed(2)}</span>
              </div>
            </div>
          </div>
        </CardContent>
      </Card>

      {/* Dados do Cliente */}
      <Card className="mb-6">
        <CardHeader>
          <CardTitle>Seus Dados</CardTitle>
        </CardHeader>
        <CardContent className="space-y-3">
          <div className="flex items-center gap-3">
            <User className="h-5 w-5 text-gray-600" />
            <span>{bookingData.customerName}</span>
          </div>
          
          <div className="flex items-center gap-3">
            <Mail className="h-5 w-5 text-gray-600" />
            <span>{bookingData.customerEmail || 'Não informado'}</span>
          </div>
          
          <div className="flex items-center gap-3">
            <Phone className="h-5 w-5 text-gray-600" />
            <span>{bookingData.customerPhone}</span>
          </div>
        </CardContent>
      </Card>

      {/* Informações do Salão */}
      <Card className="mb-8">
        <CardHeader>
          <CardTitle>Local do Atendimento</CardTitle>
        </CardHeader>
        <CardContent className="space-y-3">
          <div className="flex items-center gap-3">
            <MapPin className="h-5 w-5 text-gray-600" />
            <div>
              <div className="font-medium">{salon.name}</div>
              <div className="text-gray-600">{salon.address}</div>
              <div className="text-gray-600">{salon.phone}</div>
            </div>
          </div>
        </CardContent>
      </Card>

      {/* Ações */}
      <div className="flex flex-col sm:flex-row gap-3">
        <Button
          variant="outline"
          className="flex-1"
          onClick={() => window.open(generateCalendarEvent(), '_blank')}
        >
          <Calendar className="w-4 h-4 mr-2" />
          Adicionar ao Calendário
        </Button>
        
        <Button
          className="flex-1 text-white"
          style={{ backgroundColor: primaryColor }}
          onClick={onNewBooking}
        >
          Fazer Novo Agendamento
        </Button>
      </div>
    </div>
  );
}