import {
    Dialog,
    DialogContent,
    DialogClose,
} from "@/components/ui/dialog";
import { MessagesSquare as MessageSquareText, X as X } from "lucide-react";
import { useNavigate } from "react-router-dom";
import easySalonLogo from "@/assets/easy-logo.svg";
import { useSelectedSalon } from "@/hooks/useSelectedSalon";

interface PlanActivationSuccessModalProps {
    isOpen: boolean;
    onClose: () => void;
    planName: string;
}

export function PlanActivationSuccessModal({ isOpen, onClose, planName }: PlanActivationSuccessModalProps) {
    const navigate = useNavigate();
    const { selectedSalon } = useSelectedSalon();

    const handleWhatsAppIA = () => {
        const phone = import.meta.env.VITE_WHATSAPP_IA || "554192938071";
        if (!phone) return;

        const salonName = selectedSalon?.name || "Meu Salão";
        const salonPhone = selectedSalon?.phone || "";
        const message = `Olá, sou do salão ${salonName} ${salonPhone ? `${salonPhone} ` : ""}e gostaria de marcar um agendamento`;

        window.open(`https://wa.me/${phone}?text=${encodeURIComponent(message)}`, "_blank");
    };

    const handleGoToAgenda = () => {
        onClose();
        navigate("/salon/agenda");
    };

    return (
        <Dialog open={isOpen} onOpenChange={(open) => !open && onClose()}>
            <DialogContent className="sm:max-w-[520px] p-0 overflow-hidden border-none bg-transparent shadow-none [&>button]:hidden" onInteractOutside={(e) => e.preventDefault()}>
                <div className="relative w-full overflow-hidden bg-[#EFE9DD] rounded-3xl shadow-2xl animate-in fade-in zoom-in slide-in-from-bottom-12 duration-1000">

                    {/* Custom Close Button */}
                    <DialogClose className="absolute right-5 top-5 sm:right-8 sm:top-8 z-50 rounded-full p-2 text-[#C74634]/60 hover:text-[#C74634] hover:bg-white/40 transition-all duration-300 backdrop-blur-sm outline-none">
                        <X className="h-5 w-5 sm:h-6 sm:w-6" />
                        <span className="sr-only">Fechar</span>
                    </DialogClose>

                    {/* Hero Section */}
                    <div className="relative pt-10 pb-6 px-6 sm:pt-16 sm:pb-8 sm:px-12 text-center overflow-hidden">
                        <div className="absolute top-0 left-1/2 -translate-x-1/2 w-[140%] h-[400px] bg-[#EADDC6] opacity-30 blur-[100px] rounded-full -translate-y-1/2" />

                        <div className="relative z-10 flex flex-col items-center">
                            {/* Brand Logo Header */}
                            <div className="mb-6 sm:mb-8 animate-in fade-in slide-in-from-top-4 duration-1000 delay-300">
                                <div className="p-1.5 bg-white/40 rounded-2xl backdrop-blur-sm border border-white/20 shadow-sm">
                                    <img
                                        src={easySalonLogo}
                                        alt="Easy Salon Logo"
                                        className="h-8 sm:h-10 w-auto object-contain"
                                    />
                                </div>
                            </div>

                            <h2 className="text-[#C74634] text-2xl sm:text-3xl md:text-4xl font-bold leading-tight mb-4 sm:mb-6 tracking-tight">
                                Parabéns! <br /> A nova era da sua gestão começa agora
                            </h2>

                            <p className="text-[#5A5247] text-sm sm:text-base font-medium opacity-90 max-w-md leading-relaxed">
                                O <span className="text-[#C74634] font-bold">{planName}</span> está ativo. Suas ferramentas de gestão e automação já estão rodando.
                            </p>
                        </div>
                    </div>

                    {/* CTA Section */}
                    <div className="px-6 pb-4 sm:px-12 sm:pb-6 flex flex-col gap-3">
                        <button
                            onClick={handleWhatsAppIA}
                            className="inline-flex items-center justify-center gap-2 w-full rounded-xl text-base font-semibold transition-all cursor-pointer bg-primary hover:bg-primary/90 text-primary-foreground h-11 px-5 py-2.5 active:scale-[0.98]"
                            style={{ boxShadow: 'rgba(199, 70, 52, 0.3) 0px 12px 20px 0px' }}
                        >
                            <MessageSquareText className="h-5 w-5" />
                            Testar minha IA no WhatsApp
                        </button>

                        <button
                            onClick={handleGoToAgenda}
                            className="inline-flex items-center justify-center w-full rounded-xl text-sm font-medium transition-all cursor-pointer bg-transparent hover:bg-[#EADDC6]/60 text-[#5A5247] h-11 px-4 py-2"
                        >
                            Ir para a Agenda
                        </button>
                    </div>

                    {/* Footer */}
                    <div className="px-6 pb-6 sm:px-12 sm:pb-10 flex flex-col items-center">
                        <div className="flex items-center gap-4 select-none">
                            <div className="h-[1px] w-10 bg-[#AC9671]/30" />
                            <span className="text-[11px] font-bold text-[#AC9671] tracking-[0.3em] uppercase opacity-90">
                                Bem-vindo à nova era
                            </span>
                            <div className="h-[1px] w-10 bg-[#AC9671]/30" />
                        </div>
                    </div>
                </div>
            </DialogContent>
        </Dialog>
    );
}
