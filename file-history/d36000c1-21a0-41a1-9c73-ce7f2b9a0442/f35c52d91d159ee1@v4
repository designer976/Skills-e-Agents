
import { Button } from "@/components/ui/button";
import {
    Dialog,
    DialogContent,
    DialogHeader,
    DialogTitle,
} from "@/components/ui/dialog";
import { Checkbox } from "@/components/ui/checkbox";
import { Loader2 as Loader2 } from "lucide-react";
import { useState } from "react";

interface CancelSubscriptionModalProps {
    isOpen: boolean;
    onClose: () => void;
    onConfirm: () => Promise<void>;
}

export function CancelSubscriptionModal({ isOpen, onClose, onConfirm }: CancelSubscriptionModalProps) {
    const [isChecked, setIsChecked] = useState(false);
    const [isSubmitting, setIsSubmitting] = useState(false);

    const handleConfirm = async () => {
        setIsSubmitting(true);
        try {
            await onConfirm();
            onClose();
        } finally {
            setIsSubmitting(false);
        }
    };

    return (
        <Dialog open={isOpen} onOpenChange={(open) => !open && !isSubmitting && onClose()}>
            <DialogContent className="w-[95vw] md:max-w-[500px] max-h-[90vh] md:max-h-[85vh] p-0 gap-0 rounded-xl md:rounded-lg border-none shadow-2xl overflow-hidden flex flex-col">
                <DialogHeader className="sticky top-0 z-10 bg-background px-4 pt-4 pb-3 border-b shrink-0 text-left">
                    <DialogTitle className="text-xl font-bold">Cancelar assinatura</DialogTitle>
                    <p className="text-sm text-muted-foreground mt-2">
                        Ao cancelar, você terá acesso ao sistema até o final do período pago.
                        Após isso, seu acesso será suspenso.
                    </p>
                </DialogHeader>

                <div className="flex-1 overflow-y-auto px-4 py-4 custom-scrollbar">
                    <div className="flex items-start space-x-3 p-4 bg-muted/30 rounded-lg border border-border">
                        <Checkbox
                            id="terms"
                            checked={isChecked}
                            onCheckedChange={(checked) => setIsChecked(checked === true)}
                            className="mt-1"
                        />
                        <div className="grid gap-1.5 leading-none">
                            <label
                                htmlFor="terms"
                                className="text-sm font-medium leading-normal peer-disabled:cursor-not-allowed peer-disabled:opacity-70 cursor-pointer"
                            >
                                Entendo que ao cancelar perderei acesso a todas as funcionalidades do sistema após o período pago.
                            </label>
                        </div>
                    </div>
                </div>

                <div className="sticky bottom-0 z-10 bg-background px-4 pt-3 pb-4 border-t shrink-0 flex flex-col-reverse sm:flex-row sm:justify-end gap-2 sm:gap-3">
                    <Button
                        variant="outline"
                        className="w-full sm:flex-1 h-12 rounded-xl text-foreground font-semibold min-h-[44px]"
                        onClick={onClose}
                        disabled={isSubmitting}
                    >
                        Voltar
                    </Button>
                    <Button
                        variant="destructive"
                        className="w-full sm:flex-1 h-12 rounded-xl font-semibold min-h-[44px]"
                        onClick={handleConfirm}
                        disabled={!isChecked || isSubmitting}
                    >
                        {isSubmitting ? <Loader2 className="w-4 h-4 animate-spin mr-2" /> : null}
                        Confirmar cancelamento
                    </Button>
                </div>
            </DialogContent>
        </Dialog>
    );
}
