import { TimeSlot } from "./types";

interface TimeGridProps {
  timeSlots: TimeSlot[];
  slotHeight: number;
  currentTimePosition?: number;
}

export const TimeGrid: React.FC<TimeGridProps> = ({
  timeSlots,
  slotHeight,
  currentTimePosition,
}) => {
  return (
    <div className="flex-shrink-0 flex flex-col w-20 border-r border-gray-200 bg-gray-50 relative sticky left-0 z-20">
      <div className="sticky top-0 z-20 h-16 border-b border-gray-200 bg-gray-50 flex-shrink-0" />
      <div className="relative">
        {timeSlots.map((slot, index) => (
          <div
            key={`${slot.hour}-${slot.minute}`}
            className="border-b border-gray-200 flex items-start justify-end pr-2 pt-1"
            style={{ height: `${slotHeight}px` }}
            data-time-slot={slot.label}
          >
            <span className="text-xs text-gray-600 font-medium">
              {slot.label}
            </span>
          </div>
        ))}
      </div>
      {currentTimePosition !== undefined && (
        <div
          className="absolute left-0 right-0 border-t-2 border-red-500 pointer-events-none"
          style={{
            top: `${currentTimePosition + 64}px`,
            minWidth: "calc(100vw - 330px)",
            zIndex: 15,
          }}
        >
          <div className="absolute -left-1 -top-1 w-2 h-2 bg-red-500 rounded-full" />
        </div>
      )}
    </div>
  );
};
