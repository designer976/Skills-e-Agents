import { useState, useRef } from "react";
import {
  Dialog,
  DialogContent,
  DialogDescription,
  DialogHeader,
  DialogTitle,
  DialogFooter,
} from "@/components/ui/dialog";
import { Tabs, TabsContent, TabsList, TabsTrigger } from "@/components/ui/tabs";
import { Button } from "@/components/ui/button";
import { ServicePricingForm } from "@/components/forms/ServicePricingForm";
import { ServiceRecommendationsManager } from "@/components/services/ServiceRecommendationsManager";
import { useSelectedSalon } from "@/hooks/useSelectedSalon";

export interface ServicePricingData {
  duration: string;
  priceType: string;
  grossValue: string;
  maxValue?: string;
  adminFeeFixed: string;
  adminFeePercent: string;
  supplies: string;
  netValue: string;
  commissionFixed: string;
  commissionPercent: string;
}

export interface ServicePricingInput {
  id: string;
  specialty: string;
  name?: string;
  service: string;
  duration?: string;
  priceType?: string;
  grossValue?: string;
  maxValue?: string;
  adminFeeFixed?: string;
  adminFeePercent?: string;
  supplies?: string;
  netValue?: string;
  commissionFixed?: string;
  commissionPercent?: string;
}

interface ServicePricingModalProps {
  isOpen: boolean;
  onClose: () => void;
  service?: ServicePricingInput;
  onSave: (data: ServicePricingData) => void;
}

export function ServicePricingModal({
  isOpen,
  onClose,
  service,
  onSave,
}: ServicePricingModalProps) {
  const [activeTab, setActiveTab] = useState("pricing");
  const isEditing = !!service;
  const { selectedSalon } = useSelectedSalon();
  const formRef = useRef<HTMLFormElement>(null);

  const handleCancel = (): void => {
    onClose();
    setActiveTab("pricing");
  };

  const initialData = service
    ? {
        ...service,
        duration: service.duration || "00:30",
        priceType: service.priceType || "Fixo",
        grossValue: service.grossValue || "",
        adminFeeFixed: service.adminFeeFixed || "",
        adminFeePercent: service.adminFeePercent || "",
        supplies: service.supplies || "",
        netValue: service.netValue || "",
        commissionFixed: service.commissionFixed || "",
        commissionPercent: service.commissionPercent || "",
      }
    : undefined;

  return (
    <Dialog open={isOpen} onOpenChange={(open) => {
      if (!open) {
        handleCancel();
      }
    }}>
      <DialogContent className="w-[95vw] md:max-w-[900px] max-h-[85vh] rounded-lg flex flex-col overflow-hidden p-0">
        <DialogHeader className="px-6 pt-6 pb-3 border-b shrink-0">
          <DialogTitle>Configurações do Serviço</DialogTitle>
          {(service?.service || service?.name || service?.specialty) && (
            <DialogDescription>
              {service?.service || service?.name}
              {service?.specialty ? ` · ${service.specialty}` : ""}
            </DialogDescription>
          )}
        </DialogHeader>

        <Tabs value={activeTab} onValueChange={setActiveTab} className="flex-1 flex flex-col min-h-0">
          <div className="px-6 pt-3 shrink-0">
            <TabsList className="grid w-full grid-cols-2">
              <TabsTrigger value="pricing">Precificação</TabsTrigger>
              <TabsTrigger value="recommendations">Recomendações</TabsTrigger>
            </TabsList>
          </div>

          <div className="flex-1 overflow-y-auto">
            <TabsContent value="pricing" className="mt-0">
              <ServicePricingForm
                formRef={formRef}
                initialData={initialData}
                onSave={onSave}
              />
            </TabsContent>

            <TabsContent value="recommendations" className="mt-0 p-6">
              {service?.id ? (
                <ServiceRecommendationsManager
                  serviceId={service.id}
                  serviceName={service?.service || service?.name || ""}
                />
              ) : (
                <div className="text-center py-8 text-muted-foreground">
                  <p>Salve o serviço primeiro para configurar recomendações</p>
                </div>
              )}
            </TabsContent>
          </div>
        </Tabs>

        <DialogFooter className="px-6 pt-6 pb-6 border-t shrink-0">
          <Button variant="outline" onClick={handleCancel}>Cancelar</Button>
          {activeTab === "pricing" && (
            <Button
              type="button"
              onClick={() => formRef.current?.requestSubmit()}
              disabled={!selectedSalon?.active}
            >
              {isEditing ? "Salvar Alterações" : "Definir Precificação"}
            </Button>
          )}
        </DialogFooter>
      </DialogContent>
    </Dialog>
  );
}
