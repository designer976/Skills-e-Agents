import { Button } from "@/components/ui/button";
import { Card, CardContent } from "@/components/ui/card";
import { PaymentMethod } from "@/types/subscription";
import { CreditCard, Trash2 } from "lucide-react";
import { useState } from "react";
import { SecureCardInput } from "./SecureCardInput";
import { ReplaceCardModal } from "@/components/modals/ReplaceCardModal";

export interface TokenizedCardData {
    token: string;
    brand: string;
    last4: string;
    holderName: string;
    expirationDate: string;
}

interface PaymentMethodCardProps {
    paymentMethod: PaymentMethod | null;
    onSave: (data: TokenizedCardData) => Promise<void>;
    onDelete?: (id: string) => void;
}

export function PaymentMethodCard({ paymentMethod, onSave, onDelete }: PaymentMethodCardProps) {
    const [isReplaceModalOpen, setIsReplaceModalOpen] = useState(false);

    const handleTokenHtml = async (token: string, brand: string, last4: string, holder: string, exp: string) => {
        try {
            await onSave({
                token,
                brand,
                last4,
                holderName: holder,
                expirationDate: exp
            });
        } catch (error) {
            console.error(error);
        }
    };

    const handleModalSave = async (data: TokenizedCardData) => {
        await onSave(data);
    };

    return (
        <div className="space-y-4">
            <h2 className="text-xl font-semibold text-foreground">Forma de Pagamento</h2>

            <div className="bg-card border border-[#dd4227] bg-[#dd4227]/5 rounded-lg p-6 border-[rgba(222,222,222,1)]">
                {paymentMethod ? (
                    <div className="flex items-center justify-between">
                        <div className="flex items-center gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" className="tabler-icon tabler-icon-credit-card w-8 h-8 text-[#dd4227]">
                                <path d="M3 8a3 3 0 0 1 3 -3h12a3 3 0 0 1 3 3v8a3 3 0 0 1 -3 3h-12a3 3 0 0 1 -3 -3l0 -8"></path>
                                <path d="M3 10l18 0"></path>
                                <path d="M7 15l.01 0"></path>
                                <path d="M11 15l2 0"></path>
                            </svg>
                            <div>
                                <p className="text-sm font-medium text-foreground">
                                    {paymentMethod.brand} •••• {paymentMethod.last4}
                                </p>
                                <p className="text-xs text-muted-foreground">
                                    {paymentMethod.expirationDate ? `Expira em ${paymentMethod.expirationDate}` : paymentMethod.holderName}
                                </p>
                            </div>
                        </div>
                        <div className="ml-auto flex items-center gap-2">
                            <Button
                                variant="default"
                                size="sm"
                                className="transition-all cursor-pointer shadow-xs h-8 rounded-md gap-1.5 px-3"
                                onClick={() => setIsReplaceModalOpen(true)}
                            >
                                Alterar
                            </Button>
                            {onDelete && (
                                <Button
                                    variant="ghost"
                                    size="sm"
                                    className="inline-flex items-center justify-center whitespace-nowrap text-sm font-medium transition-all cursor-pointer disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg:not([class*='size-'])]:size-4 shrink-0 [&_svg]:shrink-0 outline-none focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px] aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive dark:hover:bg-accent/50 h-8 rounded-md gap-1.5 px-3 has-[>svg]:px-2.5 text-red-500 hover:text-red-600 hover:bg-red-50 shadow-none border-none"
                                    onClick={() => onDelete(paymentMethod.id)}
                                >
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" className="tabler-icon tabler-icon-trash w-4 h-4 text-red-600">
                                        <path d="M4 7l16 0"></path>
                                        <path d="M10 11l0 6"></path>
                                        <path d="M14 11l0 6"></path>
                                        <path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12"></path>
                                        <path d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3"></path>
                                    </svg>
                                </Button>
                            )}
                        </div>
                    </div>
                ) : (
                    <div className="space-y-6">
                        <div className="flex items-center gap-3 p-4 bg-yellow-50 text-yellow-800 rounded-lg border border-yellow-200">
                            <CreditCard className="h-5 w-5" />
                            <div>
                                <p className="font-medium text-sm">Nenhum cartão cadastrado</p>
                                <p className="text-xs opacity-90">Cadastre um cartão para assinar um plano.</p>
                            </div>
                        </div>

                        <SecureCardInput
                            onTokenHtml={handleTokenHtml}
                            onCancel={() => { }} // No cancel needed for first card
                            loading={false}
                        />
                    </div>
                )}

                <ReplaceCardModal
                    isOpen={isReplaceModalOpen}
                    onClose={() => setIsReplaceModalOpen(false)}
                    onSave={handleModalSave}
                />
            </div>
        </div>
    );
}
