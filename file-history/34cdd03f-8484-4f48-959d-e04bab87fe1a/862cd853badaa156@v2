import { Alert, AlertDescription, AlertTitle } from "@/components/ui/alert";
import { Button } from "@/components/ui/button";
import { PaymentMethod } from "@/types/subscription";
import { CreditCard, Trash2 } from "lucide-react";
import { useState } from "react";
import { SecureCardInput } from "./SecureCardInput";
import { ReplaceCardModal } from "@/components/modals/ReplaceCardModal";

export interface TokenizedCardData {
    token: string;
    brand: string;
    last4: string;
    holderName: string;
    expirationDate: string;
}

interface PaymentMethodCardProps {
    paymentMethod: PaymentMethod | null;
    onSave: (data: TokenizedCardData) => Promise<void>;
    onDelete?: (id: string) => void;
}

export function PaymentMethodCard({ paymentMethod, onSave, onDelete }: PaymentMethodCardProps) {
    const [isReplaceModalOpen, setIsReplaceModalOpen] = useState(false);

    const handleTokenHtml = async (token: string, brand: string, last4: string, holder: string, exp: string) => {
        try {
            await onSave({
                token,
                brand,
                last4,
                holderName: holder,
                expirationDate: exp
            });
        } catch (error) {
            console.error(error);
        }
    };

    const handleModalSave = async (data: TokenizedCardData) => {
        await onSave(data);
    };

    return (
        <div className="space-y-4">
            <h2 className="text-[13px] font-semibold text-foreground">Forma de Pagamento</h2>

            <div className="bg-card border border-border rounded-lg p-6">
                {paymentMethod ? (
                    <div className="flex items-center justify-between">
                        <div className="flex items-center gap-3">
                            <CreditCard className="w-8 h-8 text-primary" />
                            <div>
                                <p className="text-[13px] font-medium text-foreground">
                                    {paymentMethod.brand} •••• {paymentMethod.last4}
                                </p>
                                <p className="text-xs text-muted-foreground">
                                    {paymentMethod.expirationDate ? `Expira em ${paymentMethod.expirationDate}` : paymentMethod.holderName}
                                </p>
                            </div>
                        </div>
                        <div className="ml-auto flex items-center gap-2">
                            <Button
                                variant="outline"
                                size="sm"
                                onClick={() => setIsReplaceModalOpen(true)}
                            >
                                Alterar
                            </Button>
                            {onDelete && (
                                <Button
                                    variant="ghost"
                                    size="sm"
                                    className="text-destructive hover:text-destructive hover:bg-destructive/10"
                                    onClick={() => onDelete(paymentMethod.id)}
                                    aria-label="Remover cartão"
                                >
                                    <Trash2 className="h-4 w-4" aria-hidden="true" />
                                </Button>
                            )}
                        </div>
                    </div>
                ) : (
                    <div className="space-y-6">
                        <Alert variant="warning">
                            <CreditCard className="h-4 w-4" />
                            <AlertTitle>Nenhum cartão cadastrado</AlertTitle>
                            <AlertDescription>Cadastre um cartão para assinar um plano.</AlertDescription>
                        </Alert>

                        <SecureCardInput
                            onTokenHtml={handleTokenHtml}
                            onCancel={() => { }}
                            loading={false}
                        />
                    </div>
                )}

                <ReplaceCardModal
                    isOpen={isReplaceModalOpen}
                    onClose={() => setIsReplaceModalOpen(false)}
                    onSave={handleModalSave}
                />
            </div>
        </div>
    );
}
