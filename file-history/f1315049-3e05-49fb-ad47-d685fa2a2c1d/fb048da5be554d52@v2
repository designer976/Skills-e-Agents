<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Demo - Template de Proposta Wa Project</title>
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
    <style>
        :root {
            /* Design System Tokens */
            --background: hsl(0 0% 100%);
            --foreground: hsl(0 0% 3.9%);
            --card: hsl(0 0% 96.1%);
            --card-foreground: hsl(0 0% 3.9%);
            --border: hsl(0 0% 89.8%);
            --muted-foreground: hsl(0 0% 45.1%);
            --radius: 1rem;

            /* Wa Project Brand Tokens */
            --wa-brand-primary: hsl(211 100% 22%);     /* #003B71 - Azul corporativo oficial */
            --wa-brand-accent: hsl(211 83% 95%);       /* #E8F0FE - Azul claro para hover/accent */
            --wa-brand-foreground: hsl(0 0% 100%);     /* #FFFFFF - Branco para contraste */
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background-color: hsl(var(--background));
            color: hsl(var(--foreground));
            line-height: 1.5;
            padding: 20px;
        }

        /* Container principal */
        .proposal-container {
            display: flex;
            flex-direction: column;
            height: calc(100vh - 40px);
            border-radius: 0.5rem;
            border: 1px solid hsl(var(--border));
            background-color: hsl(var(--card));
            box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1);
        }

        /* Header */
        .proposal-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.5rem;
            border-bottom: 1px solid hsl(var(--border));
            padding: 0.75rem 1rem;
        }

        .proposal-header h2 {
            font-size: 0.875rem;
            font-weight: 600;
            color: hsl(var(--foreground));
        }

        /* Button */
        .download-button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.375rem;
            white-space: nowrap;
            border-radius: 0.375rem;
            font-size: 0.875rem;
            font-weight: 500;
            transition: background-color 0.2s, color 0.2s, border-color 0.2s;
            cursor: pointer;
            border: 1px solid hsl(var(--wa-brand-primary) / 0.3);
            background-color: hsl(var(--background));
            color: hsl(var(--wa-brand-primary));
            height: 2rem;
            padding: 0.5rem 0.75rem;
        }

        .download-button:hover {
            background-color: hsl(var(--wa-brand-accent));
        }

        .download-button:disabled {
            pointer-events: none;
            opacity: 0.5;
        }

        .download-button svg {
            width: 0.875rem;
            height: 0.875rem;
        }

        .download-button.loading svg.download {
            display: none;
        }

        .download-button.loading svg.loading {
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        /* Content area */
        .proposal-content {
            flex: 1;
            overflow-y: auto;
            padding: 1rem 1.5rem;
        }

        .document-wrapper {
            margin: 0 auto;
            max-width: 700px;
            border-radius: 0.5rem;
            border: 1px solid hsl(var(--border));
            background-color: hsl(var(--background));
            padding: 2rem;
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
        }

        /* Document header */
        .document-header {
            margin-bottom: 2rem;
            text-align: center;
        }

        .logo-container {
            margin-bottom: 1.5rem;
            display: flex;
            justify-content: center;
        }

        .logo-box {
            height: 3rem;
            width: 8rem;
            background-color: hsl(var(--wa-brand-primary));
            border-radius: 0.25rem;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .logo-text {
            color: hsl(var(--wa-brand-foreground));
            font-weight: bold;
            font-size: 1.125rem;
        }

        .document-title {
            font-size: 1.5rem;
            font-weight: 800;
            color: hsl(var(--wa-brand-primary));
            margin-bottom: 0.5rem;
        }

        .project-title {
            font-size: 1.25rem;
            font-weight: bold;
            color: hsl(var(--wa-brand-primary));
            margin-bottom: 1rem;
        }

        .document-info {
            font-size: 0.875rem;
            color: hsl(var(--foreground));
            margin-bottom: 1rem;
        }

        .document-info p {
            margin-bottom: 0.25rem;
        }

        .document-info strong {
            font-weight: bold;
        }

        .separator-line {
            margin: 0 auto;
            height: 1px;
            width: 4rem;
            background-color: hsl(var(--wa-brand-primary) / 0.3);
            margin-bottom: 1.5rem;
        }

        /* Document sections */
        .document-sections {
            margin-bottom: 2rem;
        }

        .section {
            border-radius: 0.375rem;
            padding: 0.75rem;
            margin-bottom: 2rem;
            transition: background-color 0.2s;
        }

        .section.highlighted {
            animation: highlight-flash 1.5s ease-out;
        }

        @keyframes highlight-flash {
            0% { background-color: #fef3c7; }
            100% { background-color: transparent; }
        }

        .section-title {
            margin-bottom: 0.75rem;
            font-size: 1.125rem;
            font-weight: bold;
            color: hsl(var(--wa-brand-primary));
            border-bottom: 1px solid hsl(var(--wa-brand-primary) / 0.2);
            padding-bottom: 0.5rem;
        }

        .section-content {
            font-size: 0.875rem;
            color: hsl(var(--foreground));
            line-height: 1.6;
        }

        .section-content h3 {
            font-size: 0.875rem;
            font-weight: 600;
            color: hsl(var(--wa-brand-primary));
            margin-top: 1rem;
            margin-bottom: 0.5rem;
        }

        .section-content p {
            margin-bottom: 0.5rem;
        }

        .section-content li {
            font-size: 0.875rem;
            color: hsl(var(--foreground));
            margin-left: 1rem;
            margin-bottom: 0.25rem;
        }

        .section-content .numbered-item {
            font-size: 0.875rem;
            color: hsl(var(--foreground));
            margin-bottom: 0.5rem;
        }

        .section-content .numbered-item strong {
            font-weight: bold;
        }

        /* Document footer */
        .document-footer {
            margin-top: 3rem;
            padding-top: 2rem;
            border-top: 1px solid hsl(var(--border));
            text-align: center;
        }

        .footer-message {
            margin-bottom: 1.5rem;
        }

        .footer-quote {
            font-size: 1.125rem;
            font-weight: bold;
            color: hsl(var(--wa-brand-primary));
            margin-bottom: 0.5rem;
        }

        .footer-thanks {
            font-size: 1rem;
            font-weight: 600;
            color: hsl(var(--foreground));
        }

        .company-info {
            font-size: 0.75rem;
            color: hsl(var(--muted-foreground));
            margin-bottom: 1rem;
        }

        .company-info p {
            margin-bottom: 0.25rem;
        }

        .company-info strong {
            font-weight: bold;
        }

        .validity-info {
            margin-top: 1rem;
            font-size: 0.75rem;
            color: hsl(var(--muted-foreground));
        }

        .footer-logo {
            margin-top: 1rem;
            display: flex;
            justify-content: center;
        }

        .footer-logo-box {
            height: 1.5rem;
            width: 5rem;
            background-color: hsl(var(--wa-brand-primary));
            border-radius: 0.25rem;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .footer-logo-text {
            color: hsl(var(--wa-brand-foreground));
            font-weight: bold;
            font-size: 0.75rem;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .proposal-content {
                padding: 1rem;
            }

            .document-wrapper {
                padding: 1rem;
            }

            .document-title {
                font-size: 1.25rem;
            }

            .project-title {
                font-size: 1.125rem;
            }
        }
    </style>
</head>
<body>
    <div class="proposal-container">
        <!-- Header -->
        <div class="proposal-header">
            <h2>Proposta Comercial - Wa Project</h2>
            <button class="download-button" id="downloadBtn" onclick="handleDownload()">
                <svg class="download" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                    <polyline points="7,10 12,15 17,10"/>
                    <line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                <svg class="loading" style="display: none;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 12c0 4.97-4.03 9-9 9s-9-4.03-9-9 4.03-9 9-9c.239 0 .474.01.706.03"/>
                    <path d="M12 2v1"/>
                    <path d="m13.05 2.05l-.707.707"/>
                    <path d="M13 13L8 8l-2-2"/>
                </svg>
                Baixar PDF
            </button>
        </div>

        <!-- Content -->
        <div class="proposal-content">
            <div class="document-wrapper">
                <!-- Document header -->
                <div class="document-header">
                    <!-- Logo -->
                    <div class="logo-container">
                        <div class="logo-box">
                            <span class="logo-text">Wa Project</span>
                        </div>
                    </div>

                    <!-- Title -->
                    <h1 class="document-title">Proposta Comercial</h1>

                    <!-- Project name -->
                    <h2 class="project-title">Sistema de Gestão ERP Customizado</h2>

                    <!-- Document info -->
                    <div class="document-info">
                        <p>30/03/2026 | Válido por 30 dias</p>
                        <p><strong>Para:</strong> TechNova Soluções LTDA</p>
                        <p><strong>Tipo:</strong> Escopo Fechado</p>
                    </div>

                    <!-- Separator line -->
                    <div class="separator-line"></div>
                </div>

                <!-- Document sections -->
                <div class="document-sections">
                    <div class="section">
                        <h2 class="section-title">Apresentação</h2>
                        <div class="section-content">
                            <p>É com grande satisfação que a <strong>Wa Project</strong> apresenta esta proposta comercial para o desenvolvimento de um Sistema de Gestão ERP Customizado para a TechNova Soluções.</p>

                            <p>Com mais de 13 anos de experiência no mercado de desenvolvimento de software, somos especializados em criar soluções tecnológicas inovadoras que transformam negócios e geram resultados excepcionais.</p>
                        </div>
                    </div>

                    <div class="section">
                        <h2 class="section-title">Sobre o Projeto</h2>
                        <div class="section-content">
                            <p>O sistema proposto será uma solução completa de gestão empresarial, integrando os principais módulos operacionais da TechNova Soluções:</p>

                            <h3>Módulos Incluídos</h3>
                            <ul>
                                <li>Gestão Financeira completa com fluxo de caixa</li>
                                <li>Controle de Estoque e Inventário</li>
                                <li>CRM integrado para gestão de clientes</li>
                                <li>Relatórios gerenciais e dashboards</li>
                                <li>Sistema de usuários com controle de acesso</li>
                            </ul>
                        </div>
                    </div>

                    <div class="section">
                        <h2 class="section-title">Escopo Técnico</h2>
                        <div class="section-content">
                            <h3>Tecnologias Propostas</h3>
                            <ul>
                                <li><strong>Backend:</strong> Node.js + TypeScript + Express</li>
                                <li><strong>Frontend:</strong> React + Next.js + TypeScript</li>
                                <li><strong>Banco de Dados:</strong> PostgreSQL</li>
                                <li><strong>Infraestrutura:</strong> AWS (EC2, RDS, S3)</li>
                                <li><strong>Autenticação:</strong> JWT + OAuth 2.0</li>
                            </ul>

                            <h3>Funcionalidades Principais</h3>
                            <div class="numbered-item">
                                <strong>1.</strong> Dashboard executivo com métricas em tempo real
                            </div>
                            <div class="numbered-item">
                                <strong>2.</strong> Sistema completo de faturamento e cobrança
                            </div>
                            <div class="numbered-item">
                                <strong>3.</strong> Integração com APIs de bancos e meios de pagamento
                            </div>
                            <div class="numbered-item">
                                <strong>4.</strong> Relatórios personalizáveis e exportação em PDF/Excel
                            </div>
                        </div>
                    </div>

                    <div class="section highlighted">
                        <h2 class="section-title">Metodologia de Desenvolvimento</h2>
                        <div class="section-content">
                            <p>Utilizamos metodologia ágil (Scrum) com entregas incrementais e feedback contínuo:</p>

                            <ul>
                                <li>Sprints de 2 semanas com demos regulares</li>
                                <li>Daily meetings para acompanhamento</li>
                                <li>Testes automatizados em todas as funcionalidades</li>
                                <li>Deploy contínuo em ambiente de homologação</li>
                                <li>Documentação técnica completa</li>
                            </ul>
                        </div>
                    </div>

                    <div class="section">
                        <h2 class="section-title">Timeline do Projeto</h2>
                        <div class="section-content">
                            <div class="numbered-item">
                                <strong>Fase 1 - Planejamento (2 semanas):</strong> Levantamento detalhado de requisitos e prototipagem
                            </div>
                            <div class="numbered-item">
                                <strong>Fase 2 - Desenvolvimento Core (8 semanas):</strong> Implementação dos módulos principais
                            </div>
                            <div class="numbered-item">
                                <strong>Fase 3 - Integrações (3 semanas):</strong> APIs externas e sistemas legados
                            </div>
                            <div class="numbered-item">
                                <strong>Fase 4 - Homologação (2 semanas):</strong> Testes, ajustes e treinamento
                            </div>
                        </div>
                    </div>

                    <div class="section">
                        <h2 class="section-title">Investimento</h2>
                        <div class="section-content">
                            <p><strong>Valor Total:</strong> R$ 89.500,00</p>
                            <p><strong>Prazo de Entrega:</strong> 15 semanas (aproximadamente 4 meses)</p>

                            <h3>Condições de Pagamento</h3>
                            <ul>
                                <li>30% na assinatura do contrato</li>
                                <li>40% na entrega dos módulos principais</li>
                                <li>30% na entrega final e homologação</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Document footer -->
                <div class="document-footer">
                    <div class="footer-message">
                        <p class="footer-quote">Não é sobre desenvolvimento, é sobre envolvimento.</p>
                        <p class="footer-thanks">Obrigado por confiar na Wa Project!</p>
                    </div>

                    <div class="company-info">
                        <p><strong>Wa Project Soluções Tecnológicas LTDA.</strong></p>
                        <p>CNPJ: 19.317.018/0001-40</p>
                        <p>Website: waproject.com.br</p>
                        <p>Email: comercial@waproject.com.br</p>
                        <p>Telefone/WhatsApp: (11) 5028-2010</p>
                    </div>

                    <p class="validity-info">
                        Proposta válida por 30 dias a partir da data de emissão
                    </p>

                    <div class="footer-logo">
                        <div class="footer-logo-box">
                            <span class="footer-logo-text">Wa Project</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function handleDownload() {
            const button = document.getElementById('downloadBtn');
            const downloadIcon = button.querySelector('.download');
            const loadingIcon = button.querySelector('.loading');

            // Simular loading
            button.disabled = true;
            button.classList.add('loading');
            downloadIcon.style.display = 'none';
            loadingIcon.style.display = 'inline-block';

            // Simular geração de PDF
            setTimeout(() => {
                // Reset button state
                button.disabled = false;
                button.classList.remove('loading');
                downloadIcon.style.display = 'inline-block';
                loadingIcon.style.display = 'none';

                // Simular download
                alert('PDF gerado com sucesso!\n\nEsta é uma demonstração. No sistema real, o PDF seria baixado automaticamente.');
            }, 2000);
        }

        // Simular highlight de seção após carregamento
        window.addEventListener('load', () => {
            setTimeout(() => {
                const highlightedSection = document.querySelector('.section.highlighted');
                if (highlightedSection) {
                    highlightedSection.style.animation = 'highlight-flash 1.5s ease-out';
                }
            }, 1000);
        });
    </script>
</body>
</html>