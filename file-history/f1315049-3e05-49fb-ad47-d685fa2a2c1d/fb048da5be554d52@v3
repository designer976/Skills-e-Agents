    <script>
        function handleDownload() {
            const button = document.getElementById('downloadBtn');
            const downloadIcon = button.querySelector('.download');
            const loadingIcon = button.querySelector('.loading');

            // Simular loading
            button.disabled = true;
            button.classList.add('loading');
            downloadIcon.style.display = 'none';
            loadingIcon.style.display = 'inline-block';

            // Simular geração de PDF
            setTimeout(() => {
                // Reset button state
                button.disabled = false;
                button.classList.remove('loading');
                downloadIcon.style.display = 'inline-block';
                loadingIcon.style.display = 'none';

                // Simular download
                alert('PDF gerado com sucesso!\n\nEsta é uma demonstração. No sistema real, o arquivo "Proposta_Easy_Salon_27-03-2026.pdf" seria baixado automaticamente.');
            }, 2500);
        }

        // Aplicar animação suave ao scroll
        document.addEventListener('DOMContentLoaded', function() {
            // Smooth scroll behavior
            document.documentElement.style.scrollBehavior = 'smooth';

            // Fade in animation
            const sections = document.querySelectorAll('.section');
            sections.forEach((section, index) => {
                section.style.opacity = '0';
                section.style.transform = 'translateY(20px)';
                section.style.transition = 'opacity 0.6s ease, transform 0.6s ease';

                setTimeout(() => {
                    section.style.opacity = '1';
                    section.style.transform = 'translateY(0)';
                }, index * 100);
            });
        });
    </script>
