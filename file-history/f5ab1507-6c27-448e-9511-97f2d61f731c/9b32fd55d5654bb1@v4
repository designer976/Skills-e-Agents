import { useState, useEffect, useCallback } from "react";
import { useNavigate } from "react-router-dom";
import { Pencil, Clock, Briefcase, Lock, UserX, Trash2, Search, ChevronDown } from "lucide-react";
import { LoadingSpinner } from "@/components/ui/loading-spinner";
import { EasySalonLayout } from "@/components/layout/EasySalonLayout";
import { PageHeader } from "@/components/layout/PageHeader";
import { DataTable, Column, TableAction } from "@/components/ui/data-table";
import { Button } from "@/components/ui/button";
import { Badge } from "@/components/ui/badge";
import { Input } from "@/components/ui/input";
import {
  DropdownMenu,
  DropdownMenuContent,
  DropdownMenuItem,
  DropdownMenuSeparator,
  DropdownMenuTrigger,
} from "@/components/ui/dropdown-menu";
import {
  AlertDialog,
  AlertDialogAction,
  AlertDialogCancel,
  AlertDialogContent,
  AlertDialogDescription,
  AlertDialogFooter,
  AlertDialogHeader,
  AlertDialogTitle,
} from "@/components/ui/alert-dialog";
import { getSalonNavItems } from "@/config/navigation";
import { useAuth } from "@/contexts/AuthContext";
import { useSelectedSalon } from "@/hooks/useSelectedSalon";
import { userService } from "@/services/userService";
import { User, UserRole } from "@/types/user";
import { toast } from "sonner";
import { getErrorMessage } from "@/utils/error";
import { useDebouncedValue } from "@/hooks/useDebouncedValue";
import { formatPhone } from "@/utils/formatters";
import { ResponsivePagination } from "@/components/ui/responsive-pagination";

export default function SalonUsersPage() {
  const navigate = useNavigate();
  const { selectedSalon } = useSelectedSalon();
  const { user } = useAuth();
  const [users, setUsers] = useState<User[]>([]);
  const [loading, setLoading] = useState(true);
  const [searchTerm, setSearchTerm] = useState("");
  const debouncedSearchTerm = useDebouncedValue(searchTerm, 500);
  const [statusFilter, setStatusFilter] = useState<string>("all");
  const [currentPage, setCurrentPage] = useState(1);
  const [totalPages, setTotalPages] = useState(1);
  const [totalItems, setTotalItems] = useState(0);
  const [pageSize, setPageSize] = useState(16);
  const [userToDelete, setUserToDelete] = useState<User | null>(null);

  const navItems = getSalonNavItems(user?.role || "Profissional");

  const loadUsers = useCallback(
    async (
      page: number = 1,
      search?: string,
      status?: string,
      limit: number = pageSize
    ): Promise<void> => {
      try {
        setLoading(true);
        const searchParam = search && search.trim() ? search.trim() : undefined;
        const params = {
          salonId: selectedSalon?.id,
          search: searchParam,
          status: status && status !== "all" ? (status as "active" | "inactive") : undefined,
          page,
          limit,
          sortBy: "name",
          sortOrder: "asc" as const,
        };

        const response = await userService.list(params);

        // Filter to show only salon-level roles (Manager, Professional and Receptionist)
        // Exclude platform admin roles (super_admin, tenant_admin) and client role
        const filteredUsers = response.data.filter(
          (user) =>
            user.role === "manager" ||
            user.role === "professional" ||
            user.role === "receptionist"
        );
        setUsers(filteredUsers);
        setTotalPages(
          response.totalPages ||
            Math.ceil((response.total || filteredUsers.length) / limit)
        );
        setTotalItems(response.total || filteredUsers.length);
      } catch (error) {
        toast.error(getErrorMessage(error) || "Erro ao carregar usuários.");
        setUsers([]);
      } finally {
        setLoading(false);
      }
    },
    [selectedSalon?.id, pageSize]
  );

  // Load users from backend with debounce for search
  useEffect(() => {
    // Garantir que a página comece no topo (especialmente no mobile)
    window.scrollTo(0, 0);
  }, []);

  useEffect(() => {
    if (selectedSalon?.id) {
      loadUsers(currentPage, debouncedSearchTerm, statusFilter, pageSize);
    }
  }, [
    selectedSalon?.id,
    currentPage,
    debouncedSearchTerm,
    statusFilter,
    pageSize,
  ]);

  // Reset to first page when search or filter changes
  useEffect(() => {
    setCurrentPage(1);
  }, [debouncedSearchTerm, statusFilter]);

  const handleNewUser = (): void => {
    navigate("/salon/users/create");
  };

  const handleEditUser = (user: User): void => {
    navigate(`/salon/users/edit/${user.id}`);
  };

  const handleUserSchedule = (user: User): void => {
    navigate(`/salon/users/${user.id}/schedule`);
  };

  const handleUserServices = (user: User): void => {
    navigate(`/salon/users/${user.id}/services`);
  };

  const handleUserPassword = (user: User): void => {
    navigate(`/salon/users/${user.id}/password`);
  };

  const handleToggleUserStatus = async (user: User): Promise<void> => {
    try {
      setLoading(true);
      const newStatus = !user.active;
      await userService.update(user.id, { active: newStatus });

      toast.success(
        `Usuário ${newStatus ? "ativado" : "desativado"} com sucesso!`
      );
      loadUsers(currentPage, debouncedSearchTerm, statusFilter, pageSize);
    } catch (error) {
      toast.error(
        getErrorMessage(error) || "Erro ao alterar status do usuário."
      );
    } finally {
      setLoading(false);
    }
  };

  const handleDeleteUser = async (user: User): Promise<void> => {
    try {
      setLoading(true);
      await userService.delete(user.id);

      toast.success("Usuário excluído com sucesso!");
      loadUsers(currentPage, debouncedSearchTerm, statusFilter, pageSize);
    } catch (error) {
      toast.error(getErrorMessage(error) || "Erro ao excluir usuário.");
    } finally {
      setLoading(false);
    }
  };

  const handlePageSizeChange = (value: string): void => {
    const newPageSize = Number(value);
    setPageSize(newPageSize);
    setCurrentPage(1);
  };

  const getRoleLabel = (role: UserRole): string => {
    return userService.getRoleLabel(role);
  };

  const columns: Column<User>[] = [
    {
      key: "nickname",
      header: "Apelido",
      render: (value: string | undefined): string => value || "-",
    },
    {
      key: "name",
      header: "Nome",
    },
    {
      key: "role",
      header: "Perfil",
      render: (value: UserRole): string => getRoleLabel(value),
    },
    {
      key: "email",
      header: "Email",
    },
    {
      key: "whatsapp",
      header: "WhatsApp",
      render: (value: string | undefined): string => value ? formatPhone(value) : "-",
    },
    {
      key: "active",
      header: "Status",
      render: (value: boolean): JSX.Element => (
        <Badge className={value ? "salon-badge-active" : "salon-badge-inactive"}>
          {value ? "Ativo" : "Inativo"}
        </Badge>
      ),
    },
  ];

  const userActions: TableAction<User>[] = [
    {
      label: "Editar",
      icon: <Pencil className="h-4 w-4" />,
      onClick: (row: User): void => handleEditUser(row),
    },
    {
      label: "Gerenciar horários",
      icon: <Clock className="h-4 w-4" />,
      onClick: (row: User): void => handleUserSchedule(row),
      hidden: (row: User): boolean => row.role !== "professional",
    },
    {
      label: "Gerenciar serviços",
      icon: <Briefcase className="h-4 w-4" />,
      onClick: (row: User): void => handleUserServices(row),
      hidden: (row: User): boolean => row.role !== "professional",
    },
    {
      label: "Alterar senha",
      icon: <Lock className="h-4 w-4" />,
      onClick: (row: User): void => handleUserPassword(row),
      disabled: (_row: User): boolean => !selectedSalon?.active,
    },
    {
      label: "Alterar status",
      icon: <UserX className="h-4 w-4" />,
      onClick: (row: User): void => { void handleToggleUserStatus(row); },
      disabled: (_row: User): boolean => !selectedSalon?.active,
    },
    {
      label: "Excluir usuário",
      icon: <Trash2 className="h-4 w-4" />,
      variant: "destructive",
      onClick: (row: User): void => setUserToDelete(row),
      disabled: (_row: User): boolean => !selectedSalon?.active,
    },
  ];

  return (
    <EasySalonLayout
      sideNavTitle="Easy Salon"
      sideNavSubtitle={selectedSalon?.name || "Salão"}
      sideNavItems={navItems}
    >
      <PageHeader
        title="Usuários do Salão"
        disabledActions={!selectedSalon?.active}
        action={{
          label: "Novo Usuário",
          onClick: handleNewUser,
        }}
      />

      {/* Barra de Ferramentas Responsiva */}
      <div className="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
        <div className="flex flex-col sm:flex-row items-center gap-4 w-full md:w-auto">
          <div className="relative w-full sm:max-w-sm">
            <Search className="absolute left-3 top-1/2 transform -translate-y-1/2 text-muted-foreground h-4 w-4" />
            <Input
              type="text"
              placeholder="Buscar por nome ou email..."
              value={searchTerm}
              onChange={(e) => setSearchTerm(e.target.value)}
              className="pl-10 salon-input"
            />
          </div>
          <DropdownMenu>
            <DropdownMenuTrigger asChild>
              <Button
                variant="outline"
                size="sm"
                className={statusFilter !== "all" ? "bg-primary/10 border-primary/40 text-primary" : ""}
              >
                <span className="truncate">
                  {statusFilter === "active" ? "Ativos" : statusFilter === "inactive" ? "Inativos" : "Status"}
                </span>
                <ChevronDown className="h-4 w-4 flex-shrink-0" />
              </Button>
            </DropdownMenuTrigger>
            <DropdownMenuContent className="w-40 p-0 bg-card border border-border shadow-lg" align="end">
              <DropdownMenuItem onClick={() => setStatusFilter("all")}>
                Todos
              </DropdownMenuItem>
              <DropdownMenuSeparator />
              <DropdownMenuItem
                onClick={() => setStatusFilter("active")}
                className={statusFilter === "active" ? "bg-accent" : ""}
              >
                Ativos
              </DropdownMenuItem>
              <DropdownMenuItem
                onClick={() => setStatusFilter("inactive")}
                className={statusFilter === "inactive" ? "bg-accent" : ""}
              >
                Inativos
              </DropdownMenuItem>
            </DropdownMenuContent>
          </DropdownMenu>
        </div>
      </div>

      {loading ? (
        <div className="flex justify-center items-center h-64">
          <LoadingSpinner size="md" />
        </div>
      ) : users.length === 0 ? (
        <div className="text-center py-12">
          <p className="text-muted-foreground mb-4">
            {searchTerm || statusFilter !== "all"
              ? "Nenhum usuário encontrado com os filtros aplicados."
              : "Nenhum usuário cadastrado ainda."}
          </p>
          {!searchTerm && statusFilter === "all" && (
            <Button onClick={handleNewUser}>Cadastrar Primeiro Usuário</Button>
          )}
        </div>
      ) : (
        <>
          <DataTable<User>
            data={users}
            columns={columns}
            actions={userActions}
            mobileView="cards"
            mobileCardConfig={{
              title: "nickname",
              subtitle: "email",
              badge: (row: User) => (
                <Badge variant="outline" className={row.active ? "salon-badge-active" : "salon-badge-inactive"}>
                  {row.active ? "Ativo" : "Inativo"}
                </Badge>
              ),
            }}
          />

          <ResponsivePagination
            currentPage={currentPage}
            totalPages={totalPages}
            totalItems={totalItems}
            pageSize={pageSize}
            onPageChange={setCurrentPage}
            onPageSizeChange={(size) => handlePageSizeChange(String(size))}
          />
        </>
      )}
      <AlertDialog open={userToDelete !== null} onOpenChange={(open) => { if (!open) setUserToDelete(null); }}>
        <AlertDialogContent className="w-[95vw] max-w-[400px] rounded-lg p-6 gap-6">
          <AlertDialogHeader className="text-left">
            <AlertDialogTitle className="text-section-title">Excluir usuário</AlertDialogTitle>
            <AlertDialogDescription className="text-base pt-2">
              Tem certeza que deseja excluir o usuário "{userToDelete?.name}"? Esta
              ação não pode ser desfeita.
            </AlertDialogDescription>
          </AlertDialogHeader>
          <AlertDialogFooter className="flex flex-col-reverse sm:flex-row gap-3">
            <AlertDialogCancel className="w-full sm:w-auto min-h-[44px] rounded-lg mt-0">Cancelar</AlertDialogCancel>
            <AlertDialogAction
              onClick={() => { if (userToDelete) void handleDeleteUser(userToDelete); }}
              className="w-full sm:w-auto min-h-[44px] rounded-lg bg-destructive hover:bg-destructive/90 shadow-md transition-all active:scale-[0.98]"
            >
              Excluir
            </AlertDialogAction>
          </AlertDialogFooter>
        </AlertDialogContent>
      </AlertDialog>
    </EasySalonLayout>
  );
}
