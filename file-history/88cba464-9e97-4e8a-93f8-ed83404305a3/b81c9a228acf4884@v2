export default function ClienteDashboard() {
  const [loading, setLoading] = useState(true)
  const [estado, setEstado] = useState("todos")
  const [periodo, setPeriodo] = useState<PeriodoDashboard>("mes")
  const [filtroVistoria, setFiltroVistoria] = useState<"todos" | "Pedido" | "Em andamento" | "Concluído">("todos")
  const [expandida, setExpandida] = useState<string | null>(null)

  useEffect(() => { const t = setTimeout(() => setLoading(false), 1200); return () => clearTimeout(t) }, [])

  return (
    <AdminDashboardLayout profile="cliente" title="Dashboard">
      {loading ? <DashboardSkeleton /> : (
        <>
          <div className="mb-6">
            <h2 className="text-2xl font-bold text-gray-900">Bom dia, Maria!</h2>
            <p className="text-sm text-gray-500 mt-1">Aqui está o resumo das suas vistorias.</p>
          </div>

          {/* Filtros */}
          <DashboardFilters
            estado={estado} onEstadoChange={setEstado}
            periodo={periodo} onPeriodoChange={setPeriodo}
            className="mb-6"
          />

          <div className="grid grid-cols-2 lg:grid-cols-4 gap-5 mb-8">            <StatCard title="Vistorias Ativas" value="8" icon={ClipboardCheck} color="#0B7A8F" sub="Em execução agora" />
            <StatCard title="Aguardando Agendamento" value="3" icon={Clock} color="#F59E0B" sub="Pendentes de data" />
            <StatCard title="Concluídas (Mês)" value="27" icon={CheckCircle2} color="#10B981" sub="Relatórios disponíveis" />
            <StatCard title="Divergências Abertas" value="2" icon={AlertTriangle} color="#EF4444" sub="Requerem atenção" />
          </div>

          {/* Vistorias Recentes — largura total */}
          <div className="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden mb-6">
              {/* Header + filtro */}
              <div className="flex flex-wrap items-center justify-between gap-3 px-6 py-4 border-b border-gray-100">
                <h3 className="text-base font-bold text-gray-900">Vistorias Recentes</h3>
                <div className="flex items-center gap-2">
                  {/* Filtro de status */}
                  <div className="flex items-center gap-1 bg-gray-100 rounded-lg p-1">
                    {(["todos", "Pedido", "Em andamento", "Concluído"] as const).map((f) => (
                      <button
                        key={f}
                        type="button"
                        onClick={() => setFiltroVistoria(f)}
                        className={`px-3 h-7 text-xs font-medium rounded-md transition-all ${
                          filtroVistoria === f
                            ? "bg-white text-[#002533] shadow-sm"
                            : "text-gray-500 hover:text-gray-700"
                        }`}
                      >
                        {f === "todos" ? "Todos" : f}
                      </button>
                    ))}
                  </div>
                  <Link href="/admin/cliente/vistorias/andamento">
                    <AdminButton variant="ghost" size="sm" icon={<ArrowRight size={15} />}>
                      Ver todas
                    </AdminButton>
                  </Link>
                </div>
              </div>

              {/* Linhas */}
              <div className="divide-y divide-gray-100">
                {/* Header */}
                <div className="grid grid-cols-[1fr_2fr_1fr_auto_auto_auto] items-center gap-3 px-6 py-3 bg-gray-50 border-b border-gray-100">
                  <span className="text-xs font-semibold text-gray-500 uppercase tracking-wide">Código</span>
                  <span className="text-xs font-semibold text-gray-500 uppercase tracking-wide">Endereço</span>
                  <span className="text-xs font-semibold text-gray-500 uppercase tracking-wide">Tipo</span>
                  <span className="text-xs font-semibold text-gray-500 uppercase tracking-wide">Status</span>
                  <span className="text-xs font-semibold text-gray-500 uppercase tracking-wide"></span>
                  <span className="text-xs font-semibold text-gray-500 uppercase tracking-wide"></span>
                </div>

                {vistorias
                  .filter((v) => filtroVistoria === "todos" || v.status === filtroVistoria)
                  .map((v) => (
                    <div key={v.id}>
                      {/* Linha principal */}
                      <div
                        className="grid grid-cols-[1fr_2fr_1fr_auto_auto_auto] items-center gap-3 px-6 py-3.5 hover:bg-gray-50 transition-colors cursor-pointer text-sm"
                        onClick={() => setExpandida(expandida === v.id ? null : v.id)}
                      >
                        <span className="font-mono text-xs text-gray-400">{v.id}</span>
                        <span className="text-gray-700 truncate">{v.endereco}</span>
                        <span className="text-gray-500">{v.tipo}</span>
                        <span className={`px-2 py-1 rounded-full text-xs font-semibold whitespace-nowrap ${v.statusColor}`}>
                          {v.status}
                        </span>
                        {/* Botão olho — navega para página de detalhe */}
                        <Link href={`/admin/cliente/vistorias/${v.id}`} onClick={(e) => e.stopPropagation()}>
                          <AdminButton
                            variant="ghost"
                            size="sm"
                            icon={<Eye size={14} />}
                            className="h-7 w-7 p-0"
                            title="Ver vistoria"
                          />
                        </Link>
                        {/* Botão download — só se tiver relatório */}
                        {v.temRelatorio ? (
                          <AdminButton
                            variant="ghost"
                            size="sm"
                            icon={<Download size={14} />}
                            className="h-7 w-7 p-0 text-[#0B7A8F]"
                            title="Baixar relatório"
                            onClick={(e) => { e.stopPropagation() }}
                          />
                        ) : (
                          <span className="h-7 w-7" />
                        )}
                      </div>

                      {/* Linha do tempo — expande ao clicar */}
                      {expandida === v.id && (
                        <div className="px-6 pb-5 pt-2 bg-gray-50 border-t border-gray-100">
                          <p className="text-xs text-gray-400 font-semibold uppercase mb-3">Etapas da vistoria</p>
                          <div className="flex items-start gap-0">
                            {ETAPAS.map((etapa, idx) => {
                              const concluida = idx < v.etapa
                              const atual     = idx === v.etapa
                              return (
                                <div key={idx} className="flex-1 flex flex-col items-center gap-1 min-w-0">
                                  {/* Linha conectora + círculo */}
                                  <div className="flex items-center w-full">
                                    <div className={`h-0.5 flex-1 ${idx === 0 ? "invisible" : concluida || atual ? "bg-[#0B7A8F]" : "bg-gray-200"}`} />
                                    <div className={`flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center border-2 transition-all ${
                                      concluida
                                        ? "bg-[#0B7A8F] border-[#0B7A8F]"
                                        : atual
                                          ? "bg-white border-[#0B7A8F]"
                                          : "bg-white border-gray-300"
                                    }`}>
                                      {concluida
                                        ? <Check size={12} className="text-white" />
                                        : atual
                                          ? <div className="w-2 h-2 rounded-full bg-[#0B7A8F]" />
                                          : null
                                      }
                                    </div>
                                    <div className={`h-0.5 flex-1 ${idx === ETAPAS.length - 1 ? "invisible" : concluida ? "bg-[#0B7A8F]" : "bg-gray-200"}`} />
                                  </div>
                                  {/* Label */}
                                  <p className={`text-center text-[10px] leading-tight px-1 ${
                                    concluida ? "text-[#0B7A8F] font-medium"
                                    : atual    ? "text-[#002533] font-bold"
                                    :            "text-gray-400"
                                  }`}>
                                    {etapa}
                                  </p>
                                </div>
                              )
                            })}
                          </div>
                        </div>
                      )}
                    </div>
                  ))}
              </div>
          </div>

          {/* Divergências + Resumo — empilhados verticalmente */}
          <div className="space-y-6">
            {/* Resumo do Mês — primeiro */}
            <div className="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                <h3 className="text-base font-bold text-gray-900 mb-4">Resumo do Mês</h3>
                <div className="space-y-3">
                  <div className="flex items-center justify-between">
                    <span className="text-sm text-gray-500">Solicitadas</span>
                    <span className="font-bold text-gray-900">32</span>
                  </div>
                  <div className="flex items-center justify-between">
                    <span className="text-sm text-gray-500">Concluídas</span>
                    <span className="font-bold text-green-600">27</span>
                  </div>
                  <div className="flex items-center justify-between">
                    <span className="text-sm text-gray-500">Taxa de conclusão</span>
                    <span className="flex items-center gap-1 font-bold text-green-600">
                      <TrendingUp size={14} /> 84%
                    </span>
                  </div>
                  <div className="w-full bg-gray-100 rounded-full h-2 mt-2">
                    <div className="bg-[#0B7A8F] h-2 rounded-full" style={{ width: "84%" }} />
                  </div>
                  <div className="pt-2 border-t border-gray-100 flex items-center justify-between">
                    <span className="text-sm text-gray-500">vs. mês anterior</span>
                    <span className="flex items-center gap-1 text-sm font-semibold text-green-600">
                      <TrendingUp size={14} /> +6%
                    </span>
                  </div>
                </div>
              </div>

            {/* Divergências Abertas — abaixo */}
            <div className="space-y-6">
              <div className="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                <h3 className="text-base font-bold text-gray-900 mb-4 flex items-center gap-2">
                  <Bell size={17} className="text-[#0B7A8F]" /> Divergências Abertas
                </h3>
                <div className="space-y-3">
                  <div className="bg-red-50 border border-red-100 rounded-lg p-3">
                    <p className="text-xs font-bold text-red-800">V-2024-1019</p>
                    <p className="text-xs text-red-600 mt-1">Rua Augusta, 45 — Fotos do quarto 2 inconsistentes.</p>
                    <AdminButton variant="ghost" size="sm" className="text-red-700 hover:bg-red-50 mt-2 px-0">Ver divergência →</AdminButton>
                  </div>
                  <div className="bg-yellow-50 border border-yellow-100 rounded-lg p-3">
                    <p className="text-xs font-bold text-yellow-800">V-2024-1015</p>
                    <p className="text-xs text-yellow-700 mt-1">Av. Brasil, 250 — Aguardando parecer do vistoriador.</p>
                    <AdminButton variant="ghost" size="sm" className="text-yellow-800 hover:bg-yellow-50 mt-2 px-0">Ver divergência →</AdminButton>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </>
      )}
    </AdminDashboardLayout>
  )
}
